<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  body { background: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', sans-serif; margin: 0; transition: background 0.2s, color 0.2s; }
  .page-wrap { max-width: 1300px; margin: 0 auto; padding: 1.5rem; }

  /* ===== RSBY-AI CHATBOT WIDGET (PUBLIC VIEW) ===== */
  #ai-fab { position: fixed; bottom: 24px; right: 24px; width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; border: none; cursor: pointer; box-shadow: 0 4px 18px rgba(99,102,241,0.45); display: flex; align-items: center; justify-content: center; z-index: 9998; transition: transform 0.2s, box-shadow 0.2s; }
  #ai-fab:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(99,102,241,0.55); }
  #ai-fab svg { width: 24px; height: 24px; }
  
  #ai-panel { position: fixed; bottom: 88px; right: 24px; width: 360px; max-height: 540px; background: #13161f; border: 1px solid rgba(255,255,255,0.07); border-radius: 16px; box-shadow: 0 12px 40px rgba(0,0,0,0.4); display: none; flex-direction: column; z-index: 9999; overflow: hidden; font-family: inherit; }
  #ai-panel.open { display: flex; }
  
  .ai-header { display: flex; align-items: center; gap: 10px; padding: 14px 16px; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; border-radius: 16px 16px 0 0; flex-shrink: 0; }
  .ai-header-icon { width: 34px; height: 34px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ai-header-title { font-weight: 700; font-size: 14px; line-height: 1.2; }
  .ai-header-sub { font-size: 11px; opacity: 0.8; }
  .ai-header-close { margin-left: auto; background: none; border: none; color: #fff; cursor: pointer; padding: 4px; border-radius: 6px; display: flex; align-items: center; opacity: 0.8; transition: opacity 0.15s; }
  .ai-header-close:hover { opacity: 1; background: rgba(255,255,255,0.15); }
  
  #ai-messages { flex: 1; overflow-y: auto; padding: 14px 14px 8px; display: flex; flex-direction: column; gap: 10px; scroll-behavior: smooth; }
  #ai-messages::-webkit-scrollbar { width: 4px; } #ai-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px; }
  
  .ai-msg { display: flex; gap: 8px; align-items: flex-start; animation: aiMsgIn 0.2s ease; }
  @keyframes aiMsgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .ai-msg.user { flex-direction: row-reverse; }
  .ai-bubble { max-width: 80%; padding: 9px 13px; border-radius: 14px; font-size: 13px; line-height: 1.55; word-break: break-word; white-space: pre-wrap; }
  .ai-msg.bot .ai-bubble { background: #1e2130; color: #e2e8f0; border-radius: 4px 14px 14px 14px; }
  .ai-msg.user .ai-bubble { background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; border-radius: 14px 4px 14px 14px; }
  .ai-avatar { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
  .ai-msg.bot .ai-avatar { background: linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff; }
  .ai-msg.user .ai-avatar { background: #3b4263; color: #e2e8f0; }
  
  .ai-typing .ai-bubble { display: flex; gap: 4px; align-items: center; padding: 12px 16px; }
  .ai-typing .dot { width: 7px; height: 7px; border-radius: 50%; background: #8b8fa8; animation: typingDot 1.2s infinite; }
  .ai-typing .dot:nth-child(2) { animation-delay: 0.2s; } .ai-typing .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingDot { 0%,60%,100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-5px); opacity: 1; } }
  
  .ai-quick { display: flex; flex-wrap: wrap; gap: 6px; padding: 0 14px 10px; flex-shrink: 0; }
  .ai-quick-btn { font-size: 11px; padding: 5px 10px; border: 1px solid rgba(255,255,255,0.12); background: #0f1117; color: #8b8fa8; border-radius: 20px; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .ai-quick-btn:hover { background: #6366f1; color: #fff; border-color: #6366f1; }
  
  .ai-input-area { display: flex; gap: 8px; align-items: flex-end; padding: 10px 14px 14px; border-top: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; background: #13161f; }
  #ai-input { flex: 1; border: 1px solid rgba(255,255,255,0.08); background: #080a10; color: #e2e8f0; border-radius: 10px; padding: 9px 12px; font-size: 13px; resize: none; outline: none; max-height: 100px; min-height: 38px; font-family: inherit; transition: border-color 0.15s; }
  #ai-input:focus { border-color: #818cf8; }
  #ai-send { width: 38px; height: 38px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none; border-radius: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #fff; }
</style>

<button id="ai-fab" onclick="toggleAiPanel()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a6 6 0 0 1 6 6c0 2.4-1.4 4.5-3.5 5.5L16 21H8l1.5-7.5C7.4 12.5 6 10.4 6 8a6 6 0 0 1 6-6z"/><circle cx="9" cy="8" r="1" fill="currentColor"/><circle cx="12" cy="7" r="1" fill="currentColor"/><circle cx="15" cy="8" r="1" fill="currentColor"/></svg></button>

<div id="ai-panel">
  <div class="ai-header">
    <div class="ai-header-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg></div>
    <div>
      <div class="ai-header-title">RSBY-AI Assistant</div>
      <div class="ai-header-sub">Tanya info umum ketersediaan aset</div>
    </div>
    <button class="ai-header-close" onclick="toggleAiPanel()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
  </div>

  <div id="ai-messages">
    <div class="ai-msg bot">
      <div class="ai-avatar">AI</div>
      <div class="ai-bubble">Halo! Saya <strong>RSBY-AI</strong>. 👋<br>Silakan tanya info umum seputar ketersediaan stok aset di sini. Untuk info detail mutasi, harap login terlebih dahulu.</div>
    </div>
  </div>

  <div class="ai-quick" id="aiQuickPrompts">
    <button class="ai-quick-btn" onclick="sendQuick('Aset apa saja yang tersedia saat ini?')">📦 Cek ketersediaan aset</button>
    <button class="ai-quick-btn" onclick="sendQuick('Bagaimana kondisi barang-barang sekarang?')">📊 Status kondisi aset</button>
    <button class="ai-quick-btn" onclick="sendQuick('Berapa banyak divisi yang terdaftar?')">🏢 Info Divisi</button>
  </div>

  <div class="ai-input-area">
    <textarea id="ai-input" placeholder="Tanya sesuatu..." rows="1" onkeydown="aiKeydown(event)"></textarea>
    <button id="ai-send" onclick="sendAiMessage()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg></button>
  </div>
</div>

<script>
(function() {
  var aiHistory = []; var aiOpen = false;
  window.toggleAiPanel = function() { aiOpen = !aiOpen; document.getElementById('ai-panel').classList.toggle('open', aiOpen); if (aiOpen) document.getElementById('ai-input').focus(); };
  window.aiKeydown = function(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAiMessage(); } };
  window.sendQuick = function(msg) { document.getElementById('ai-input').value = msg; sendAiMessage(); document.getElementById('aiQuickPrompts').style.display = 'none'; };

  function appendMsg(role, text) {
    var msgs = document.getElementById('ai-messages'); var div = document.createElement('div'); div.className = 'ai-msg ' + role;
    var html = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g,'<br>');
    div.innerHTML = '<div class="ai-avatar">' + (role==='bot'?'AI':'U') + '</div><div class="ai-bubble">' + html + '</div>';
    msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
  }

  window.sendAiMessage = async function() {
    var input = document.getElementById('ai-input'); var msg = input.value.trim(); if (!msg) return;
    var btn = document.getElementById('ai-send'); input.value = ''; btn.disabled = true;
    appendMsg('user', msg); document.getElementById('aiQuickPrompts').style.display = 'none';
    
    var msgs = document.getElementById('ai-messages'); var t = document.createElement('div'); t.className = 'ai-msg bot ai-typing'; t.id = 'ai-typing';
    t.innerHTML = '<div class="ai-avatar">AI</div><div class="ai-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>'; msgs.appendChild(t); msgs.scrollTop = msgs.scrollHeight;

    try {
      var res = await fetch('/api/ai-chat-public', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg, history: aiHistory }) });
      var data = await res.json(); document.getElementById('ai-typing').remove();
      appendMsg('bot', data.reply || 'Tidak ada respons.');
      aiHistory.push({ role: 'user', content: msg }); aiHistory.push({ role: 'assistant', content: data.reply });
      if (aiHistory.length > 10) aiHistory = aiHistory.slice(-10);
    } catch(err) { document.getElementById('ai-typing').remove(); appendMsg('bot', '⚠️ Gagal terhubung ke AI.'); } 
    finally { btn.disabled = false; input.focus(); }
  };
})();
</script>

<%- include('navbar', {activePage: activePage || 'aset-public'}) %>