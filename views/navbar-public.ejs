      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3"/><path d="M3 12h10"/></svg>
      Export Excel
    </a>
    <% } %>
    <a href="/logout" style="color:#dc2626 !important;">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 8h7m0 0l-2.5-2.5M13 8l-2.5 2.5"/><path d="M9 5V3a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h4a1 1 0 001-1v-2"/></svg>
      Keluar
    </a>
  <% } else { %>
    <a href="/login" style="color:var(--body-accent) !important;">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 8H3m0 0l2.5-2.5M3 8l2.5 2.5"/><path d="M7 5V3a1 1 0 011-1h4a1 1 0 011 1v10a1 1 0 01-1 1H8a1 1 0 01-1-1v-2"/></svg>
      Login ke Dashboard
    </a>
  <% } %>
</div>


<!-- EXPORT MODAL -->
<div id="exportModal">
  <div class="export-modal-box">

    <!-- MODE: LOG (muncul kalau di halaman Home) -->
    <div id="exportModeLog">
      <div class="export-modal-title">📊 Export Log IT ke Excel</div>
      <div class="export-modal-sub">Pilih bulan dan tahun untuk tim audit.</div>
      <div class="export-form-row">
        <select id="exportMonth">
          <option value="1">Januari</option>
          <option value="2">Februari</option>
          <option value="3">Maret</option>
          <option value="4">April</option>
          <option value="5">Mei</option>
          <option value="6">Juni</option>
          <option value="7">Juli</option>
          <option value="8">Agustus</option>
          <option value="9">September</option>
          <option value="10">Oktober</option>
          <option value="11">November</option>
          <option value="12">Desember</option>
        </select>
        <select id="exportYear"></select>
      </div>
      <div class="export-modal-actions">
        <button class="btn-export-confirm" onclick="doExportLog()">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3"/><path d="M3 12h10"/></svg>
          Download Excel
        </button>
        <button class="btn-export-cancel" onclick="document.getElementById('exportModal').style.display='none'">Batal</button>
      </div>
    </div>

    <!-- MODE: ASET (muncul kalau di halaman Aset) -->
    <div id="exportModeAset" style="display:none;">
      <div class="export-modal-title">🗂 Export Data Aset IT ke Excel</div>
      <div class="export-modal-sub">Akan mengunduh seluruh data aset IT saat ini.</div>
      <div style="padding:12px;background:var(--body-bg);border-radius:8px;margin-bottom:1rem;font-size:12px;color:var(--body-text2);">
        📋 Berisi: Nama Aset, Kategori, Satuan, Stok, Kondisi, Jumlah Dipakai, Keterangan
      </div>
      <div class="export-modal-actions">
        <button class="btn-export-confirm" onclick="doExportAset()">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3"/><path d="M3 12h10"/></svg>
          Download Excel
        </button>
        <button class="btn-export-cancel" onclick="document.getElementById('exportModal').style.display='none'">Batal</button>
      </div>
    </div>

  </div>
</div>

<script>
(function() {
  // Isi dropdown tahun
  var now = new Date();
  var curMonth = now.getMonth() + 1;
  var curYear  = now.getFullYear();
  var sel = document.getElementById('exportYear');
  for (var y = curYear; y >= curYear - 5; y--) {
    var opt = document.createElement('option');
    opt.value = y; opt.textContent = y;
    sel.appendChild(opt);
  }
  document.getElementById('exportMonth').value = curMonth;

  // Deteksi halaman aktif lewat activePage yang di-render EJS
  var isAsetPage = '<%= typeof activePage !== "undefined" && activePage === "aset-public" %>' === 'true';

  // Buka modal: tampilkan mode yang sesuai
  window.openExportModal = function() {
    document.getElementById('exportModeLog').style.display  = isAsetPage ? 'none'  : 'block';
    document.getElementById('exportModeAset').style.display = isAsetPage ? 'block' : 'none';
    document.getElementById('exportModal').style.display = 'flex';
  };

  window.doExportLog = function() {
    var m = document.getElementById('exportMonth').value;
    var y = document.getElementById('exportYear').value;
    document.getElementById('exportModal').style.display = 'none';
    window.location.href = '/export?month=' + m + '&year=' + y;
  };

  window.doExportAset = function() {
    document.getElementById('exportModal').style.display = 'none';
    window.location.href = '/export-aset';
  };

  // Tutup modal kalau klik di luar box
  document.getElementById('exportModal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
  });
})();
</script>

<script>
(function() {
  function getTheme() { return localStorage.getItem('itlog-theme') || 'dark'; }
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('itlog-theme', t);
    var lbl   = document.getElementById('navThemeLabel');
    var thumb = document.getElementById('navThumb');
    if (lbl)   lbl.textContent = t === 'dark' ? 'Light' : 'Dark';
    if (thumb) {
      thumb.style.transform  = t === 'light' ? 'translateX(12px)' : '';
      thumb.style.background = t === 'light' ? '#ffffff' : '';
    }
  }
  window.toggleTheme = function() { applyTheme(getTheme() === 'dark' ? 'light' : 'dark'); };
  window.toggleMobileNav = function() {
    var el = document.getElementById('mobileNav');
    if (el) el.classList.toggle('open');
  };
  applyTheme(getTheme());
})();
</script>

