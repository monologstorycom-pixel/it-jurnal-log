  .pub-ai-header-icon { width:34px;height:34px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
  .pub-ai-header-close { margin-left:auto;background:none;border:none;color:#fff;cursor:pointer;padding:4px;border-radius:6px;display:flex;align-items:center;opacity:0.8; }
  .pub-ai-header-close:hover { opacity:1;background:rgba(255,255,255,0.15); }
  #pub-ai-messages { flex:1;overflow-y:auto;padding:14px 14px 8px;display:flex;flex-direction:column;gap:10px;scroll-behavior:smooth; }
  #pub-ai-messages::-webkit-scrollbar { width:4px; }
  #pub-ai-messages::-webkit-scrollbar-thumb { background:var(--body-border2,#ccc);border-radius:4px; }
  .pub-ai-msg { display:flex;gap:8px;align-items:flex-start;animation:pubMsgIn 0.2s ease; }
  @keyframes pubMsgIn { from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)} }
  .pub-ai-msg.user { flex-direction:row-reverse; }
  .pub-ai-bubble { max-width:80%;padding:9px 13px;border-radius:14px;font-size:13px;line-height:1.55;word-break:break-word;white-space:pre-wrap; }
  .pub-ai-msg.bot .pub-ai-bubble { background:var(--body-bg3,#f3f4f6);color:var(--body-text,#111827);border-radius:4px 14px 14px 14px; }
  .pub-ai-msg.user .pub-ai-bubble { background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border-radius:14px 4px 14px 14px; }
  .pub-ai-avatar { width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0; }
  .pub-ai-msg.bot .pub-ai-avatar { background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff; }
  .pub-ai-msg.user .pub-ai-avatar { background:var(--body-bg3,#e5e7eb);color:var(--body-text,#374151); }
  .pub-ai-typing .pub-ai-bubble { display:flex;gap:4px;align-items:center;padding:12px 16px; }
  .pub-ai-typing .dot { width:7px;height:7px;border-radius:50%;background:var(--body-text2,#6b7280);animation:typDot 1.2s infinite; }
  .pub-ai-typing .dot:nth-child(2){animation-delay:0.2s}.pub-ai-typing .dot:nth-child(3){animation-delay:0.4s}
  @keyframes typDot{0%,60%,100%{transform:translateY(0);opacity:0.4}30%{transform:translateY(-5px);opacity:1}}
  .pub-ai-quick { display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 10px;flex-shrink:0; }
  .pub-ai-quick-btn { font-size:11px;padding:5px 10px;border:1px solid var(--body-border2,rgba(0,0,0,0.14));background:var(--body-bg,#f9fafb);color:var(--body-text2,#6b7280);border-radius:20px;cursor:pointer;transition:all 0.15s;white-space:nowrap; }
  .pub-ai-quick-btn:hover { background:#6366f1;color:#fff;border-color:#6366f1; }
  .pub-ai-input-area { display:flex;gap:8px;align-items:flex-end;padding:10px 14px 14px;border-top:1px solid var(--body-border,rgba(0,0,0,0.08));flex-shrink:0;background:var(--body-card,#fff); }
  #pub-ai-input { flex:1;border:1px solid var(--body-input-border,rgba(0,0,0,0.12));background:var(--body-input,#f9fafb);color:var(--body-text,#111827);border-radius:10px;padding:9px 12px;font-size:13px;resize:none;outline:none;max-height:100px;min-height:38px;font-family:inherit;line-height:1.4;transition:border-color 0.15s; }
  #pub-ai-input:focus { border-color:#6366f1; }
  #pub-ai-send { width:38px;height:38px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border:none;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#fff;transition:opacity 0.15s; }
  #pub-ai-send:disabled { opacity:0.5;cursor:not-allowed; }
  @media(max-width:480px){#pub-ai-panel{width:calc(100vw - 24px);right:12px;bottom:80px;}#pub-ai-fab{right:16px;bottom:16px;}}
</style>

<button id="pub-ai-fab" onclick="pubToggleAi()" title="Tanya RSBY-AI">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M12 2a6 6 0 0 1 6 6c0 2.4-1.4 4.5-3.5 5.5L16 21H8l1.5-7.5C7.4 12.5 6 10.4 6 8a6 6 0 0 1 6-6z"/>
    <circle cx="9" cy="8" r="1" fill="currentColor" stroke="none"/>
    <circle cx="12" cy="7" r="1" fill="currentColor" stroke="none"/>
    <circle cx="15" cy="8" r="1" fill="currentColor" stroke="none"/>
  </svg>
</button>

<div id="pub-ai-panel">
  <div class="pub-ai-header">
    <div class="pub-ai-header-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
    </div>
    <div>
      <div style="font-weight:700;font-size:14px;">RSBY-AI Assistant</div>
      <div style="font-size:11px;opacity:0.8;">Powered by Gemini · IT Support</div>
    </div>
    <button class="pub-ai-header-close" onclick="pubToggleAi()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div id="pub-ai-messages">
    <div class="pub-ai-msg bot">
      <div class="pub-ai-avatar">AI</div>
      <div class="pub-ai-bubble">Halo! Saya <strong>RSBY-AI</strong> 👋<br>Tanya saya seputar log IT, status tiket, atau troubleshooting!</div>
    </div>
  </div>

  <div class="pub-ai-quick" id="pubAiQuick">
    <button class="pub-ai-quick-btn" onclick="pubSendQuick('Tiket IT apa saja yang pending?')">📋 Tiket pending</button>
    <button class="pub-ai-quick-btn" onclick="pubSendQuick('Aset IT apa yang tersedia dan stoknya berapa?')">🖥️ Stok aset</button>
    <button class="pub-ai-quick-btn" onclick="pubSendQuick('Aset apa yang sedang dipinjam sekarang?')">🔄 Aset dipinjam</button>
    <button class="pub-ai-quick-btn" onclick="pubSendQuick('Tips komputer lemot?')">💡 Tips IT</button>
  </div>

  <div class="pub-ai-input-area">
    <textarea id="pub-ai-input" placeholder="Tanya sesuatu..." rows="1"
      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();pubSendMsg();}"
      oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'"></textarea>
    <button id="pub-ai-send" onclick="pubSendMsg()">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
    </button>
  </div>
</div>

<script>
(function(){
  var pubHistory = [];
  var pubOpen = false;

  window.pubToggleAi = function(){
    pubOpen = !pubOpen;
    document.getElementById('pub-ai-panel').classList.toggle('open', pubOpen);
    if(pubOpen) document.getElementById('pub-ai-input').focus();
  };

  window.pubSendQuick = function(msg){
    document.getElementById('pub-ai-input').value = msg;
    document.getElementById('pubAiQuick').style.display = 'none';
    pubSendMsg();
  };

  function pubAppend(role, text){
    var msgs = document.getElementById('pub-ai-messages');
    var div = document.createElement('div');
    div.className = 'pub-ai-msg ' + role;
    var av = role === 'bot' ? 'AI' : 'Anda';
    div.innerHTML = '<div class="pub-ai-avatar">' + av.substring(0,2) + '</div><div class="pub-ai-bubble">' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>') + '</div>';
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function pubTyping(show){
    var existing = document.getElementById('pub-typing');
    if(show && !existing){
      var msgs = document.getElementById('pub-ai-messages');
      var div = document.createElement('div');
      div.id = 'pub-typing';
      div.className = 'pub-ai-msg bot pub-ai-typing';
      div.innerHTML = '<div class="pub-ai-avatar">AI</div><div class="pub-ai-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
      msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
    } else if(!show && existing){ existing.remove(); }
  }

  window.pubSendMsg = async function(){
    var input = document.getElementById('pub-ai-input');
    var msg = input.value.trim();
    if(!msg) return;
    var btn = document.getElementById('pub-ai-send');
    input.value = ''; input.style.height = 'auto';
    btn.disabled = true;
    pubAppend('user', msg);
    pubTyping(true);
    document.getElementById('pubAiQuick').style.display = 'none';
    try {
      var res = await fetch('/api/ai-chat-public',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({message:msg, history:pubHistory})
      });
      var data = await res.json();
      pubTyping(false);
      var reply = data.reply || data.error || 'Tidak ada respons.';
      pubAppend('bot', reply);
      pubHistory.push({role:'user',content:msg},{role:'assistant',content:reply});
      if(pubHistory.length > 20) pubHistory = pubHistory.slice(-20);
    } catch(e){
      pubTyping(false);
      pubAppend('bot','⚠️ Gagal koneksi ke AI.');
    } finally { btn.disabled=false; input.focus(); }
  };
})();
</script>
