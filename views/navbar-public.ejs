<style>
  /* ===== GLOBAL THEME VARS ===== */
  :root {
    --nav-bg: #ffffff; --nav-border: rgba(0,0,0,0.08);
    --nav-text: #111827; --nav-text2: #6b7280;
    --nav-hover-bg: #f9fafb; --nav-active-bg: #f3f4f6;
    --body-bg: #f9fafb; --body-bg2: #ffffff; --body-bg3: #f3f4f6;
    --body-text: #111827; --body-text2: #6b7280; --body-text3: #9ca3af;
    --body-border: rgba(0,0,0,0.08); --body-border2: rgba(0,0,0,0.14);
    --body-card: #ffffff; --body-input: #f9fafb;
    --body-input-border: rgba(0,0,0,0.1); --body-input-focus: #6366f1;
    --body-accent: #16a34a; --body-accent-bg: #dcfce7;
    --body-table-row: #ffffff; --body-table-row-alt: #f9fafb;
    --body-table-text: #111827; --body-table-border: rgba(0,0,0,0.07);
    --body-table-head: #f9fafb; --body-table-head-text: #374151;
  }
  [data-theme="dark"] {
    --nav-bg: #0f1117; --nav-border: rgba(255,255,255,0.07);
    --nav-text: #f1f5f9; --nav-text2: #94a3b8;
    --nav-hover-bg: #1e2130; --nav-active-bg: #1a1d2e;
    --body-bg: #080a10; --body-bg2: #0f1117; --body-bg3: #13161f;
    --body-text: #e2e8f0; --body-text2: #8b8fa8; --body-text3: #3b4263;
    --body-border: rgba(255,255,255,0.07); --body-border2: rgba(255,255,255,0.12);
    --body-card: #0f1117; --body-input: #080a10;
    --body-input-border: rgba(255,255,255,0.08); --body-input-focus: #818cf8;
    --body-accent: #4ade80; --body-accent-bg: #0d2a18;
    --body-table-row: #ffffff; --body-table-row-alt: #f4f4f4;
    --body-table-text: #000000; --body-table-border: #dddddd;
    --body-table-head: #1f242b; --body-table-head-text: #ffffff;
  }
  body {
    background-color: var(--body-bg) !important;
    color: var(--body-text) !important;
    transition: background-color 0.2s, color 0.2s;
  }

  /* NAV */
  .it-nav {
    position: sticky; top: 0; z-index: 999;
    background: var(--nav-bg);
    border-bottom: 0.5px solid var(--nav-border);
    height: 56px; display: flex; align-items: center;
    padding: 0 24px; transition: background 0.2s, border-color 0.2s;
  }
  .it-nav-brand {
    font-size: 13px; font-weight: 600; color: var(--nav-text);
    letter-spacing: 0.03em; text-decoration: none;
    margin-right: 28px; white-space: nowrap; flex-shrink: 0;
  }
  .it-nav-brand span { color: var(--body-accent); }
  .it-nav-links { display: flex; align-items: center; gap: 2px; flex: 1; }
  .it-nav-link {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 8px;
    font-size: 13px; color: var(--nav-text2);
    text-decoration: none; transition: background 0.12s, color 0.12s;
    white-space: nowrap;
  }
  .it-nav-link:hover { background: var(--nav-hover-bg); color: var(--nav-text); }
  .it-nav-link.active { background: var(--nav-active-bg); color: var(--nav-text); font-weight: 500; }
  .it-nav-link svg { width: 14px; height: 14px; flex-shrink: 0; }
  .it-nav-right { display: flex; align-items: center; gap: 8px; margin-left: auto; flex-shrink: 0; }
  .it-nav-divider { width: 0.5px; height: 20px; background: var(--nav-border); margin: 0 2px; }

  /* THEME BTN */
  .it-nav-theme {
    display: flex; align-items: center; gap: 6px;
    padding: 5px 10px; border-radius: 20px;
    border: 0.5px solid var(--nav-border);
    cursor: pointer; font-size: 12px; color: var(--nav-text2);
    background: transparent; transition: border-color 0.12s, color 0.12s;
  }
  .it-nav-theme:hover { border-color: var(--body-border2); color: var(--nav-text); }
  .t-track { width: 26px; height: 14px; background: var(--nav-border); border-radius: 7px; position: relative; flex-shrink: 0; }
  .t-thumb { position: absolute; top: 2px; left: 2px; width: 10px; height: 10px; border-radius: 50%; background: var(--nav-text2); transition: transform 0.2s, background 0.2s; }
  [data-theme="light"] .t-track { background: #16a34a; }
  [data-theme="light"] .t-thumb { transform: translateX(12px); background: #ffffff; }

  /* LOGIN BTN */
  .it-nav-login {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 8px;
    background: var(--body-accent-bg);
    border: 0.5px solid var(--body-accent);
    color: var(--body-accent);
    font-size: 13px; font-weight: 600;
    text-decoration: none; transition: all 0.12s;
    white-space: nowrap;
  }
  .it-nav-login:hover { opacity: 0.85; }
  .it-nav-login svg { width: 13px; height: 13px; }

  /* PUBLIC BADGE */
  .it-nav-public-badge {
    font-size: 11px; color: var(--body-text3);
    padding: 3px 8px; border-radius: 20px;
    border: 0.5px solid var(--nav-border);
    white-space: nowrap;
  }

  /* HAMBURGER */
  .it-nav-hamburger {
    display: none; background: none;
    border: 0.5px solid var(--nav-border);
    border-radius: 8px; padding: 6px 9px;
    color: var(--nav-text2); cursor: pointer; margin-left: auto;
  }
  .it-nav-hamburger:hover { color: var(--nav-text); }
  .it-nav-mobile {
    display: none; background: var(--nav-bg);
    border-top: 0.5px solid var(--nav-border);
    padding: 10px 16px 14px;
  }
  .it-nav-mobile.open { display: block; }
  .it-nav-mobile a {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 8px;
    color: var(--nav-text2); font-size: 13px;
    font-weight: 500; text-decoration: none;
    margin-bottom: 2px; transition: background 0.12s, color 0.12s;
  }
  .it-nav-mobile a:hover, .it-nav-mobile a.active { background: var(--nav-active-bg); color: var(--nav-text); }
  .it-nav-mobile a svg { width: 14px; height: 14px; }
  .it-nav-mobile .m-sep { border: none; border-top: 0.5px solid var(--nav-border); margin: 8px 0; }

  @media (max-width: 768px) {
    .it-nav-links, .it-nav-right { display: none; }
    .it-nav-hamburger { display: flex; align-items: center; }
    .it-nav { padding: 0 16px; }
  }

  /* EXPORT MODAL */
  #exportModal {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.5);
    align-items: center; justify-content: center;
    padding: 1rem;
  }
  .export-modal-box {
    background: var(--body-card);
    border: 0.5px solid var(--body-border);
    border-radius: 16px;
    padding: 1.75rem;
    width: 100%; max-width: 380px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .export-modal-title {
    font-size: 15px; font-weight: 700;
    color: var(--body-text); margin-bottom: 4px;
  }
  .export-modal-sub {
    font-size: 12px; color: var(--body-text2); margin-bottom: 1.25rem;
  }
  .export-form-row { display: flex; gap: 10px; margin-bottom: 1rem; }
  .export-form-row select {
    flex: 1;
    background: var(--body-input);
    border: 0.5px solid var(--body-input-border);
    border-radius: 8px;
    color: var(--body-text);
    padding: 8px 10px;
    font-size: 13px;
    outline: none;
  }
  .export-form-row select:focus { border-color: var(--body-input-focus); }
  .export-modal-actions { display: flex; gap: 8px; margin-top: 1.25rem; }
  .btn-export-confirm {
    flex: 1; padding: 9px 0; border-radius: 8px;
    background: var(--body-accent); border: none;
    color: var(--body-bg); font-size: 13px; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: opacity 0.12s;
  }
  .btn-export-confirm:hover { opacity: 0.85; }
  .btn-export-cancel {
    padding: 9px 16px; border-radius: 8px;
    background: transparent; border: 0.5px solid var(--body-border);
    color: var(--body-text2); font-size: 13px; cursor: pointer;
    transition: all 0.12s;
  }
  .btn-export-cancel:hover { border-color: var(--body-border2); color: var(--body-text); }
</style>

<nav class="it-nav" id="mainNav">
  <a href="/" class="it-nav-brand">&gt;_ IT <span>SUPPORT</span> LOG</a>

  <div class="it-nav-links">
    <a href="/" class="it-nav-link <%= activePage === 'home' ? 'active' : '' %>">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 6.5L8 2l6 4.5V14a1 1 0 01-1 1H3a1 1 0 01-1-1V6.5z"/></svg>
      Home
    </a>
    <a href="/aset-public" class="it-nav-link <%= activePage === 'aset-public' ? 'active' : '' %>">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="12" height="9" rx="1"/><path d="M5 4V3a1 1 0 011-1h4a1 1 0 011 1v1"/></svg>
      Aset IT
    </a>
  </div>

  <div class="it-nav-right">
    <% if (typeof currentUser === 'undefined' || !currentUser) { %>
      <span class="it-nav-public-badge">👁 Public View</span>
    <% } %>

    <button class="it-nav-theme" onclick="toggleTheme()" id="navThemeBtn">
      <div class="t-track"><div class="t-thumb" id="navThumb"></div></div>
      <span id="navThemeLabel">Light</span>
    </button>

    <div class="it-nav-divider"></div>

    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <%
        var initials = currentUser.nama
          ? currentUser.nama.split(' ').slice(0,2).map(function(w){ return w[0]; }).join('').toUpperCase()
          : currentUser.username.slice(0,2).toUpperCase();
        var roleClass = currentUser.role === 'admin' ? 'role-admin'
                      : currentUser.role === 'user'   ? 'role-user'
                      : currentUser.role === 'viewer' ? 'role-viewer'
                      : 'role-custom';
      %>
      <div class="it-nav-user" style="display:flex;align-items:center;gap:8px;padding:4px 10px 4px 4px;border-radius:24px;border:0.5px solid var(--nav-border);">
        <div class="it-nav-avatar" style="width:28px;height:28px;border-radius:50%;background:var(--body-accent-bg);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--body-accent);"><%= initials %></div>
        <span style="font-size:13px;font-weight:500;color:var(--nav-text);"><%= currentUser.nama || currentUser.username %></span>
        <span style="font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px;" class="<%= roleClass %>"><%= currentUser.role.toUpperCase() %></span>
      </div>
      <% if (typeof userPerms !== 'undefined' && userPerms && userPerms.canExport) { %>
      <button onclick="document.getElementById('exportModal').style.display='flex'" class="it-nav-login" style="border:none;cursor:pointer;">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3"/><path d="M3 12h10"/></svg>
        Export Excel
      </button>
      <% } %>
      <a href="/logout" style="padding:5px 12px;border-radius:8px;border:0.5px solid var(--nav-border);font-size:12px;font-weight:500;color:var(--nav-text2);text-decoration:none;display:inline-flex;align-items:center;">Keluar</a>
    <% } else { %>
      <a href="/login" class="it-nav-login">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 8H3m0 0l2.5-2.5M3 8l2.5 2.5"/><path d="M7 5V3a1 1 0 011-1h4a1 1 0 011 1v10a1 1 0 01-1 1H8a1 1 0 01-1-1v-2"/></svg>
        Login
      </a>
    <% } %>
  </div>

  <button class="it-nav-hamburger" onclick="toggleMobileNav()">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="2" y1="4" x2="14" y2="4"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="12" x2="14" y2="12"/>
    </svg>
  </button>
</nav>

<div class="it-nav-mobile" id="mobileNav">
  <a href="/" class="<%= activePage === 'home' ? 'active' : '' %>">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 6.5L8 2l6 4.5V14a1 1 0 01-1 1H3a1 1 0 01-1-1V6.5z"/></svg>
    Home
  </a>
  <a href="/aset-public" class="<%= activePage === 'aset-public' ? 'active' : '' %>">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="12" height="9" rx="1"/><path d="M5 4V3a1 1 0 011-1h4a1 1 0 011 1v1"/></svg>
    Aset IT
  </a>
  <hr class="m-sep">
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div style="display:flex;align-items:center;gap:8px;padding:8px 12px;font-size:13px;color:var(--nav-text2);">
      <div style="width:28px;height:28px;border-radius:50%;background:var(--body-accent-bg);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--body-accent);"><%= initials %></div>
      <span style="font-size:13px;font-weight:500;color:var(--nav-text);"><%= currentUser.nama || currentUser.username %></span>
    </div>
    <% if (typeof userPerms !== 'undefined' && userPerms && userPerms.canExport) { %>
    <a href="#" onclick="document.getElementById('exportModal').style.display='flex';document.getElementById('mobileNav').classList.remove('open');return false;" style="color:var(--body-accent) !important;">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3"/><path d="M3 12h10"/></svg>
      Export Excel
    </a>
    <% } %>
    <a href="/logout" style="color:#dc2626 !important;">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 8h7m0 0l-2.5-2.5M13 8l-2.5 2.5"/><path d="M9 5V3a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h4a1 1 0 001-1v-2"/></svg>
      Keluar
    </a>
  <% } else { %>
    <a href="/login" style="color:var(--body-accent) !important;">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 8H3m0 0l2.5-2.5M3 8l2.5 2.5"/><path d="M7 5V3a1 1 0 011-1h4a1 1 0 011 1v10a1 1 0 01-1 1H8a1 1 0 01-1-1v-2"/></svg>
      Login ke Dashboard
    </a>
  <% } %>
</div>


<!-- EXPORT MODAL -->
<div id="exportModal">
  <div class="export-modal-box">
    <div class="export-modal-title">📊 Export Data ke Excel</div>
    <div class="export-modal-sub">Pilih bulan dan tahun yang ingin di-export untuk tim audit.</div>
    <div class="export-form-row">
      <select id="exportMonth">
        <option value="1">Januari</option>
        <option value="2">Februari</option>
        <option value="3">Maret</option>
        <option value="4">April</option>
        <option value="5">Mei</option>
        <option value="6">Juni</option>
        <option value="7">Juli</option>
        <option value="8">Agustus</option>
        <option value="9">September</option>
        <option value="10">Oktober</option>
        <option value="11">November</option>
        <option value="12">Desember</option>
      </select>
      <select id="exportYear"></select>
    </div>
    <div class="export-modal-actions">
      <button class="btn-export-confirm" onclick="doExport()">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8m0 0l-3-3m3 3l3-3"/><path d="M3 12h10"/></svg>
        Download Excel
      </button>
      <button class="btn-export-cancel" onclick="document.getElementById('exportModal').style.display='none'">Batal</button>
    </div>
  </div>
</div>

<script>
(function() {
  var now = new Date();
  var curMonth = now.getMonth() + 1;
  var curYear  = now.getFullYear();
  var sel = document.getElementById('exportYear');
  for (var y = curYear; y >= curYear - 5; y--) {
    var opt = document.createElement('option');
    opt.value = y; opt.textContent = y;
    sel.appendChild(opt);
  }
  document.getElementById('exportMonth').value = curMonth;

  window.doExport = function() {
    var m = document.getElementById('exportMonth').value;
    var y = document.getElementById('exportYear').value;
    document.getElementById('exportModal').style.display = 'none';
    window.location.href = '/export?month=' + m + '&year=' + y;
  };

  // Tutup modal kalau klik di luar box
  document.getElementById('exportModal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
  });
})();
</script>

<script>
(function() {
  function getTheme() { return localStorage.getItem('itlog-theme') || 'dark'; }
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('itlog-theme', t);
    var lbl   = document.getElementById('navThemeLabel');
    var thumb = document.getElementById('navThumb');
    if (lbl)   lbl.textContent = t === 'dark' ? 'Light' : 'Dark';
    if (thumb) {
      thumb.style.transform  = t === 'light' ? 'translateX(12px)' : '';
      thumb.style.background = t === 'light' ? '#ffffff' : '';
    }
  }
  window.toggleTheme = function() { applyTheme(getTheme() === 'dark' ? 'light' : 'dark'); };
  window.toggleMobileNav = function() {
    var el = document.getElementById('mobileNav');
    if (el) el.classList.toggle('open');
  };
  applyTheme(getTheme());
})();
</script>
