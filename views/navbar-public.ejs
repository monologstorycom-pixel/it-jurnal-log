<style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body { background: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', sans-serif; margin: 0; transition: background 0.2s, color 0.2s; }
        .page-wrap { max-width: 1300px; margin: 0 auto; padding: 1.5rem; }

        /* LOGIN PROMPT */
        .login-prompt { background: var(--body-accent-bg); border: 0.5px solid var(--body-accent); border-radius: 10px; padding: 12px 16px; margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
        .login-prompt-text { font-size: 13px; color: var(--body-accent); font-weight: 500; }
        .login-prompt a { padding: 6px 14px; border-radius: 8px; background: var(--body-accent); color: var(--body-bg); font-size: 13px; font-weight: 600; text-decoration: none; }
        .login-prompt a:hover { opacity: 0.88; }

        /* PANEL */
        .panel { background: var(--body-card); border: 0.5px solid var(--body-border); border-radius: 12px; overflow: hidden; margin-bottom: 1.5rem; }
        .panel-hd { padding: 1rem 1.25rem; border-bottom: 0.5px solid var(--body-border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
        .panel-title { font-size: 12px; font-weight: 600; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.07em; }

        /* SEARCH */
        .search-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
        .s-input { background: var(--body-input); border: 0.5px solid var(--body-input-border); border-radius: 8px; color: var(--body-text); padding: 6px 10px; font-size: 13px; outline: none; }
        .s-input:focus { border-color: var(--body-input-focus); }
        .s-btn { padding: 6px 12px; border-radius: 8px; border: 0.5px solid var(--body-border); background: var(--body-bg3); color: var(--body-text2); font-size: 13px; font-weight: 500; cursor: pointer; text-decoration: none; display: inline-block; }
        .s-btn:hover { color: var(--body-text); border-color: var(--body-border2); }
        .s-btn-primary { background: var(--body-accent-bg); border-color: var(--body-accent); color: var(--body-accent); }

        /* STATS */
        .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 1px; background: var(--body-border); }
        .stat-item { background: var(--body-card); padding: 1rem; text-align: center; }
        .stat-val { font-size: 1.5rem; font-weight: 700; line-height: 1; }
        .stat-lbl { font-size: 11px; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.07em; margin-top: 4px; font-weight: 600; }

        /* ASET TABLE */
        .aset-table { width: 100%; border-collapse: collapse; }
        .aset-table thead tr { background: var(--body-bg3); }
        .aset-table th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 600; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.07em; border-bottom: 0.5px solid var(--body-border); white-space: nowrap; }
        .aset-table tbody tr { border-bottom: 0.5px solid var(--body-border); transition: background 0.1s; }
        .aset-table tbody tr:hover td { background: var(--body-bg3); }
        .aset-table td { padding: 11px 14px; font-size: 13px; color: var(--body-text); vertical-align: middle; }

        /* STOK BAR */
        .stok-val { font-weight: 600; font-size: 14px; }
        .stok-bar { width: 60px; height: 3px; background: var(--body-border); border-radius: 2px; margin-top: 4px; overflow: hidden; display: inline-block; }
        .stok-fill { height: 100%; border-radius: 2px; }

        /* BADGES */
        .badge-kondisi { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .k-baik    { background: #dcfce7; color: #15803d; }
        .k-rusak   { background: #fee2e2; color: #dc2626; }
        .k-service { background: #fef3c7; color: #d97706; }
        .badge-pinjam { display: inline-block; background: #ede9fe; color: #6d28d9; border-radius: 4px; padding: 1px 7px; font-size: 11px; font-weight: 600; }

        /* HISTORI TABLE */
        .rw-table { width: 100%; border-collapse: collapse; }
        .rw-table th { padding: 8px 12px; font-size: 11px; font-weight: 600; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.07em; border-bottom: 0.5px solid var(--body-border); text-align: left; }
        .rw-table td { padding: 9px 12px; font-size: 12px; color: var(--body-text); border-bottom: 0.5px solid var(--body-bg3); vertical-align: middle; }
        .rw-table tr:last-child td { border-bottom: none; }

        .bp-aktif   { display:inline-block;padding:1px 7px;border-radius:3px;font-size:11px;font-weight:600;background:#ede9fe;color:#6d28d9; }
        .bp-kembali { display:inline-block;padding:1px 7px;border-radius:3px;font-size:11px;font-weight:600;background:#dcfce7;color:#15803d; }

        /* ACCORDION */
        .aset-row-detail { display: none; background: var(--body-bg3) !important; }
        .aset-row-detail.show { display: table-row; }
        .aset-row-detail td { padding: 0 !important; }
        .detail-inner { padding: 1rem 1.25rem; }
        .detail-tabs { display: flex; gap: 6px; margin-bottom: 1rem; }
        .detail-tab { padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer; border: 0.5px solid var(--body-border); background: var(--body-card); color: var(--body-text2); }
        .detail-tab.active { background: var(--body-accent-bg); border-color: var(--body-accent); color: var(--body-accent); }
        .detail-tab-content { display: none; }
        .detail-tab-content.active { display: block; }

        .btn-toggle-detail { background: none; border: 0.5px solid var(--body-border); border-radius: 6px; padding: 4px 10px; font-size: 12px; color: var(--body-text2); cursor: pointer; }
        .btn-toggle-detail:hover { color: var(--body-text); border-color: var(--body-border2); }

        .empty-row td { text-align: center; padding: 3rem; color: var(--body-text3); font-size: 13px; }

        /* FOTO THUMBNAIL */
        .aset-thumb { width:40px;height:40px;border-radius:6px;object-fit:cover;border:0.5px solid var(--body-border);cursor:pointer;transition:transform 0.15s; }
        .aset-thumb:hover { transform:scale(1.12); }
        .aset-no-thumb { width:40px;height:40px;border-radius:6px;background:var(--body-bg3);border:0.5px dashed var(--body-border);display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--body-text3); }
        .rw-thumb { width:36px;height:36px;border-radius:5px;object-fit:cover;border:0.5px solid var(--body-border);cursor:pointer;transition:transform 0.15s; }
        .rw-thumb:hover { transform:scale(1.12); }
        .rw-no-thumb { width:36px;height:36px;border-radius:5px;background:var(--body-bg3);border:0.5px dashed var(--body-border);display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--body-text3); }
        /* FOTO MODAL */
        .foto-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:12px; }
        .foto-overlay.show { display:flex; }
        .foto-overlay img { max-width:92vw;max-height:85vh;border-radius:10px;object-fit:contain; }
        .foto-overlay-caption { color:#fff;font-size:13px;opacity:0.8; }
        .foto-overlay-close { position:absolute;top:16px;right:20px;color:#fff;font-size:28px;cursor:pointer;line-height:1;opacity:0.7; }
        .foto-overlay-close:hover { opacity:1; }

        @media (max-width: 768px) { .page-wrap { padding: 1rem; } }
</style>

<%- include('navbar', {activePage: activePage || 'aset-public'}) %>
