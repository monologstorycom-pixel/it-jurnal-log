<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#1a3a1a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="IT Log">
    <link rel="icon" type="image/x-icon"   href="/favicon.ico">
    <link rel="icon" type="image/svg+xml"  href="/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180x180.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Riwayat: <%= aset.nama %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { background: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', -apple-system, sans-serif; margin: 0; transition: background 0.25s, color 0.25s; }
        .page-wrap { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
        .panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; overflow: hidden; margin-bottom: 1.5rem; }
        .panel-hd { padding: 1rem 1.25rem; border-bottom: 1px solid var(--body-border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
        .panel-title { font-size: 0.75rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.08em; }
        .back-link { color: var(--body-text2); font-size: 0.78rem; text-decoration: none; }
        .back-link:hover { color: var(--body-text); }
        .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 1px; background: var(--body-border); }
        .stat-item { background: var(--body-card); padding: 1rem; text-align: center; }
        .stat-val { font-size: 1.6rem; font-weight: 800; line-height: 1; }
        .stat-lbl { font-size: 0.63rem; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.07em; margin-top: 4px; font-weight: 700; }
        .rw-table { width: 100%; border-collapse: collapse; }
        .rw-table th { padding: 9px 14px; font-size: 0.65rem; font-weight: 700; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--body-border); text-align: left; }
        .rw-table td { padding: 10px 14px; font-size: 0.82rem; color: var(--body-text); border-bottom: 1px solid var(--body-bg); vertical-align: middle; }
        .rw-table tr:last-child td { border-bottom: none; }
        .rw-table tr:hover td { background: var(--body-bg3); }
        .badge-p { display:inline-block;padding:2px 7px;border-radius:3px;font-size:0.63rem;font-weight:700; }
        .bp-aktif   { background:#1a0d3d;color:#a78bfa;border:1px solid #4c3780; }
        .bp-kembali { background:#0d2a18;color:#4ade80;border:1px solid #1a5c30; }
        .act-btn { background:none;border:1px solid var(--body-border);color:var(--body-text2);padding:3px 8px;border-radius:4px;font-size:0.68rem;font-weight:600;cursor:pointer;transition:all 0.12s; }
        .act-btn.green:hover{border-color:#2d6a4a;color:#4ade80;background:#0d2a18;}
        .act-btn.red:hover{border-color:#5c1a1a;color:#f87171;background:#2a0d0d;}
        .empty-msg { text-align:center;padding:2.5rem;color:var(--body-text3);font-size:0.83rem; }

        /* FOTO HEADER ASET */
        .aset-main-foto {
            width: 100%; max-height: 280px; object-fit: cover;
            border-bottom: 1px solid var(--body-border);
            display: block; cursor: pointer;
        }
        .aset-no-foto-banner {
            height: 80px; display: flex; align-items: center; justify-content: center;
            color: var(--body-text3); font-size: 0.82rem;
            border-bottom: 1px solid var(--body-border);
            background: var(--body-bg3);
        }

        /* FOTO THUMBNAIL di tabel */
        .rw-thumb {
            width: 48px; height: 48px; border-radius: 6px; object-fit: cover;
            border: 1px solid var(--body-border); cursor: pointer;
            transition: transform 0.15s, border-color 0.15s;
        }
        .rw-thumb:hover { transform: scale(1.1); border-color: #4ade80; }
        .rw-no-foto {
            width: 48px; height: 48px; border-radius: 6px;
            background: var(--body-bg3); border: 1px dashed var(--body-border2);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: var(--body-text3);
        }
        .f-label { display: block; font-size: 0.68rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
        .f-input { background: var(--body-input) !important; border: 1px solid var(--body-input-border) !important; border-radius: 6px; color: var(--body-text) !important; padding: 8px 10px; width: 100%; margin-bottom: 0.65rem; font-size: 0.83rem; outline: none; transition: border-color 0.15s; }
        .f-input:focus { border-color: var(--body-input-focus) !important; }
    </style>
</head>
<body>
<%- include('navbar', {activePage: 'aset'}) %>
<div class="page-wrap">
    <%
        var totalPakai = aset.penggunaan.reduce((s,p) => s+p.jumlah, 0);
        var aktifPinjam = aset.pinjaman.filter(p => p.status==='Dipinjam').reduce((s,p) => s+p.jumlah, 0);
        var pct = aset.stokAwal > 0 ? Math.round((aset.stok/aset.stokAwal)*100) : 0;
        var barColor = pct > 50 ? '#4ade80' : pct > 20 ? '#fb923c' : '#f87171';
    %>

    <!-- HEADER ASET -->
    <div class="panel">
        <!-- FOTO ASET (maks 3) -->
        <% var fotoList = [aset.fotoUrl, aset.foto2Url, aset.foto3Url].filter(Boolean); %>
        <% var fotoListJson = JSON.stringify(fotoList); %>
        <% if(fotoList.length > 0) { %>
        <div style="display:grid;grid-template-columns:repeat(<%= fotoList.length %>,1fr);gap:0;border-bottom:1px solid var(--body-border);">
            <% fotoList.forEach(function(url, idx) { %>
            <div style="position:relative;overflow:hidden;">
                <img src="<%= url %>"
                    onclick="showFotoSlider(<%- fotoListJson %>, <%= idx %>, '<%= aset.nama.replace(/'/g, "&#39;") %>')"
                    alt="Foto <%= idx+1 %>"
                    title="Klik untuk perbesar"
                    style="width:100%;max-height:240px;object-fit:cover;display:block;cursor:pointer;<%= idx > 0 ? 'border-left:1px solid var(--body-border);' : '' %>">
                <% if(fotoList.length > 1) { %>
                <div style="position:absolute;bottom:6px;right:6px;background:rgba(0,0,0,0.55);color:#fff;font-size:0.6rem;font-weight:700;padding:2px 6px;border-radius:10px;pointer-events:none;">
                    <%= idx+1 %>/<%= fotoList.length %>
                </div>
                <% } %>
            </div>
            <% }); %>
        </div>
        <% } else { %>
        <div class="aset-no-foto-banner"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg> Belum ada foto aset</div>
        <% } %>

        <div class="panel-hd">
            <div>
                <div style="font-size:1.1rem;font-weight:800;color:var(--body-text);"><%= aset.nama %></div>
                <div style="font-size:0.78rem;color:var(--body-text2);margin-top:2px;"><%= aset.kategori %> &bull; Satuan: <%= aset.satuan %> &bull; Kondisi: <span style="color:<%= aset.kondisi==='Baik'?'#4ade80':aset.kondisi==='Rusak'?'#f87171':'#fb923c' %>"><%= aset.kondisi %></span></div>
                <% if(aset.keterangan){%><div style="font-size:0.75rem;color:var(--body-text3);margin-top:3px;"><%= aset.keterangan %></div><%}%>
            </div>
            <a href="/aset" class="back-link">← Kembali ke Aset</a>
        </div>
        <div class="stat-grid">
            <div class="stat-item"><div class="stat-val" style="color:<%= barColor %>"><%= aset.stok %></div><div class="stat-lbl">Stok Sisa</div></div>
            <div class="stat-item"><div class="stat-val" style="color:var(--body-text2)"><%= aset.stokAwal %></div><div class="stat-lbl">Stok Awal</div></div>
            <div class="stat-item"><div class="stat-val" style="color:#7eb8f7"><%= totalPakai %></div><div class="stat-lbl">Total Dipasang</div></div>
            <div class="stat-item"><div class="stat-val" style="color:#a78bfa"><%= aktifPinjam %></div><div class="stat-lbl">Sedang Dipinjam</div></div>
            <div class="stat-item"><div class="stat-val" style="color:var(--body-text3)"><%= aset.pinjaman.length %></div><div class="stat-lbl">Total Pinjam</div></div>
        </div>
    </div>

    <div class="row g-4">
        <!-- RIWAYAT PENGGUNAAN -->
        <div class="col-md-6">
            <div class="panel">
                <div class="panel-hd"><span class="panel-title">Riwayat Penggunaan / Pemasangan</span><span style="font-size:0.72rem;color:var(--body-text3);"><%= aset.penggunaan.length %> catatan</span></div>
                <% if(aset.penggunaan.length === 0){ %><div class="empty-msg">Belum ada catatan penggunaan.</div>
                <% } else { %>
                <div style="overflow-x:auto;">
                  <table class="rw-table">
                    <thead><tr><th>Foto</th><th>Tanggal</th><th>Jumlah</th><th>Divisi / Lokasi</th><th></th></tr></thead>
                    <tbody>
                    <% aset.penggunaan.forEach(p => { %>
                    <tr>
                        <td style="width:60px;">
                            <% if(p.fotoUrl) { %>
                                <img src="<%= p.fotoUrl %>" class="rw-thumb"
                                    onclick="showFoto('<%= p.fotoUrl %>', 'Pemasangan — <%= new Date(p.tanggal).toLocaleDateString("id-ID") %>')"
                                    alt="foto penggunaan">
                            <% } else { %>
                                <div class="rw-no-foto" title="Tidak ada foto"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
                            <% } %>
                        </td>
                        <td style="white-space:nowrap;color:var(--body-text2);font-size:0.75rem;"><%= new Date(p.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></td>
                        <td><span style="font-weight:700;color:#7eb8f7;"><%= p.jumlah %></span> <span style="color:var(--body-text3);font-size:0.72rem;"><%= aset.satuan %></span></td>
                        <td>
                            <div style="font-weight:600;color:var(--body-text);"><%= p.divisi %></div>
                            <div style="font-size:0.72rem;color:var(--body-text2);"><%= p.lokasi %></div>
                            <%if(p.keterangan){%><div style="font-size:0.7rem;color:var(--body-text3);"><%= p.keterangan %></div><%}%>
                        </td>
                        <td>
                            <form action="/aset/pakai-hapus/<%= p.id %>" method="POST">
                                <button type="submit" class="act-btn red" onclick="return confirm('Hapus catatan? Stok akan kembali.')">Hapus</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                    </tbody>
                  </table>
                </div>
                <% } %>
            </div>
        </div>

        <!-- RIWAYAT PINJAMAN -->
        <div class="col-md-6">
            <div class="panel">
                <div class="panel-hd"><span class="panel-title">Riwayat Peminjaman</span><span style="font-size:0.72rem;color:var(--body-text3);"><%= aset.pinjaman.length %> catatan</span></div>
                <% if(aset.pinjaman.length === 0){ %><div class="empty-msg">Belum ada catatan pinjaman.</div>
                <% } else { %>
                <div style="overflow-x:auto;">
                  <table class="rw-table">
                    <thead><tr><th>Foto</th><th>Peminjam</th><th>Jml</th><th>Tgl Pinjam</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    <% aset.pinjaman.forEach(p => { %>
                    <tr>
                        <td style="width:60px;">
                            <% if(p.fotoUrl) { %>
                                <img src="<%= p.fotoUrl %>" class="rw-thumb"
                                    onclick="showFoto('<%= p.fotoUrl %>', 'Pinjam — <%= p.peminjam.replace(/'/g, "&#39;") %>')"
                                    alt="foto pinjaman">
                            <% } else { %>
                                <div class="rw-no-foto" title="Tidak ada foto"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></div>
                            <% } %>
                        </td>
                        <td>
                            <div style="font-weight:600;color:var(--body-text);"><%= p.peminjam %></div>
                            <div style="font-size:0.72rem;color:var(--body-text2);"><%= p.divisi %></div>
                            <%if(p.keperluan){%><div style="font-size:0.7rem;color:var(--body-text3);"><%= p.keperluan %></div><%}%>
                        </td>
                        <td><span style="font-weight:700;color:#a78bfa;"><%= p.jumlah %></span></td>
                        <td style="white-space:nowrap;color:var(--body-text2);font-size:0.75rem;">
                            <%= new Date(p.tanggalPinjam).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                            <%if(p.tanggalKembali){%><br><span style="color:#4ade80;">Kembali: <%= new Date(p.tanggalKembali).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></span><%}%>
                        </td>
                        <td><span class="badge-p <%= p.status==='Dipinjam'?'bp-aktif':'bp-kembali' %>"><%= p.status %></span></td>
                        <td>
                            <div style="display:flex;flex-direction:column;gap:4px;">
                                <%if(p.status==='Dipinjam'){%>
                                <form action="/aset/kembali/<%= p.id %>" method="POST">
                                    <button type="submit" class="act-btn green" onclick="return confirm('Konfirmasi pengembalian oleh <%= p.peminjam.replace(/'/g, "&#39;") %>?')" style="width:100%;">Kembali</button>
                                </form>
                                <%}%>
                                <form action="/aset/pinjam-hapus/<%= p.id %>" method="POST">
                                    <button type="submit" class="act-btn red" onclick="return confirm('Hapus catatan pinjaman ini?')" style="width:100%;">Hapus</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                    </tbody>
                  </table>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- RIWAYAT SERVICE -->
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="panel">
                <div class="panel-hd">
                    <span class="panel-title" style="color:#fb923c;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg> Riwayat Service</span>
                    <span style="font-size:0.72rem;color:var(--body-text3);"><%= aset.service ? aset.service.length : 0 %> catatan</span>
                </div>
                <% if(!aset.service || aset.service.length === 0){ %>
                <div class="empty-msg">Belum ada catatan service.</div>
                <% } else { %>
                <div style="overflow-x:auto;">
                  <table class="rw-table">
                    <thead><tr><th>Foto</th><th>Tanggal</th><th>Teknisi / Vendor</th><th>Keluhan</th><th>Hasil</th><th>Biaya</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    <% aset.service.forEach(sv => { %>
                    <tr>
                        <td style="width:60px;">
                            <% if(sv.fotoUrl) { %>
                                <% var tglSv = new Date(sv.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}); %>
                                <img src="<%= sv.fotoUrl %>" class="rw-thumb"
                                    onclick="showFoto('<%= sv.fotoUrl %>', 'Service — <%= tglSv %>')"
                                    alt="foto service">
                            <% } else { %>
                                <div class="rw-no-foto" title="Tidak ada foto"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
                            <% } %>
                        </td>
                        <td style="white-space:nowrap;color:var(--body-text2);font-size:0.75rem;">
                            <div><%= new Date(sv.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></div>
                            <% if(sv.tanggalSelesai) { %>
                            <div style="color:#4ade80;">Selesai: <%= new Date(sv.tanggalSelesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></div>
                            <% } %>
                        </td>
                        <td>
                            <div style="font-weight:600;color:var(--body-text)"><%= sv.teknisi %></div>
                            <% if(sv.vendor) { %><div style="font-size:0.72rem;color:var(--body-text2);"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg> <%= sv.vendor %></div><% } %>
                        </td>
                        <td style="max-width:200px;font-size:0.78rem;color:var(--body-text2);"><%= sv.keluhan %></td>
                        <td style="max-width:200px;font-size:0.78rem;color:var(--body-text3);">
                            <%= sv.hasil || '—' %>
                        </td>
                        <td style="white-space:nowrap;font-size:0.78rem;">
                            <% if(sv.biaya && sv.biaya > 0) { %>
                                <span style="color:#fb923c;font-weight:600;">Rp <%= sv.biaya.toLocaleString('id-ID') %></span>
                            <% } else { %>
                                <span style="color:var(--body-text3);">—</span>
                            <% } %>
                        </td>
                        <td>
                            <span style="padding:2px 8px;border-radius:4px;font-size:0.68rem;font-weight:700;
                                <%= sv.status==='Selesai' ? 'background:#0d2a18;color:#4ade80;border:1px solid #2d6a4a;' : 'background:#2a1200;color:#fb923c;border:1px solid #7a3a10;' %>">
                                <%= sv.status %>
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;flex-direction:column;gap:4px;">
                                <button class="act-btn orange" style="width:100%;"
                                    onclick="openEditService(<%= sv.id %>, '<%= sv.teknisi.replace(/'/g,`\\'`) %>', '<%= (sv.vendor||'').replace(/'/g,`\\'`) %>', `<%- (sv.keluhan||'').replace(/`/g,'\\`') %>`, `<%- (sv.hasil||'').replace(/`/g,'\\`') %>`, <%= sv.biaya||0 %>, '<%= sv.status %>', '<%= new Date(sv.tanggal).toISOString().split('T')[0] %>', '<%= sv.tanggalSelesai ? new Date(sv.tanggalSelesai).toISOString().split('T')[0] : '' %>')">
                                    Edit
                                </button>
                                <form action="/aset/service-hapus/<%= sv.id %>" method="POST">
                                    <button type="submit" class="act-btn red" onclick="return confirm('Hapus catatan service ini?')" style="width:100%;">Hapus</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                    </tbody>
                  </table>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- MODAL FOTO SLIDER -->
<div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);">
      <div class="modal-header" style="border-color:var(--body-border);padding:10px 16px;">
        <h5 class="modal-title" id="fotoModalTitle" style="color:var(--body-text);font-size:0.9rem;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0" style="position:relative;background:#000;min-height:200px;">
        <!-- Gambar utama -->
        <img id="fotoModalImg" src="" class="img-fluid d-block mx-auto" style="max-height:78vh;object-fit:contain;">

        <!-- Tombol PREV -->
        <button id="fotoModalPrev" onclick="sliderNav(-1)"
          style="position:absolute;left:10px;top:50%;transform:translateY(-50%);
                 background:rgba(0,0,0,0.55);border:none;color:#fff;font-size:1.5rem;
                 width:40px;height:40px;border-radius:50%;cursor:pointer;z-index:10;
                 align-items:center;justify-content:center;display:none;">&#8249;</button>

        <!-- Tombol NEXT -->
        <button id="fotoModalNext" onclick="sliderNav(1)"
          style="position:absolute;right:10px;top:50%;transform:translateY(-50%);
                 background:rgba(0,0,0,0.55);border:none;color:#fff;font-size:1.5rem;
                 width:40px;height:40px;border-radius:50%;cursor:pointer;z-index:10;
                 align-items:center;justify-content:center;display:none;">&#8250;</button>
      </div>

      <!-- Dot indicator + thumbnail strip -->
      <div id="fotoModalDots" style="display:flex;justify-content:center;align-items:center;gap:8px;padding:10px 16px;background:var(--body-card);flex-wrap:wrap;"></div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ===== SLIDER STATE =====
var _sliderUrls  = [];
var _sliderIdx   = 0;
var _sliderNama  = '';

function showFotoSlider(urls, startIdx, nama) {
    _sliderUrls = Array.isArray(urls) ? urls : [urls];
    _sliderIdx  = startIdx || 0;
    _sliderNama = nama || 'Foto';
    _renderSlider();
    new bootstrap.Modal(document.getElementById('fotoModal')).show();
}

// Fallback: showFoto single (dipanggil dari riwayat penggunaan/pinjaman/service)
function showFoto(url, judul) {
    showFotoSlider([url], 0, judul);
}

function _renderSlider() {
    var total = _sliderUrls.length;
    var url   = _sliderUrls[_sliderIdx];

    document.getElementById('fotoModalImg').src = url;
    document.getElementById('fotoModalTitle').innerHTML =
        '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> ' + _sliderNama + (total > 1 ? ' (' + (_sliderIdx+1) + '/' + total + ')' : '');

    // Prev / Next visibility
    var btnPrev = document.getElementById('fotoModalPrev');
    var btnNext = document.getElementById('fotoModalNext');
    if (total > 1) {
        btnPrev.style.display = 'flex';
        btnNext.style.display = 'flex';
        btnPrev.style.opacity = _sliderIdx === 0 ? '0.3' : '1';
        btnNext.style.opacity = _sliderIdx === total-1 ? '0.3' : '1';
    } else {
        btnPrev.style.display = 'none';
        btnNext.style.display = 'none';
    }

    // Dots / thumbnail strip
    var dotsEl = document.getElementById('fotoModalDots');
    dotsEl.innerHTML = '';
    if (total > 1) {
        _sliderUrls.forEach(function(u, i) {
            var thumb = document.createElement('img');
            thumb.src = u;
            thumb.onclick = (function(idx) { return function() { _sliderIdx = idx; _renderSlider(); }; })(i);
            Object.assign(thumb.style, {
                width: '52px', height: '52px', objectFit: 'cover',
                borderRadius: '6px', cursor: 'pointer', transition: 'all 0.15s',
                border: i === _sliderIdx ? '2px solid #4ade80' : '2px solid transparent',
                opacity: i === _sliderIdx ? '1' : '0.5'
            });
            dotsEl.appendChild(thumb);
        });
    }
}

function sliderNav(dir) {
    var total = _sliderUrls.length;
    _sliderIdx = Math.max(0, Math.min(total-1, _sliderIdx + dir));
    _renderSlider();
}

// Keyboard arrow support
document.addEventListener('keydown', function(e) {
    var modal = document.getElementById('fotoModal');
    if (!modal || !modal.classList.contains('show')) return;
    if (e.key === 'ArrowRight') sliderNav(1);
    if (e.key === 'ArrowLeft')  sliderNav(-1);
});
</script>

<!-- MODAL EDIT SERVICE (TERINTEGRASI DENGAN VENDOR) -->
<div class="modal fade" id="modalEditService" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="background:var(--body-card);border:1px solid #7a3a10;">
      <div class="modal-header" style="border-color:#7a3a10;">
        <h5 class="modal-title" style="color:#fb923c;font-size:14px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg> Edit Catatan Service</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formEditService" action="" method="POST">
        <div class="modal-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div>
              <label class="f-label">Teknisi / PIC *</label>
              <input type="text" name="teknisi" id="esTeknisi" class="f-input" required>
            </div>
            
            <!-- Vendor Dinamis Dropdown -->
            <div>
              <label class="f-label">Vendor / Bengkel</label>
              <select id="esVendorSelect" class="f-input" onchange="toggleManualVendorEdit(this.value)">
                  <option value="">-- Tanpa Vendor --</option>
                  <% if (typeof vendors !== 'undefined' && vendors.length > 0) { %>
                      <% vendors.forEach(v => { %>
                          <option value="<%= v.nama %>"><%= v.nama %> (<%= v.kategori %>)</option>
                      <% }); %>
                  <% } %>
                  <option value="manual"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Input Manual / Vendor Baru</option>
              </select>
              <input type="text" name="vendor" id="esVendor" class="f-input" style="display:none; margin-top:5px;" placeholder="Ketik nama vendor...">
            </div>

            <div>
              <label class="f-label">Tanggal Masuk</label>
              <input type="date" name="tanggal" id="esTanggal" class="f-input">
            </div>
            <div>
              <label class="f-label">Tanggal Selesai</label>
              <input type="date" name="tanggalSelesai" id="esTanggalSelesai" class="f-input">
            </div>
            <div style="grid-column:1/-1;">
              <label class="f-label">Keluhan / Kerusakan *</label>
              <textarea name="keluhan" id="esKeluhan" class="f-input" rows="2" required style="resize:vertical;"></textarea>
            </div>
            <div style="grid-column:1/-1;">
              <label class="f-label">Hasil / Tindakan</label>
              <textarea name="hasil" id="esHasil" class="f-input" rows="2" style="resize:vertical;"></textarea>
            </div>
            <div>
              <label class="f-label">Biaya Service (Rp)</label>
              <input type="number" name="biaya" id="esBiaya" class="f-input" min="0">
            </div>
            <div>
              <label class="f-label">Status</label>
              <select name="status" id="esStatus" class="f-input">
                <option value="Proses">Proses</option>
                <option value="Selesai">Selesai</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer" style="border-color:#7a3a10;">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn fw-bold" style="background:#fb923c;color:#0f1117;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Simpan Perubahan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Fungsi untuk memunculkan text input manual kalau milih "Input Manual"
function toggleManualVendorEdit(val) {
    const inputManual = document.getElementById('esVendor');
    if (val === 'manual') {
        inputManual.style.display = 'block';
        inputManual.value = '';
        inputManual.focus();
    } else {
        inputManual.style.display = 'none';
        inputManual.value = val;
    }
}

function openEditService(id, teknisi, vendor, keluhan, hasil, biaya, status, tanggal, tanggalSelesai) {
    document.getElementById('formEditService').action = '/aset/service-edit/' + id;
    document.getElementById('esTeknisi').value       = teknisi;
    document.getElementById('esKeluhan').value       = keluhan;
    document.getElementById('esHasil').value         = hasil;
    document.getElementById('esBiaya').value         = biaya;
    document.getElementById('esTanggal').value       = tanggal;
    document.getElementById('esTanggalSelesai').value = tanggalSelesai;
    
    // Set Status
    var selStatus = document.getElementById('esStatus');
    for (var i = 0; i < selStatus.options.length; i++) {
        selStatus.options[i].selected = (selStatus.options[i].value === status);
    }
    
    // Set Vendor
    var selVendor = document.getElementById('esVendorSelect');
    var inputVendor = document.getElementById('esVendor');
    var vendorFound = false;
    
    if (!vendor || vendor === '') {
        selVendor.value = '';
        inputVendor.value = '';
        inputVendor.style.display = 'none';
    } else {
        for (var i = 0; i < selVendor.options.length; i++) {
            if (selVendor.options[i].value === vendor) {
                selVendor.selectedIndex = i;
                vendorFound = true;
                inputVendor.value = vendor;
                inputVendor.style.display = 'none';
                break;
            }
        }
        // Kalau vendor di database lamanya gak ada di list dropdown (berarti diketik manual dulu)
        if (!vendorFound) {
            selVendor.value = 'manual';
            inputVendor.value = vendor;
            inputVendor.style.display = 'block';
        }
    }

    new bootstrap.Modal(document.getElementById('modalEditService')).show();
}
</script>

</body>
</html>