<!-- MODAL EDIT JURNAL -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);">
      <div class="modal-header" style="border-color:var(--body-border);">
        <h5 class="modal-title" style="color:var(--body-text);">✏️ Edit Data Jurnal</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formEdit" action="" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="tipeInput" id="editTipeInputVal" value="harian">
        <div class="modal-body">
          <div class="row">
            <div class="col-12 mb-2">
              <span class="label-text">Tipe Pekerjaan</span>
              <div class="tipe-toggle">
                <div class="tipe-btn active-harian" id="editBtnHarian" onclick="setEditTipe('harian')">📅 HARIAN</div>
                <div class="tipe-btn" id="editBtnMulti" onclick="setEditTipe('multihari')">📆 MULTI-HARI</div>
              </div>
            </div>
            <div class="col-md-6" id="editFormHarian">
              <span class="label-text">Tanggal</span>
              <input type="date" name="tanggalManual" id="edit_tanggal" class="input-custom" required>
              <div class="row g-2">
                <div class="col-6"><span class="label-text">Jam Mulai</span><input type="time" name="jamMulai" id="edit_jamMulai" class="input-custom" style="margin-bottom:0;"></div>
                <div class="col-6"><span class="label-text">Jam Selesai</span><input type="time" name="jamSelesai" id="edit_jamSelesai" class="input-custom" style="margin-bottom:0;"></div>
              </div>
              <div style="margin-bottom:0.5rem;"></div>
              <div class="durasi-preview" id="editDurasiPreview">⏱ Durasi: <strong id="editDurasiText">-</strong></div>
            </div>
            <div class="col-md-6" id="editFormMultihari" style="display:none;">
              <span class="label-text" style="color:#9b6dff;">📅 Tgl &amp; Jam MULAI</span>
              <div class="row g-2">
                <div class="col-7"><input type="date" name="tanggalMulaiDate" id="edit_tanggalMulai" class="input-custom" style="margin-bottom:0;"></div>
                <div class="col-5"><input type="time" name="jamMulaiMulti" id="edit_jamMulaiMulti" class="input-custom" style="margin-bottom:0;"></div>
              </div>
              <div style="margin-bottom:0.5rem;"></div>
              <span class="label-text" style="color:#9b6dff;">🏁 Tgl &amp; Jam SELESAI</span>
              <div class="row g-2">
                <div class="col-7"><input type="date" name="tanggalSelesaiDate" id="edit_tanggalSelesai" class="input-custom" style="margin-bottom:0;"></div>
                <div class="col-5"><input type="time" name="jamSelesaiMulti" id="edit_jamSelesaiMulti" class="input-custom" style="margin-bottom:0;"></div>
              </div>
              <div style="margin-bottom:0.5rem;"></div>
              <div class="durasi-preview" id="editDurasiPreviewMulti" style="background:#1a0d3d;border-color:#6b3dbf;color:#c9aaff;display:none;">⏱ Durasi: <strong id="editDurasiTextMulti">-</strong></div>
            </div>
            <div class="col-md-6">
              <span class="label-text">Pemesan (User)</span>
              <input type="text" name="pemesan" id="edit_pemesan" class="input-custom" required>
              <span class="label-text">Aktivitas</span>
              <input type="text" name="aktivitas" id="edit_aktivitas" class="input-custom" required>
              <span class="label-text">Divisi</span>
              <select name="divisi" id="edit_divisi" class="input-custom">
                <option value="IT & IC">IT &amp; IC</option>
                <option value="HRGA">HRGA</option>
                <option value="Accounting">Accounting</option>
                <option value="Exim & Pembelian">Exim &amp; Pembelian</option>
                <option value="Operasional">Operasional</option>
                <option value="Finance">Finance</option>
                <option value="Produksi">Produksi</option>
                <option value="Bahanbaku">Bahanbaku</option>
                <option value="Admin Sales">Admin Sales</option>
              </select>
              <span class="label-text">Status</span>
              <select name="status" id="edit_status" class="input-custom">
                <option value="Solved">SOLVED</option>
                <option value="Pending">PENDING</option>
              </select>
            </div>
            <div class="col-md-6">
              <span class="label-text" style="color:#ffc107;">📷 Ganti Foto AWAL (Opsional)</span>
              <input type="file" name="fotoAwal" class="input-custom file-compress" accept="image/*">
              <small class="text-success fw-bold d-none compress-msg">✅ Foto dikompres!</small>
              <span class="label-text" style="color:#90ee90;">📷 Ganti Foto SESUDAH (Opsional)</span>
              <input type="file" name="foto" class="input-custom file-compress" accept="image/*">
              <small class="text-success fw-bold d-none compress-msg">✅ Foto dikompres!</small>
            </div>
            <div class="col-12">
              <span class="label-text">Deskripsi</span>
              <textarea name="deskripsi" id="edit_deskripsi" class="input-custom" rows="3" required></textarea>
