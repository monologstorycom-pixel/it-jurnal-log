<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ========== TIPE TOGGLE ==========
function setTipe(tipe) {
    document.getElementById('tipeInputVal').value = tipe;
    var isMulti = tipe === 'multihari';
    document.getElementById('formHarian').style.display    = isMulti ? 'none' : 'block';
    document.getElementById('formMultihari').style.display = isMulti ? 'block' : 'none';
    document.getElementById('btnHarian').className = 'tipe-btn' + (!isMulti ? ' active-harian' : '');
    document.getElementById('btnMulti').className  = 'tipe-btn' + (isMulti ? ' active-multi' : '');
}
function setEditTipe(tipe) {
    document.getElementById('editTipeInputVal').value = tipe;
    var isMulti = tipe === 'multihari';
    document.getElementById('editFormHarian').style.display    = isMulti ? 'none' : 'block';
    document.getElementById('editFormMultihari').style.display = isMulti ? 'block' : 'none';
    document.getElementById('editBtnHarian').className = 'tipe-btn' + (!isMulti ? ' active-harian' : '');
    document.getElementById('editBtnMulti').className  = 'tipe-btn' + (isMulti ? ' active-multi' : '');
    if (isMulti) updatePreviewMultiEdit();
    else updatePreviewHarian('edit_jamMulai','edit_jamSelesai','editDurasiPreview','editDurasiText');
}

// ========== DURASI ==========
function hitungMenit(a,b){if(!a||!b)return null;var aP=a.split(':').map(Number),bP=b.split(':').map(Number);var mA=aP[0]*60+aP[1],mB=bP[0]*60+bP[1];if(mB<mA)mB+=1440;return mB-mA>0?mB-mA:null;}
function hitungMenitDT(tA,jA,tB,jB){if(!tA||!tB)return null;var a=new Date(tA+'T'+(jA||'00:00')+':00'),b=new Date(tB+'T'+(jB||'00:00')+':00');var d=Math.floor((b-a)/60000);return d>0?d:null;}
function formatDurasi(m){if(!m||m<=0)return null;var h=Math.floor(m/1440),s=m%1440,j=Math.floor(s/60),mn=s%60,p=[];if(h>0)p.push(h+' hari');if(j>0)p.push(j+' jam');if(mn>0)p.push(mn+' menit');return p.length>0?p.join(' '):'0 menit';}
function updatePreviewHarian(mId,sId,pId,tId){var d=hitungMenit(document.getElementById(mId).value,document.getElementById(sId).value),el=document.getElementById(pId);if(d){document.getElementById(tId).textContent=formatDurasi(d);el.style.display='block';}else el.style.display='none';}
function updatePreviewMulti(){var d=hitungMenitDT(document.getElementById('tanggalMulaiDate').value,document.getElementById('jamMulaiMulti').value,document.getElementById('tanggalSelesaiDate').value,document.getElementById('jamSelesaiMulti').value),el=document.getElementById('durasiPreviewMulti');if(d){document.getElementById('durasiTextMulti').textContent=formatDurasi(d);el.style.display='block';}else el.style.display='none';}
function updatePreviewMultiEdit(){var d=hitungMenitDT(document.getElementById('edit_tanggalMulai').value,document.getElementById('edit_jamMulaiMulti').value,document.getElementById('edit_tanggalSelesai').value,document.getElementById('edit_jamSelesaiMulti').value),el=document.getElementById('editDurasiPreviewMulti');if(d){document.getElementById('editDurasiTextMulti').textContent=formatDurasi(d);el.style.display='block';}else el.style.display='none';}

['jamMulaiInput','jamSelesaiInput'].forEach(function(id){document.getElementById(id).addEventListener('change',function(){updatePreviewHarian('jamMulaiInput','jamSelesaiInput','durasiPreview','durasiText');});});
['tanggalMulaiDate','jamMulaiMulti','tanggalSelesaiDate','jamSelesaiMulti'].forEach(function(id){document.getElementById(id).addEventListener('change',updatePreviewMulti);});
['edit_jamMulai','edit_jamSelesai'].forEach(function(id){document.getElementById(id).addEventListener('change',function(){updatePreviewHarian('edit_jamMulai','edit_jamSelesai','editDurasiPreview','editDurasiText');});});
['edit_tanggalMulai','edit_jamMulaiMulti','edit_tanggalSelesai','edit_jamSelesaiMulti'].forEach(function(id){document.getElementById(id).addEventListener('change',updatePreviewMultiEdit);});

document.getElementById('tanggalInput').value = new Date().toISOString().split('T')[0];

// ========== MODAL HELPERS ==========
// ===== FOTO SLIDER ADMIN =====
var _aFUrls=[], _aFIdx=0;
function showFoto(urls, judul) {
    _aFUrls = Array.isArray(urls) ? urls : [urls];
    _aFIdx  = 0;
    _renderAdminFoto(judul);
    new bootstrap.Modal(document.getElementById('fotoModalAdmin')).show();
}
function _renderAdminFoto(judulOverride) {
    var total = _aFUrls.length;
    var url   = _aFUrls[_aFIdx];
    document.getElementById('popupImageAdmin').src = url;
    var svgCam = '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>';
    var judul = judulOverride || _aFUrls._judul || 'Dokumentasi';
    if(judulOverride) _aFUrls._judul = judulOverride;
    document.getElementById('fotoModalTitle').innerHTML = svgCam + ' ' + judul + (total>1?' ('+ (_aFIdx+1)+'/'+total+')':'');
    var btnP=document.getElementById('adminFotoPrev'), btnN=document.getElementById('adminFotoNext');
    if(total>1){btnP.style.display='flex';btnN.style.display='flex';btnP.style.opacity=_aFIdx===0?'0.3':'1';btnN.style.opacity=_aFIdx===total-1?'0.3':'1';}
    else{btnP.style.display='none';btnN.style.display='none';}
    var dotsEl=document.getElementById('adminFotoDots'); dotsEl.innerHTML='';
    if(total>1){
        _aFUrls.forEach(function(u,i){
            var th=document.createElement('img'); th.src=u;
            th.onclick=(function(idx){return function(){_aFIdx=idx;_renderAdminFoto();};})(i);
            Object.assign(th.style,{width:'52px',height:'52px',objectFit:'cover',borderRadius:'6px',cursor:'pointer',transition:'all 0.15s',border:i===_aFIdx?'2px solid #4ade80':'2px solid transparent',opacity:i===_aFIdx?'1':'0.55'});
            dotsEl.appendChild(th);
        });
        dotsEl.style.padding='10px 16px';
    } else { dotsEl.style.padding='0'; }
}
function adminSliderNav(dir){_aFIdx=Math.max(0,Math.min(_aFUrls.length-1,_aFIdx+dir));_renderAdminFoto();}
document.addEventListener('keydown',function(e){var m=document.getElementById('fotoModalAdmin');if(!m||!m.classList.contains('show'))return;if(e.key==='ArrowRight')adminSliderNav(1);if(e.key==='ArrowLeft')adminSliderNav(-1);});
function openUploadModal(id){document.getElementById('formUploadSusulan').action='/upload-foto/'+id;new bootstrap.Modal(document.getElementById('uploadSusulanModal')).show();}
function openUploadAwalModal(id){document.getElementById('formUploadAwal').action='/upload-foto-awal/'+id;new bootstrap.Modal(document.getElementById('uploadAwalModal')).show();}
function openEditModal(id,aktivitas,divisi,pemesan,deskripsi,status,tipe,tanggal,jamMulai,jamSelesai,tglMulai,tglSelesai){
    document.getElementById('formEdit').action='/edit/'+id;
    document.getElementById('edit_aktivitas').value=aktivitas;
    document.getElementById('edit_pemesan').value=pemesan;
    document.getElementById('edit_deskripsi').value=deskripsi.replace(/\\n/g,'\n');
    document.getElementById('edit_divisi').value=divisi;
    document.getElementById('edit_status').value=status;
    if(tipe==='multihari'){setEditTipe('multihari');document.getElementById('edit_tanggalMulai').value=tglMulai;document.getElementById('edit_tanggalSelesai').value=tglSelesai;document.getElementById('edit_jamMulaiMulti').value=jamMulai;document.getElementById('edit_jamSelesaiMulti').value=jamSelesai;updatePreviewMultiEdit();}
    else{setEditTipe('harian');document.getElementById('edit_tanggal').value=tanggal;document.getElementById('edit_jamMulai').value=jamMulai;document.getElementById('edit_jamSelesai').value=jamSelesai;updatePreviewHarian('edit_jamMulai','edit_jamSelesai','editDurasiPreview','editDurasiText');}
    new bootstrap.Modal(document.getElementById('editModal')).show();
}
function confirmDelete(id,aktivitas){document.getElementById('formDelete').action='/delete/'+id;document.getElementById('deleteItemName').textContent='"'+aktivitas+'"';new bootstrap.Modal(document.getElementById('deleteModal')).show();}

// ========== COMPRESS IMAGE ==========
async function compressImage(file){return new Promise(function(resolve,reject){var reader=new FileReader();reader.readAsDataURL(file);reader.onload=function(e){var img=new Image();img.src=e.target.result;img.onload=function(){var w=img.width,h=img.height,max=1000;if(w>h){if(w>max){h=Math.round(h*max/w);w=max;}}else{if(h>max){w=Math.round(w*max/h);h=max;}}var canvas=document.createElement('canvas');canvas.width=w;canvas.height=h;canvas.getContext('2d').drawImage(img,0,0,w,h);canvas.toBlob(function(blob){resolve(new File([blob],file.name.replace(/\.[^/.]+$/,'.jpg'),{type:'image/jpeg',lastModified:Date.now()}));}, 'image/jpeg',0.6);};};reader.onerror=function(e){reject(e);};}); }
document.querySelectorAll('.file-compress').forEach(function(input){input.addEventListener('change',async function(e){var file=e.target.files[0];if(!file||!file.type.startsWith('image/'))return;var msg=e.target.nextElementSibling;try{var c=await compressImage(file);var dt=new DataTransfer();dt.items.add(c);e.target.files=dt.files;if(msg&&msg.classList.contains('compress-msg'))msg.classList.remove('d-none');}catch(err){console.error('Gagal kompres:',err);}});});

// ========== PWA ==========
