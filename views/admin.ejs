<!-- MODAL DELETE -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-danger">
      <div class="modal-header border-danger">
        <h5 class="modal-title text-white">🗑️ Konfirmasi Hapus</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="text-white mb-1">Yakin mau hapus data ini?</p>
        <p id="deleteItemName" class="fw-bold" style="color:#ff6b6b;font-size:0.9rem;"></p>
        <p class="text-secondary" style="font-size:0.8rem;">⚠️ Data yang dihapus tidak bisa dikembalikan.</p>
      </div>
      <div class="modal-footer border-danger">
        <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
        <form id="formDelete" action="" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-danger fw-bold">YA, HAPUS SEKARANG</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ========== TIPE TOGGLE ==========
function setTipe(tipe) {
    document.getElementById('tipeInputVal').value = tipe;
    var isMulti = tipe === 'multihari';
    document.getElementById('formHarian').style.display    = isMulti ? 'none' : 'block';
    document.getElementById('formMultihari').style.display = isMulti ? 'block' : 'none';
    document.getElementById('btnHarian').className = 'tipe-btn' + (!isMulti ? ' active-harian' : '');
    document.getElementById('btnMulti').className  = 'tipe-btn' + (isMulti ? ' active-multi' : '');
}
function setEditTipe(tipe) {
    document.getElementById('editTipeInputVal').value = tipe;
    var isMulti = tipe === 'multihari';
    document.getElementById('editFormHarian').style.display    = isMulti ? 'none' : 'block';
    document.getElementById('editFormMultihari').style.display = isMulti ? 'block' : 'none';
    document.getElementById('editBtnHarian').className = 'tipe-btn' + (!isMulti ? ' active-harian' : '');
    document.getElementById('editBtnMulti').className  = 'tipe-btn' + (isMulti ? ' active-multi' : '');
    if (isMulti) updatePreviewMultiEdit();
    else updatePreviewHarian('edit_jamMulai','edit_jamSelesai','editDurasiPreview','editDurasiText');
}

// ========== DURASI HITUNG ==========
function hitungMenit(jamA, jamB) {
    if (!jamA || !jamB) return null;
    var aP = jamA.split(':').map(Number), bP = jamB.split(':').map(Number);
    var mA = aP[0]*60+aP[1], mB = bP[0]*60+bP[1];
    if (mB < mA) mB += 1440;
    return mB - mA > 0 ? mB - mA : null;
}
function hitungMenitDateTime(tglA, jamA, tglB, jamB) {
    if (!tglA || !tglB) return null;
    var dtA = new Date(tglA + 'T' + (jamA || '00:00') + ':00');
    var dtB = new Date(tglB + 'T' + (jamB || '00:00') + ':00');
    var diff = Math.floor((dtB - dtA) / 60000);
    return diff > 0 ? diff : null;
}
function formatDurasi(m) {
    if (!m || m <= 0) return null;
    var hari = Math.floor(m / 1440), sisa1 = m % 1440;
    var jam = Math.floor(sisa1 / 60), menit = sisa1 % 60;
    var parts = [];
    if (hari > 0) parts.push(hari + ' hari');
    if (jam > 0) parts.push(jam + ' jam');
    if (menit > 0) parts.push(menit + ' menit');
    return parts.length > 0 ? parts.join(' ') : '0 menit';
}
function updatePreviewHarian(mId, sId, previewId, textId) {
    var d = hitungMenit(document.getElementById(mId).value, document.getElementById(sId).value);
    var el = document.getElementById(previewId);
    if (d) { document.getElementById(textId).textContent = formatDurasi(d); el.style.display = 'block'; }
    else el.style.display = 'none';
}
function updatePreviewMulti() {
    var d = hitungMenitDateTime(
        document.getElementById('tanggalMulaiDate').value, document.getElementById('jamMulaiMulti').value,
        document.getElementById('tanggalSelesaiDate').value, document.getElementById('jamSelesaiMulti').value
    );
    var el = document.getElementById('durasiPreviewMulti');
    if (d) { document.getElementById('durasiTextMulti').textContent = formatDurasi(d); el.style.display = 'block'; }
    else el.style.display = 'none';
}
function updatePreviewMultiEdit() {
    var d = hitungMenitDateTime(
        document.getElementById('edit_tanggalMulai').value, document.getElementById('edit_jamMulaiMulti').value,
        document.getElementById('edit_tanggalSelesai').value, document.getElementById('edit_jamSelesaiMulti').value
    );
    var el = document.getElementById('editDurasiPreviewMulti');
    if (d) { document.getElementById('editDurasiTextMulti').textContent = formatDurasi(d); el.style.display = 'block'; }
    else el.style.display = 'none';
}

// Event listeners
['jamMulaiInput','jamSelesaiInput'].forEach(function(id) {
    document.getElementById(id).addEventListener('change', function(){ updatePreviewHarian('jamMulaiInput','jamSelesaiInput','durasiPreview','durasiText'); });
});
['tanggalMulaiDate','jamMulaiMulti','tanggalSelesaiDate','jamSelesaiMulti'].forEach(function(id) {
    document.getElementById(id).addEventListener('change', updatePreviewMulti);
});
['edit_jamMulai','edit_jamSelesai'].forEach(function(id) {
    document.getElementById(id).addEventListener('change', function(){ updatePreviewHarian('edit_jamMulai','edit_jamSelesai','editDurasiPreview','editDurasiText'); });
});
['edit_tanggalMulai','edit_jamMulaiMulti','edit_tanggalSelesai','edit_jamSelesaiMulti'].forEach(function(id) {
    document.getElementById(id).addEventListener('change', updatePreviewMultiEdit);
});

// Default tanggal hari ini
document.getElementById('tanggalInput').value = new Date().toISOString().split('T')[0];

// ========== FOTO & MODAL ==========
function showFoto(url, judul) {
    document.getElementById('popupImageAdmin').src = url;
    document.getElementById('fotoModalTitle').textContent = '📷 ' + (judul||'Dokumentasi');
    new bootstrap.Modal(document.getElementById('fotoModalAdmin')).show();
}
function openUploadModal(id) {
    document.getElementById('formUploadSusulan').action = '/upload-foto/' + id;
    new bootstrap.Modal(document.getElementById('uploadSusulanModal')).show();
}
function openUploadAwalModal(id) {
    document.getElementById('formUploadAwal').action = '/upload-foto-awal/' + id;
    new bootstrap.Modal(document.getElementById('uploadAwalModal')).show();
}
function openEditModal(id, aktivitas, divisi, pemesan, deskripsi, status, tipe, tanggal, jamMulai, jamSelesai, tglMulai, tglSelesai) {
    document.getElementById('formEdit').action = '/edit/' + id;
    document.getElementById('edit_aktivitas').value = aktivitas;
    document.getElementById('edit_pemesan').value   = pemesan;
    document.getElementById('edit_deskripsi').value = deskripsi.replace(/\\n/g, '\n');
    document.getElementById('edit_divisi').value    = divisi;
    document.getElementById('edit_status').value    = status;
    if (tipe === 'multihari') {
        setEditTipe('multihari');
        document.getElementById('edit_tanggalMulai').value   = tglMulai;
        document.getElementById('edit_tanggalSelesai').value = tglSelesai;
        document.getElementById('edit_jamMulaiMulti').value  = jamMulai;
        document.getElementById('edit_jamSelesaiMulti').value= jamSelesai;
        updatePreviewMultiEdit();
    } else {
        setEditTipe('harian');
        document.getElementById('edit_tanggal').value    = tanggal;
        document.getElementById('edit_jamMulai').value   = jamMulai;
        document.getElementById('edit_jamSelesai').value = jamSelesai;
        updatePreviewHarian('edit_jamMulai','edit_jamSelesai','editDurasiPreview','editDurasiText');
    }
    new bootstrap.Modal(document.getElementById('editModal')).show();
}
function confirmDelete(id, aktivitas) {
    document.getElementById('formDelete').action = '/delete/' + id;
    document.getElementById('deleteItemName').textContent = '"' + aktivitas + '"';
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}

// ========== COMPRESS IMAGE ==========
async function compressImage(file) {
    return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = function(e) {
            var img = new Image(); img.src = e.target.result;
            img.onload = function() {
                var w = img.width, h = img.height, max = 1000;
                if (w > h) { if (w > max) { h = Math.round(h*max/w); w = max; } }
                else { if (h > max) { w = Math.round(w*max/h); h = max; } }
                var canvas = document.createElement('canvas');
                canvas.width = w; canvas.height = h;
                canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                canvas.toBlob(function(blob) {
                    resolve(new File([blob], file.name.replace(/\.[^/.]+$/, '.jpg'), { type: 'image/jpeg', lastModified: Date.now() }));
                }, 'image/jpeg', 0.6);
            };
        };
        reader.onerror = function(e) { reject(e); };
    });
}
document.querySelectorAll('.file-compress').forEach(function(input) {
    input.addEventListener('change', async function(e) {
        var file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        var msg = e.target.nextElementSibling;
        try {
            var c = await compressImage(file);
            var dt = new DataTransfer(); dt.items.add(c); e.target.files = dt.files;
            if (msg && msg.classList.contains('compress-msg')) msg.classList.remove('d-none');
        } catch(err) { console.error('Gagal kompres:', err); }
    });
});

// ========== PWA ==========
if ('serviceWorker' in navigator) { window.addEventListener('load', function() { navigator.serviceWorker.register('/sw.js'); }); }
var saveToastEl = document.getElementById('saveToast');
if (saveToastEl) new bootstrap.Toast(saveToastEl, { delay: 4000 }).show();

// ========== NOTES ==========
async function loadAdminNotes() {
    try {
        var res = await fetch('/api/notes'), notes = await res.json(), el = document.getElementById('adminNotesList');
        if (notes.length === 0) { el.innerHTML = '<p style="color:#666;">Belum ada catatan.</p>'; return; }
        el.innerHTML = notes.map(function(n) {
            var d = new Date(n.createdAt).toLocaleString('id-ID', { dateStyle:'short', timeStyle:'short' });
            return '<div style="background:#0d0d0d;padding:10px;border-radius:4px;margin-bottom:6px;border-left:2px solid #0d6efd;display:flex;justify-content:space-between;align-items:start;">' +
                '<div><strong style="color:#fff;font-size:0.9rem;">' + n.title + '</strong><p style="color:#999;margin:2px 0 0 0;font-size:0.8rem;">' + n.content + '</p><small style="color:#666;">' + d + '</small></div>' +
                '<button onclick="deleteAdminNote(' + n.id + ')" class="btn btn-sm btn-danger fw-bold" style="padding:2px 6px;font-size:0.7rem;">🗑️</button></div>';
        }).join('');
    } catch(e) { document.getElementById('adminNotesList').innerHTML = '<p style="color:#f00;">Error</p>'; }
}
async function addNoteAdmin() {
    var title = document.getElementById('noteTitle').value.trim(), content = document.getElementById('noteContent').value.trim();
    if (!title || !content) { alert('Judul dan isi harus diisi!'); return; }
    await fetch('/api/notes', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({title,content}) });
    document.getElementById('noteTitle').value = ''; document.getElementById('noteContent').value = ''; loadAdminNotes();
}
async function deleteAdminNote(id) {
    if (!confirm('Yakin hapus catatan ini?')) return;
    await fetch('/api/notes/' + id, { method:'DELETE' }); loadAdminNotes();
}
window.addEventListener('load', function() { loadAdminNotes(); });

// PWA Install
var deferredPrompt, installBtn = document.getElementById('btnInstallPwa');
window.addEventListener('beforeinstallprompt', function(e) { e.preventDefault(); deferredPrompt = e; installBtn.style.display = 'block'; });
installBtn.addEventListener('click', async function() { if (deferredPrompt) { deferredPrompt.prompt(); await deferredPrompt.userChoice; deferredPrompt = null; installBtn.style.display = 'none'; } });
window.addEventListener('appinstalled', function() { installBtn.style.display = 'none'; });
</script>
