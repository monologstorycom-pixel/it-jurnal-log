<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT JURNAL LOG by RSBY</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#161b22">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="icon" type="image/png" href="/icon-512.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0d0d0d !important; color: #fff; font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; }
        .app-nav { border-bottom: 2px solid #262626; padding: 1rem 2rem; background: #161b22; }
        .input-custom { background: #1a1a1a !important; border: 1px solid #444 !important; border-radius: 6px; color: #fff !important; padding: 10px; width: 100%; margin-bottom: 0.75rem; font-size: 0.85rem; }
        .input-custom:focus { outline: none; border-color: #888 !important; }
        .label-text { color: #878787; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 4px; display: block; }
        .table-container { background: #141414 !important; border-radius: 10px; border: 1px solid #333; }
        .table { min-width: 1000px; margin: 0; }
        .table tbody tr { background: #ffffff !important; border-bottom: 1px solid #ddd; }
        .table td { padding: 0.9rem 0.8rem; vertical-align: middle; color: #000 !important; font-size: 0.82rem; line-height: 1.4; }
        .txt-bold { color: #000 !important; font-weight: 700; }
        .status-solved { color: #008000 !important; font-weight: 800; font-size: 0.7rem; }
        .status-pending { color: #8b6508 !important; font-weight: 800; font-size: 0.7rem; }
        .durasi-badge { display: inline-block; background: #e8f4fd; color: #0066aa; border: 1px solid #b3d7f0; border-radius: 4px; padding: 2px 7px; font-size: 0.68rem; font-weight: 700; margin-top: 3px; }
        .durasi-badge-multi { background: #f0e8fd; color: #6600aa; border-color: #d0b0f0; }
        .jam-info { font-size: 0.72rem; color: #444; margin-top: 2px; }
        .durasi-preview { background: #0d2a0d; border: 1px solid #1a5c1a; border-radius: 6px; padding: 8px 12px; margin-bottom: 0.75rem; font-size: 0.82rem; color: #4caf50; font-weight: 700; text-align: center; display: none; }
        .btn-action { border: none; padding: 3px 8px; font-size: 0.65rem; border-radius: 4px; font-weight: 700; cursor: pointer; width: 100%; margin-bottom: 4px; }
        .btn-foto { display: block; width: 100%; padding: 4px 7px; border-radius: 4px; font-size: 0.65rem; font-weight: 700; cursor: pointer; margin-bottom: 3px; white-space: nowrap; }
        .btn-foto-sesudah  { background: #111; color: #fff; border: none; }
        .btn-foto-awal     { background: #5a3e00; color: #ffc107; border: 1px solid #ffc107; }
        .btn-tambah-sesudah { background: transparent; color: #198754; border: 1px solid #198754; }
        .btn-tambah-awal    { background: transparent; color: #ffc107; border: 1px solid #ffc107; }

        /* Toggle TIPE INPUT */
        .tipe-toggle { display: flex; gap: 6px; margin-bottom: 0.75rem; }
        .tipe-btn { flex: 1; padding: 8px; border-radius: 6px; border: 1px solid #444; background: #1a1a1a; color: #888; font-size: 0.75rem; font-weight: 700; cursor: pointer; text-align: center; transition: all 0.2s; }
        .tipe-btn.active-harian  { background: #0d3d0d; border-color: #2d8c2d; color: #4caf50; }
        .tipe-btn.active-multi   { background: #1a0d3d; border-color: #6b3dbf; color: #9b6dff; }
        .multi-badge { display: inline-block; background: #1a0d3d; color: #9b6dff; border: 1px solid #6b3dbf; border-radius: 3px; padding: 1px 5px; font-size: 0.6rem; font-weight: 700; margin-left: 4px; vertical-align: middle; }
        .separator-line { border: none; border-top: 1px dashed #333; margin: 0.5rem 0 0.75rem; }

        @media (max-width: 768px) {
            .app-nav { padding: 1rem; text-align: center; }
            .container-fluid { padding: 1rem !important; }
            .form-sidebar { margin-bottom: 2rem; }
        }
    </style>
</head>
<body>
<nav class="app-nav" style="display:flex;justify-content:space-between;align-items:center;">
    <div style="font-weight:700;">>_ IT SUPPORT LOG | DASHBOARD</div>
    <button id="btnInstallPwa" class="btn btn-sm btn-outline-warning fw-bold" style="display:none;">📲 INSTAL APLIKASI</button>
</nav>

<div class="container-fluid p-4">
  <div class="row">

    <!-- ===== FORM SIDEBAR ===== -->
    <div class="col-md-3 form-sidebar">
      <form action="/save" method="POST" enctype="multipart/form-data" id="mainForm">
        <input type="hidden" name="tipeInput" id="tipeInputVal" value="harian">

        <!-- TOGGLE TIPE -->
        <span class="label-text">Tipe Pekerjaan</span>
        <div class="tipe-toggle">
          <div class="tipe-btn active-harian" id="btnHarian" onclick="setTipe('harian')">📅 HARIAN</div>
          <div class="tipe-btn" id="btnMulti" onclick="setTipe('multihari')">📆 MULTI-HARI</div>
        </div>

        <!-- FORM HARIAN -->
        <div id="formHarian">
          <span class="label-text">Tanggal</span>
          <input type="date" name="tanggalManual" id="tanggalInput" class="input-custom" required>
          <div class="row g-2">
            <div class="col-6">
              <span class="label-text">Jam Mulai</span>
              <input type="time" name="jamMulai" id="jamMulaiInput" class="input-custom" style="margin-bottom:0;">
            </div>
            <div class="col-6">
              <span class="label-text">Jam Selesai</span>
              <input type="time" name="jamSelesai" id="jamSelesaiInput" class="input-custom" style="margin-bottom:0;">
            </div>
          </div>
          <div style="margin-bottom:0.75rem;"></div>
          <div class="durasi-preview" id="durasiPreview">⏱ Durasi: <strong id="durasiText">-</strong></div>
        </div>

        <!-- FORM MULTI-HARI -->
        <div id="formMultihari" style="display:none;">
          <div style="background:#1a0d3d;border:1px solid #6b3dbf;border-radius:6px;padding:10px;margin-bottom:0.75rem;font-size:0.75rem;color:#c9aaff;">
            💡 Untuk pekerjaan yang berlangsung lebih dari 1 hari (vendor, instalasi, dll)
          </div>
          <span class="label-text" style="color:#9b6dff;">📅 Tanggal & Jam MULAI</span>
          <div class="row g-2">
            <div class="col-7">
              <input type="date" name="tanggalMulaiDate" id="tanggalMulaiDate" class="input-custom" style="margin-bottom:0;">
            </div>
            <div class="col-5">
              <input type="time" name="jamMulaiMulti" id="jamMulaiMulti" class="input-custom" style="margin-bottom:0;">
            </div>
          </div>
          <div style="margin-bottom:0.5rem;"></div>
          <span class="label-text" style="color:#9b6dff;">🏁 Tanggal & Jam SELESAI</span>
          <div class="row g-2">
            <div class="col-7">
              <input type="date" name="tanggalSelesaiDate" id="tanggalSelesaiDate" class="input-custom" style="margin-bottom:0;">
            </div>
            <div class="col-5">
              <input type="time" name="jamSelesaiMulti" id="jamSelesaiMulti" class="input-custom" style="margin-bottom:0;">
            </div>
          </div>
          <div style="margin-bottom:0.5rem;"></div>
          <div class="durasi-preview" id="durasiPreviewMulti" style="background:#1a0d3d;border-color:#6b3dbf;color:#c9aaff;">⏱ Durasi: <strong id="durasiTextMulti">-</strong></div>
        </div>

        <hr class="separator-line">

        <span class="label-text">Pemesan (User)</span>
        <input type="text" name="pemesan" class="input-custom" required>
        <span class="label-text">Aktivitas</span>
        <input type="text" name="aktivitas" class="input-custom" required>
        <span class="label-text">Divisi</span>
        <select name="divisi" class="input-custom">
          <option value="IT & IC">IT &amp; IC</option>
          <option value="HRGA">HRGA</option>
          <option value="Accounting">Accounting</option>
          <option value="Exim & Pembelian">Exim &amp; Pembelian</option>
          <option value="Operasional">Operasional</option>
          <option value="Finance">Finance</option>
          <option value="Produksi">Produksi</option>
          <option value="Bahanbaku">Bahanbaku</option>
          <option value="MAINTENANCE">MAINTENANCE</option>
          <option value="Admin Sales">Admin Sales</option>
        </select>
        <span class="label-text">Deskripsi</span>
        <textarea name="deskripsi" class="input-custom" rows="3" required></textarea>
        <span class="label-text">Status</span>
        <select name="status" class="input-custom">
          <option value="Solved">SOLVED</option>
          <option value="Pending">PENDING</option>
        </select>
        <span class="label-text" style="color:#ffc107;">📷 Foto AWAL (Sebelum)</span>
        <input type="file" name="fotoAwal" class="input-custom file-compress" accept="image/*" capture="environment">
        <small class="text-success fw-bold d-none compress-msg">✅ Foto dikompres!</small>
        <span class="label-text" style="color:#90ee90;">📷 Foto SESUDAH (Solved)</span>
        <input type="file" name="foto" class="input-custom file-compress" accept="image/*" capture="environment">
        <small class="text-success fw-bold d-none compress-msg">✅ Foto dikompres!</small>
        <button type="submit" class="btn btn-light w-100 fw-bold mt-2">SIMPAN DATA</button>
      </form>
    </div>

    <!-- ===== TABEL ===== -->
    <div class="col-md-9">

      <% if (saved) { %>
      <div aria-live="polite" aria-atomic="true" class="position-fixed top-0 end-0 p-3" style="z-index:1055;">
        <div id="saveToast" class="toast align-items-center text-bg-success border-0" role="alert">
          <div class="d-flex">
            <div class="toast-body">✅ Data berhasil disimpan.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
          </div>
        </div>
      </div>
      <% } %>

      <!-- NOTES -->
      <div class="mb-3 p-3" style="background:#161b22;border-radius:8px;border:1px solid #333;">
        <div style="color:#fff;font-weight:700;margin-bottom:10px;font-size:0.9rem;">📝 CATATAN (NOTES)</div>
        <input type="text" id="noteTitle" placeholder="Judul catatan..." class="form-control bg-dark text-white border-secondary mb-2">
        <textarea id="noteContent" placeholder="Isi catatan..." class="form-control bg-dark text-white border-secondary mb-2" rows="2"></textarea>
        <button onclick="addNoteAdmin()" class="btn btn-sm btn-success fw-bold">➕ TAMBAH CATATAN</button>
        <div id="adminNotesList" style="color:#aaa;font-size:0.85rem;margin-top:12px;">Loading notes...</div>
      </div>

      <!-- FILTER -->
      <div class="mb-3 p-3" style="background:#161b22;border-radius:8px;border:1px solid #333;">
        <form action="/kerja" method="GET" class="row g-2 align-items-center m-0">
          <div class="col-auto"><span class="small fw-bold text-secondary">CARI DATA LAMA:</span></div>
          <div class="col-auto">
            <select name="month" class="form-select form-select-sm bg-dark text-white border-secondary">
              <option value="" disabled selected>Pilih Bulan...</option>
              <% ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'].forEach((m,i) => { %>
                <option value="<%= i+1 %>"><%= m %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-auto">
            <select name="year" class="form-select form-select-sm bg-dark text-white border-secondary">
              <% yearOptions.forEach(y => { %><option value="<%= y %>"><%= y %></option><% }) %>
            </select>
          </div>
          <div class="col-auto">
            <select name="status" class="form-select form-select-sm bg-dark text-white border-secondary">
              <option value="">Semua Status</option>
              <option value="Pending">PENDING</option>
              <option value="Solved">SOLVED</option>
            </select>
          </div>
          <div class="col-auto"><button type="submit" class="btn btn-sm btn-primary fw-bold">CARI</button></div>
          <div class="col-auto ms-md-auto"><a href="/kerja" class="btn btn-sm btn-outline-secondary text-white fw-bold">SEMUA</a></div>
        </form>
      </div>

      <!-- TABLE -->
      <div class="table-container table-responsive">
        <table class="table">
          <thead>
            <tr style="background:#1f242b;color:#fff;">
              <th>WAKTU &amp; DURASI</th>
              <th>UNIT</th>
              <th style="width:32%;">AKTIVITAS</th>
              <th>STATUS</th>
              <th class="text-center">FOTO</th>
              <th class="text-center">AKSI</th>
            </tr>
          </thead>
          <tbody>
            <% journals.forEach(item => { %>
            <% var isMulti = item.tipeInput === 'multihari'; %>
            <tr style="<%= isMulti ? 'background: #fffbf0 !important;' : '' %>">
              <td style="min-width:145px;">
                <% if (isMulti && item.tanggalMulai && item.tanggalSelesai) { %>
                  <span class="multi-badge">📆 MULTI-HARI</span>
                  <div style="font-size:0.78rem;color:#6600aa;font-weight:600;margin-top:3px;">
                    🗓 <%= new Date(item.tanggalMulai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                    <% if(item.jamMulai) { %><span style="color:#888;font-size:0.7rem;"> <%= item.jamMulai %></span><% } %>
                  </div>
                  <div style="font-size:0.7rem;color:#888;margin:1px 0;">  ↓</div>
                  <div style="font-size:0.78rem;color:#6600aa;font-weight:600;">
                    🏁 <%= new Date(item.tanggalSelesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                    <% if(item.jamSelesai) { %><span style="color:#888;font-size:0.7rem;"> <%= item.jamSelesai %></span><% } %>
                  </div>
                  <% if(item.durasiMenit) { %><span class="durasi-badge durasi-badge-multi">⏱ <%= formatDurasi(item.durasiMenit) %></span><% } %>
                <% } else { %>
                  <div style="font-family:monospace;font-size:0.8rem;color:#006666;font-weight:600;">
                    <%= new Date(item.tanggalManual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                  </div>
                  <% if(item.jamMulai) { %><div class="jam-info">🕐 Mulai: <strong><%= item.jamMulai %></strong></div><% } %>
                  <% if(item.jamSelesai) { %><div class="jam-info">🕔 Selesai: <strong><%= item.jamSelesai %></strong></div><% } %>
                  <% if(item.durasiMenit) { %><span class="durasi-badge">⏱ <%= formatDurasi(item.durasiMenit) %></span><% } %>
                <% } %>
              </td>
              <td style="white-space:nowrap;">
                <div class="txt-bold"><%= item.divisi %></div>
                <div style="font-size:0.75rem;color:#555;">User: <%= item.pemesan %></div>
              </td>
              <td>
                <div class="txt-bold" style="margin-bottom:3px;"><%= item.aktivitas %></div>
                <div style="font-size:0.8rem;color:#444;"><%= item.deskripsi %></div>
              </td>
              <td><span class="<%= item.status==='Solved' ? 'status-solved' : 'status-pending' %>"><%= item.status %></span></td>
              <td style="min-width:115px;">
                <% if(item.fotoAwalUrl) { %>
                  <button class="btn-foto btn-foto-awal" onclick="showFoto('<%= item.fotoAwalUrl %>','Kondisi AWAL')">📷 AWAL</button>
                <% } else { %>
                  <button class="btn-foto btn-tambah-awal" onclick="openUploadAwalModal(<%= item.id %>)">+ Foto Awal</button>
                <% } %>
                <% if(item.fotoUrl) { %>
                  <button class="btn-foto btn-foto-sesudah" onclick="showFoto('<%= item.fotoUrl %>','Kondisi SESUDAH')">📷 SESUDAH</button>
                <% } else { %>
                  <button class="btn-foto btn-tambah-sesudah" onclick="openUploadModal(<%= item.id %>)">+ Foto Sesudah</button>
                <% } %>
              </td>
              <td class="text-center" style="min-width:110px;">
                <% if(item.status==='Pending') { %>
                  <form action="/update-status/<%= item.id %>" method="POST">
                    <input type="hidden" name="newStatus" value="Solved">
                    <button type="submit" class="btn-action" style="background:#198754;color:#fff;">SET SOLVED</button>
                  </form>
                <% } %>
                <button type="button" class="btn-action" style="background:#0d6efd;color:#fff;margin-bottom:4px;" onclick="openEditModal(
                  <%= item.id %>,
                  `<%- item.aktivitas.replace(/`/g,'\\`') %>`,
                  `<%= item.divisi %>`,
                  `<%- item.pemesan.replace(/`/g,'\\`') %>`,
                  `<%- item.deskripsi.replace(/`/g,'\\`').replace(/\n/g,'\\n') %>`,
                  `<%= item.status %>`,
                  `<%= item.tipeInput || 'harian' %>`,
                  `<%= new Date(item.tanggalManual).toISOString().slice(0,10) %>`,
                  `<%= item.jamMulai || '' %>`,
                  `<%= item.jamSelesai || '' %>`,
                  `<%= item.tanggalMulai ? new Date(item.tanggalMulai).toISOString().slice(0,10) : '' %>`,
                  `<%= item.tanggalSelesai ? new Date(item.tanggalSelesai).toISOString().slice(0,10) : '' %>`
                )">EDIT</button>
                <button type="button" class="btn-action" style="background:#dc3545;color:#fff;" onclick="confirmDelete(<%= item.id %>,`<%- item.aktivitas.replace(/`/g,'\\`') %>`)">HAPUS</button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- MODAL FOTO -->
<div class="modal fade" id="fotoModalAdmin" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content bg-dark border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title text-white" id="fotoModalTitle">Dokumentasi</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-3">
        <img id="popupImageAdmin" src="" class="img-fluid rounded" style="max-height:75vh;">
      </div>
    </div>
  </div>
</div>

<!-- MODAL UPLOAD SESUDAH -->
<div class="modal fade" id="uploadSusulanModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title text-white">📷 Upload Foto SESUDAH</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formUploadSusulan" action="" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <input type="file" name="foto" class="input-custom m-0 file-compress" required accept="image/*" capture="environment">
          <small class="text-success fw-bold d-none compress-msg mt-1">✅ Foto dikompres!</small>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
          <button type="submit" class="btn btn-success fw-bold">UPLOAD</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- MODAL UPLOAD AWAL -->
<div class="modal fade" id="uploadAwalModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-warning">
      <div class="modal-header border-warning">
        <h5 class="modal-title text-white">📷 Upload Foto AWAL</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formUploadAwal" action="" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <input type="file" name="fotoAwal" class="input-custom m-0 file-compress" required accept="image/*" capture="environment">
          <small class="text-success fw-bold d-none compress-msg mt-1">✅ Foto dikompres!</small>
        </div>
        <div class="modal-footer border-warning">
          <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
          <button type="submit" class="btn btn-warning fw-bold text-dark">UPLOAD</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- MODAL EDIT -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content bg-dark border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title text-white">✏️ Edit Data Jurnal</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formEdit" action="" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="tipeInput" id="editTipeInputVal" value="harian">
        <div class="modal-body">
          <div class="row">
            <div class="col-12 mb-2">
              <span class="label-text">Tipe Pekerjaan</span>
              <div class="tipe-toggle">
                <div class="tipe-btn active-harian" id="editBtnHarian" onclick="setEditTipe('harian')">📅 HARIAN</div>
                <div class="tipe-btn" id="editBtnMulti" onclick="setEditTipe('multihari')">📆 MULTI-HARI</div>
              </div>
            </div>

            <!-- EDIT HARIAN -->
            <div class="col-md-6" id="editFormHarian">
              <span class="label-text">Tanggal</span>
              <input type="date" name="tanggalManual" id="edit_tanggal" class="input-custom" required>
              <div class="row g-2">
                <div class="col-6">
                  <span class="label-text">Jam Mulai</span>
                  <input type="time" name="jamMulai" id="edit_jamMulai" class="input-custom" style="margin-bottom:0;">
                </div>
                <div class="col-6">
                  <span class="label-text">Jam Selesai</span>
                  <input type="time" name="jamSelesai" id="edit_jamSelesai" class="input-custom" style="margin-bottom:0;">
                </div>
              </div>
              <div style="margin-bottom:0.5rem;"></div>
              <div class="durasi-preview" id="editDurasiPreview">⏱ Durasi: <strong id="editDurasiText">-</strong></div>
            </div>

            <!-- EDIT MULTI-HARI -->
            <div class="col-md-6" id="editFormMultihari" style="display:none;">
              <span class="label-text" style="color:#9b6dff;">📅 Tgl &amp; Jam MULAI</span>
              <div class="row g-2">
                <div class="col-7"><input type="date" name="tanggalMulaiDate" id="edit_tanggalMulai" class="input-custom" style="margin-bottom:0;"></div>
