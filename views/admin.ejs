<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#1a3a1a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="IT Log">
    <link rel="icon" type="image/x-icon"   href="/favicon.ico">
    <link rel="icon" type="image/svg+xml"  href="/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180x180.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT JURNAL LOG by RSBY</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; transition: background-color 0.25s, color 0.25s; }

        /* FORM SIDEBAR */
        .input-custom { background: var(--body-input) !important; border: 1px solid var(--body-input-border) !important; border-radius: 6px; color: var(--body-text) !important; padding: 10px; width: 100%; margin-bottom: 0.75rem; font-size: 0.85rem; transition: border-color 0.15s; }
        .input-custom:focus { outline: none; border-color: var(--body-input-focus) !important; }
        .label-text { color: var(--body-text2); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 4px; display: block; }

        /* TABLE */
        .table-container { background: var(--body-card) !important; border-radius: 10px; border: 1px solid var(--body-border); }
        .table { min-width: 1000px; margin: 0; }
        .table thead tr { background: var(--body-table-head) !important; }
        .table thead th { color: var(--body-table-head-text) !important; }
        .table tbody tr { background: var(--body-table-row) !important; border-bottom: 1px solid var(--body-table-border); }
        .table td { padding: 0.9rem 0.8rem; vertical-align: middle; color: var(--body-table-text) !important; font-size: 0.82rem; line-height: 1.4; }
        .txt-bold { color: var(--body-table-text) !important; font-weight: 700; }
        .status-solved { color: #008000 !important; font-weight: 800; font-size: 0.7rem; }
        .status-pending { color: #8b6508 !important; font-weight: 800; font-size: 0.7rem; }

        /* DURASI */
        .durasi-badge { display: inline-block; background: #e8f4fd; color: #0066aa; border: 1px solid #b3d7f0; border-radius: 4px; padding: 2px 7px; font-size: 0.68rem; font-weight: 700; margin-top: 3px; }
        .durasi-badge-multi { background: #f0e8fd; color: #6600aa; border-color: #d0b0f0; }
        .jam-info { font-size: 0.72rem; color: var(--body-text2); margin-top: 2px; }
        .durasi-preview { background: #0d2a0d; border: 1px solid #1a5c1a; border-radius: 6px; padding: 8px 12px; margin-bottom: 0.75rem; font-size: 0.82rem; color: #4caf50; font-weight: 700; text-align: center; display: none; }

        /* ACTIONS */
        .btn-action { border: none; padding: 3px 8px; font-size: 0.65rem; border-radius: 4px; font-weight: 700; cursor: pointer; width: 100%; margin-bottom: 4px; }
        .btn-foto { display: block; width: 100%; padding: 4px 7px; border-radius: 4px; font-size: 0.65rem; font-weight: 700; cursor: pointer; margin-bottom: 3px; white-space: nowrap; }
        .btn-foto-sesudah  { background: #111; color: #fff; border: none; }
        .btn-foto-awal     { background: #5a3e00; color: #ffc107; border: 1px solid #ffc107; }
        .btn-tambah-sesudah { background: transparent; color: #198754; border: 1px solid #198754; }
        .btn-tambah-awal    { background: transparent; color: #ffc107; border: 1px solid #ffc107; }

        /* TIPE TOGGLE */
        .tipe-toggle { display: flex; gap: 6px; margin-bottom: 0.75rem; }
        .tipe-btn { flex: 1; padding: 8px; border-radius: 6px; border: 1px solid var(--body-border); background: var(--body-input); color: var(--body-text2); font-size: 0.75rem; font-weight: 700; cursor: pointer; text-align: center; transition: all 0.2s; }
        .tipe-btn.active-harian  { background: #0d3d0d; border-color: #2d8c2d; color: #4caf50; }
        .tipe-btn.active-multi   { background: #1a0d3d; border-color: #6b3dbf; color: #9b6dff; }
        .multi-badge { display: inline-block; background: #1a0d3d; color: #9b6dff; border: 1px solid #6b3dbf; border-radius: 3px; padding: 1px 5px; font-size: 0.6rem; font-weight: 700; margin-left: 4px; vertical-align: middle; }
        .separator-line { border: none; border-top: 1px dashed var(--body-border); margin: 0.5rem 0 0.75rem; }

        /* NOTES */
        .notes-box { background: var(--body-card); border-radius: 8px; border: 1px solid var(--body-border); }
        .note-item { background: var(--body-bg); padding: 10px; border-radius: 4px; margin-bottom: 6px; border-left: 2px solid #0d6efd; display: flex; justify-content: space-between; align-items: start; }
        .note-item-title { color: var(--body-text); font-size: 0.9rem; font-weight: 700; }
        .note-item-content { color: var(--body-text2); margin: 2px 0 0 0; font-size: 0.8rem; }
        .note-item-date { color: var(--body-text3); font-size: 0.72rem; }

        /* SECTION PANELS */
        .section-panel { background: var(--body-card); border-radius: 8px; border: 1px solid var(--body-border); padding: 1rem; margin-bottom: 0.75rem; }
        .section-panel .form-control, .section-panel .form-select { background: var(--body-input) !important; color: var(--body-text) !important; border-color: var(--body-border) !important; }
        .section-panel .form-control:focus, .section-panel .form-select:focus { border-color: var(--body-input-focus) !important; box-shadow: none; }

        /* QUICK FILTER BUTTONS */
        .fq-btn { background: var(--body-bg3); border: 1px solid var(--body-border); color: var(--body-text2); border-radius: 6px; padding: 4px 10px; font-size: 0.72rem; font-weight: 700; cursor: pointer; transition: all 0.12s; white-space: nowrap; }
        .fq-btn:hover, .fq-btn.fq-active { background: #6366f1; border-color: #6366f1; color: #fff; }

        
        /* STATS CARDS */
        .stat-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 12px; }
        .stat-card { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 10px; padding: 14px 16px; position: relative; overflow: hidden; }
        .stat-card-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--body-text2); margin-bottom: 4px; }
        .stat-card-value { font-size: 1.7rem; font-weight: 800; line-height: 1; margin-bottom: 2px; }
        .stat-card-sub { font-size: 0.7rem; color: var(--body-text3); }
        .stat-card.green  { border-color: #1a5c1a; }
        .stat-card.green .stat-card-value { color: #4caf50; }
        .stat-card.yellow { border-color: #7a5c00; }
        .stat-card.yellow .stat-card-value { color: #ffc107; }
        .stat-card.blue   { border-color: #0d3d6e; }
        .stat-card.blue   .stat-card-value { color: #4da6ff; }
        .stat-card.red    { border-color: #5c1a1a; }
        .stat-card.red    .stat-card-value { color: #ff6b6b; }
        .stat-card-icon { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); opacity: 0.15; display:flex; align-items:center; justify-content:center; }
        .stat-card-icon .lc { width:28px; height:28px; }
        @media (max-width: 768px) { .stat-cards { grid-template-columns: repeat(2, 1fr); } }

        /* PENDING NOTIF */
        .pending-notif { background: var(--body-card); border: 1px solid #5c1a1a; border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; }
        .pending-notif-title { font-size: 0.78rem; font-weight: 700; color: #ff6b6b; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
        .pending-notif-title span { background: #ff6b6b; color: #fff; border-radius: 20px; padding: 1px 7px; font-size: 0.65rem; }
        .pending-row { display: flex; align-items: center; gap: 10px; padding: 8px 10px; background: var(--body-bg); border-radius: 6px; margin-bottom: 6px; border-left: 3px solid #ff6b6b; }
        .pending-row:last-child { margin-bottom: 0; }
        .pending-row-info { flex: 1; min-width: 0; }
        .pending-row-title { font-size: 0.8rem; font-weight: 600; color: var(--body-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .pending-row-meta  { font-size: 0.68rem; color: var(--body-text2); margin-top: 2px; }
        .pending-age { font-size: 0.65rem; font-weight: 700; padding: 2px 7px; border-radius: 20px; white-space: nowrap; flex-shrink: 0; }
        .pending-age.urgent  { background: #5c0000; color: #ff6b6b; }
        .pending-age.warning { background: #5c3d00; color: #ffc107; }
        .pending-age.normal  { background: var(--body-bg3); color: var(--body-text3); }
        .pending-actions { display: flex; gap: 5px; flex-shrink: 0; margin-left: 4px; }
        .btn-pending-solve { padding: 4px 10px; border-radius: 6px; border: none; background: #1a4731; color: #4caf50; font-size: 0.68rem; font-weight: 700; cursor: pointer; white-space: nowrap; transition: all 0.15s; }
        .btn-pending-solve:hover { background: #198754; color: #fff; }
        .btn-pending-edit  { padding: 4px 10px; border-radius: 6px; border: none; background: #0d2d6e; color: #4da6ff; font-size: 0.68rem; font-weight: 700; cursor: pointer; white-space: nowrap; transition: all 0.15s; }
        .btn-pending-edit:hover  { background: #0d6efd; color: #fff; }
        @media (max-width: 576px) { .pending-actions { flex-direction: column; gap: 3px; } }
        @media (max-width: 768px) { .container-fluid { padding: 1rem !important; } }

        /* ===== DRAWER FORM ===== */
        .drawer-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.55);
            z-index: 1040; opacity: 0; pointer-events: none;
            transition: opacity 0.25s ease;
        }
        .drawer-overlay.open { opacity: 1; pointer-events: all; }

        .drawer-panel {
            position: fixed; top: 0; right: 0; bottom: 0;
            width: 380px; max-width: 96vw;
            background: var(--body-card);
            border-left: 1px solid var(--body-border);
            z-index: 1041;
            transform: translateX(100%);
            transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
            display: flex; flex-direction: column;
            overflow: hidden;
        }
        .drawer-panel.open { transform: translateX(0); }

        .drawer-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 18px;
            border-bottom: 1px solid var(--body-border);
            flex-shrink: 0;
        }
        .drawer-title {
            font-size: 0.85rem; font-weight: 700; color: var(--body-text);
            display: flex; align-items: center; gap: 8px;
        }
        .drawer-close {
            background: none; border: none; color: var(--body-text2);
            cursor: pointer; padding: 4px; border-radius: 6px;
            display: flex; align-items: center;
            transition: background 0.15s, color 0.15s;
        }
        .drawer-close:hover { background: var(--body-bg3); color: var(--body-text); }

        .drawer-body {
            flex: 1; overflow-y: auto; padding: 16px 18px;
        }
        .drawer-body::-webkit-scrollbar { width: 4px; }
        .drawer-body::-webkit-scrollbar-thumb { background: var(--body-border); border-radius: 4px; }

        /* ===== FAB BUTTON ===== */
        .fab-tambah {
            position: fixed; bottom: 88px; right: 24px;
            z-index: 1039;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: #fff; border: none;
            border-radius: 50px;
            padding: 13px 22px;
            font-size: 0.85rem; font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(34,197,94,0.4);
            display: flex; align-items: center; gap: 8px;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .fab-tambah:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 26px rgba(34,197,94,0.5);
        }
        .fab-tambah.hidden { opacity: 0; pointer-events: none; transform: scale(0.85); }
        .fab-tambah svg { width: 18px; height: 18px; }
    </style>
</head>
<body>
<%- include('navbar', {activePage: 'dashboard'}) %>
<span id="btnInstallPwa" style="display:none;"></span>

<!-- ===== DRAWER OVERLAY ===== -->
<div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

<!-- ===== DRAWER PANEL ===== -->
<div class="drawer-panel" id="drawerPanel">
  <div class="drawer-header">
    <div class="drawer-title">
      <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Log Baru
    </div>
    <button class="drawer-close" onclick="closeDrawer()">
      <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="drawer-body">
    <form action="/save" method="POST" enctype="multipart/form-data" id="mainForm">
      <input type="hidden" name="tipeInput" id="tipeInputVal" value="harian">
      <span class="label-text">Tipe Pekerjaan</span>
      <div class="tipe-toggle">
        <div class="tipe-btn active-harian" id="btnHarian" onclick="setTipe('harian')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> HARIAN</div>
        <div class="tipe-btn" id="btnMulti" onclick="setTipe('multihari')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> MULTI-HARI</div>
      </div>
      <div id="formHarian">
        <span class="label-text">Tanggal</span>
        <input type="date" name="tanggalManual" id="tanggalInput" class="input-custom" required>
        <div class="row g-2">
          <div class="col-6"><span class="label-text">Jam Mulai</span><input type="time" name="jamMulai" id="jamMulaiInput" class="input-custom" style="margin-bottom:0;"></div>
          <div class="col-6"><span class="label-text">Jam Selesai</span><input type="time" name="jamSelesai" id="jamSelesaiInput" class="input-custom" style="margin-bottom:0;"></div>
        </div>
        <div style="margin-bottom:0.75rem;"></div>
        <div class="durasi-preview" id="durasiPreview"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Durasi: <strong id="durasiText">-</strong></div>
      </div>
      <div id="formMultihari" style="display:none;">
        <div style="background:#1a0d3d;border:1px solid #6b3dbf;border-radius:6px;padding:10px;margin-bottom:0.75rem;font-size:0.75rem;color:#c9aaff;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg> Untuk pekerjaan yang berlangsung lebih dari 1 hari</div>
        <span class="label-text" style="color:#9b6dff;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> Tanggal & Jam MULAI</span>
        <div class="row g-2">
          <div class="col-7"><input type="date" name="tanggalMulaiDate" id="tanggalMulaiDate" class="input-custom" style="margin-bottom:0;"></div>
          <div class="col-5"><input type="time" name="jamMulaiMulti" id="jamMulaiMulti" class="input-custom" style="margin-bottom:0;"></div>
        </div>
        <div style="margin-bottom:0.5rem;"></div>
        <span class="label-text" style="color:#9b6dff;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg> Tanggal & Jam SELESAI</span>
        <div class="row g-2">
          <div class="col-7"><input type="date" name="tanggalSelesaiDate" id="tanggalSelesaiDate" class="input-custom" style="margin-bottom:0;"></div>
          <div class="col-5"><input type="time" name="jamSelesaiMulti" id="jamSelesaiMulti" class="input-custom" style="margin-bottom:0;"></div>
        </div>
        <div style="margin-bottom:0.5rem;"></div>
        <div class="durasi-preview" id="durasiPreviewMulti" style="background:#1a0d3d;border-color:#6b3dbf;color:#c9aaff;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Durasi: <strong id="durasiTextMulti">-</strong></div>
      </div>
      <hr class="separator-line">
      <span class="label-text">Pemesan (User)</span>
      <input type="text" name="pemesan" class="input-custom" required>
      <span class="label-text">Aktivitas</span>
      <input type="text" name="aktivitas" class="input-custom" required>
      <span class="label-text">Divisi</span>
      <select name="divisi" class="input-custom">
        <option value="IT & IC">IT &amp; IC</option>
        <option value="HRGA">HRGA</option>
        <option value="Accounting">Accounting</option>
        <option value="Exim & Pembelian">Exim &amp; Pembelian</option>
        <option value="Operasional">Operasional</option>
        <option value="Finance">Finance</option>
        <option value="Produksi">Produksi</option>
        <option value="Bahanbaku">Bahanbaku</option>
        <option value="MAINTENANCE">MAINTENANCE</option>
        <option value="Admin Sales">Admin Sales</option>
      </select>
      <span class="label-text">Deskripsi</span>
      <div style="position:relative;">
        <textarea name="deskripsi" id="add_deskripsi" class="input-custom" rows="3" required></textarea>
        <button type="button" id="btn_ai_desc" onclick="aiGenerateDesc()" title="Generate deskripsi pakai AI"
          style="position:absolute;bottom:8px;right:8px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;border-radius:8px;padding:4px 10px;font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;transition:opacity 0.15s;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2a6 6 0 0 1 6 6c0 2.4-1.4 4.5-3.5 5.5L16 21H8l1.5-7.5C7.4 12.5 6 10.4 6 8a6 6 0 0 1 6-6z"/><circle cx="9" cy="8" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="8" r="1" fill="currentColor" stroke="none"/></svg>
          AI
        </button>
      </div>
      <span class="label-text">Status</span>
      <select name="status" class="input-custom">
        <option value="Solved">SOLVED</option>
        <option value="Pending">PENDING</option>
      </select>
      <span class="label-text" style="color:#ffc107;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto AWAL (Sebelum)</span>
      <input type="file" name="fotoAwal" class="input-custom file-compress" accept="image/*" capture="environment">
      <small class="text-success fw-bold d-none compress-msg"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg> Foto dikompres!</small>
      <span class="label-text" style="color:#90ee90;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto SESUDAH (Solved)</span>
      <input type="file" name="foto" class="input-custom file-compress" accept="image/*" capture="environment">
      <small class="text-success fw-bold d-none compress-msg"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg> Foto dikompres!</small>
      <button type="submit" class="btn btn-light w-100 fw-bold mt-2">SIMPAN DATA</button>
    </form>
  </div>
</div>

<!-- ===== FAB BUTTON ===== -->
<button class="fab-tambah" id="fabTambah" onclick="openDrawer()">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" xmlns="http://www.w3.org/2000/svg"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  Tambah Log
</button>

<div class="container-fluid p-4">
  <div class="row">

    <!-- ===== TABEL FULL WIDTH ===== -->
    <div class="col-12">

      <% if (saved) { %>
      <div aria-live="polite" aria-atomic="true" class="position-fixed top-0 end-0 p-3" style="z-index:1055;">
        <div id="saveToast" class="toast align-items-center text-bg-success border-0" role="alert">
          <div class="d-flex">
            <div class="toast-body"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg> Data berhasil disimpan.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
          </div>
        </div>
      </div>
      <% } %>

      <!-- ===== STAT CARDS ===== -->
      <div class="stat-cards">
        <div class="stat-card green">
          <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div class="stat-card-label">Solved Hari Ini</div>
          <div class="stat-card-value"><%= stats.solvedHariIni %></div>
          <div class="stat-card-sub">dari <%= stats.totalHariIni %> tiket hari ini</div>
        </div>
        <div class="stat-card yellow">
          <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 22h14M5 2h14M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22M17 2v4.172a2 2 0 0 1-.586 1.414L12 12 7.586 7.586A2 2 0 0 1 7 6.172V2"/></svg></div>
          <div class="stat-card-label">Pending Hari Ini</div>
          <div class="stat-card-value"><%= stats.pendingHariIni %></div>
          <div class="stat-card-sub">belum diselesaikan</div>
        </div>
        <div class="stat-card blue">
          <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
          <div class="stat-card-label">Total Log</div>
          <div class="stat-card-value"><%= stats.totalAllTime %></div>
          <div class="stat-card-sub">semua waktu</div>
        </div>
        <div class="stat-card red">
          <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" fill="currentColor" stroke="none"/></svg></div>
          <div class="stat-card-label">Total Pending</div>
          <div class="stat-card-value"><%= stats.pendingAllTime %></div>
          <div class="stat-card-sub">semua waktu</div>
        </div>
      </div>

      <!-- ===== PENDING NOTIFIKASI ===== -->
      <% if (stats.pendingItems.length > 0) { %>
      <div class="pending-notif">
        <div class="pending-notif-title">
          <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" fill="currentColor" stroke="none"/></svg> TIKET PENDING PERLU PERHATIAN
          <span><%= stats.pendingAllTime %></span>
        </div>
        <% stats.pendingItems.forEach(function(p) { %>
        <div class="pending-row">
          <div class="pending-row-info">
            <div class="pending-row-title"><%= p.aktivitas %></div>
            <div class="pending-row-meta"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <%= p.pemesan %> &nbsp;·&nbsp; <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/></svg> <%= p.divisi %> &nbsp;·&nbsp; <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <%= new Date(p.tanggalManual).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'}) %></div>
          </div>
          <% if (p.hariPending >= 3) { %>
            <span class="pending-age urgent"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg> <%= p.hariPending %> hari</span>
          <% } else if (p.hariPending >= 1) { %>
            <span class="pending-age warning"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> <%= p.hariPending %> hari</span>
          <% } else { %>
            <span class="pending-age normal">Baru</span>
          <% } %>
          <div class="pending-actions">
            <form method="POST" action="/update-status/<%= p.id %>" style="margin:0;">
              <input type="hidden" name="newStatus" value="Solved">
              <button type="submit" class="btn-pending-solve" onclick="return confirm('Tandai tiket ini sebagai Solved?')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg> Selesai</button>
            </form>
            <button type="button" class="btn-pending-edit" onclick="openEditModal(
              <%= p.id %>,
              `<%- (p.aktivitas||'').replace(/`/g,'\\`') %>`,
              `<%= p.divisi %>`,
              `<%- (p.pemesan||'').replace(/`/g,'\\`') %>`,
              `<%- (p.deskripsi||'').replace(/`/g,'\\`').replace(/\n/g,'\\n') %>`,
              `<%= p.status %>`,
              `<%= p.tipeInput || 'harian' %>`,
              `<%= new Date(p.tanggalManual).toISOString().slice(0,10) %>`,
              `<%= p.jamMulai || '' %>`,
              `<%= p.jamSelesai || '' %>`,
              `<%= p.tanggalMulai ? new Date(p.tanggalMulai).toISOString().slice(0,10) : '' %>`,
              `<%= p.tanggalSelesai ? new Date(p.tanggalSelesai).toISOString().slice(0,10) : '' %>`
            )"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</button>
          </div>
        </div>
        <% }) %>
        <% if (stats.pendingAllTime > 10) { %>
        <div style="text-align:center;margin-top:8px;font-size:0.7rem;color:var(--body-text3);">+<%= stats.pendingAllTime - 10 %> tiket pending lainnya — gunakan filter Status: Pending</div>
        <% } %>
      </div>
      <% } %>

      <!-- FILTER -->
      <div class="section-panel mb-3">
        <form action="/kerja" method="GET" id="filterForm">
          <div style="display:flex;align-items:center;flex-wrap:wrap;gap:8px;">
            <!-- Label filter aktif -->
            <span style="font-size:0.72rem;font-weight:700;color:var(--body-text3);text-transform:uppercase;letter-spacing:0.06em;white-space:nowrap;">FILTER LOG:</span>

            <!-- Quick: Hari Ini -->
            <button type="button" onclick="setToday()" class="fq-btn <%= (!filterDateFrom && !filterDateTo && !filterStatus) ? 'fq-active' : '' %>">Hari Ini</button>

            <!-- Quick: Kemarin -->
            <button type="button" onclick="setYesterday()" class="fq-btn">Kemarin</button>

            <!-- Quick: 7 Hari -->
            <button type="button" onclick="setLast7()" class="fq-btn">7 Hari</button>

            <!-- Quick: Bulan Ini -->
            <button type="button" onclick="setThisMonth()" class="fq-btn">Bulan Ini</button>

            <div style="width:1px;height:20px;background:var(--body-border);margin:0 2px;flex-shrink:0;"></div>

            <!-- Date From -->
            <div style="display:flex;align-items:center;gap:5px;">
              <label style="font-size:0.7rem;font-weight:600;color:var(--body-text3);white-space:nowrap;">Dari</label>
              <input type="date" name="dateFrom" id="filterFrom" value="<%= filterDateFrom %>"
                class="form-control form-control-sm" style="width:140px;background:var(--body-input);color:var(--body-text);border-color:var(--body-input-border);">
            </div>

            <!-- Date To -->
            <div style="display:flex;align-items:center;gap:5px;">
              <label style="font-size:0.7rem;font-weight:600;color:var(--body-text3);white-space:nowrap;">s/d</label>
              <input type="date" name="dateTo" id="filterTo" value="<%= filterDateTo %>"
                class="form-control form-control-sm" style="width:140px;background:var(--body-input);color:var(--body-text);border-color:var(--body-input-border);">
            </div>

            <!-- Status -->
            <select name="status" id="filterStatus" class="form-select form-select-sm" style="width:auto;background:var(--body-input);color:var(--body-text);border-color:var(--body-input-border);">
              <option value="" <%= filterStatus==='' ? 'selected' : '' %>>Semua Status</option>
              <option value="Pending" <%= filterStatus==='Pending' ? 'selected' : '' %>>PENDING</option>
              <option value="Solved" <%= filterStatus==='Solved' ? 'selected' : '' %>>SOLVED</option>
            </select>

            <button type="submit" class="btn btn-sm btn-primary fw-bold">Cari</button>

            <% if (typeof userPerms !== 'undefined' && (userPerms.canExport || userPerms.canAudit)) { %>
            <a id="exportBtn" href="/export?dateFrom=<%= filterDateFrom %>&dateTo=<%= filterDateTo %>"
               class="btn btn-sm fw-bold" style="background:#166534;border:1px solid #15803d;color:#4ade80;white-space:nowrap;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:3px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export Excel
            </a>
            <% } %>

            <% if (isFiltered) { %>
            <a href="/kerja" class="btn btn-sm fw-bold" style="background:var(--body-bg3);border:1px solid var(--body-border);color:var(--body-text2);">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Reset
            </a>
            <% } %>
          </div>
        </form>
      </div>

      <!-- TABLE HEADER INFO -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:6px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:0.72rem;font-weight:700;color:var(--body-text3);text-transform:uppercase;letter-spacing:0.06em;">LOG JURNAL</span>
          <span style="background:var(--body-bg3);border:1px solid var(--body-border);border-radius:20px;padding:2px 10px;font-size:0.72rem;font-weight:700;color:var(--body-text2);">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:3px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <%= filterLabel %>
          </span>
          <span style="font-size:0.72rem;color:var(--body-text3);">(<%= journals.length %> data)</span>
        </div>
      </div>

      <!-- TABLE -->
      <div class="table-container table-responsive">
        <% if (journals.length === 0) { %>
        <div style="text-align:center;padding:3rem 1rem;color:var(--body-text3);">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.3;display:block;margin:0 auto 12px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <div style="font-size:0.85rem;font-weight:600;">Tidak ada data untuk <strong><%= filterLabel %></strong></div>
          <div style="font-size:0.75rem;margin-top:4px;">Coba pilih rentang tanggal lain atau <a href="/kerja" style="color:#6366f1;">reset filter</a></div>
        </div>
        <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>WAKTU &amp; DURASI</th>
              <th>UNIT</th>
              <th style="width:32%;">AKTIVITAS</th>
              <th>STATUS</th>
              <th class="text-center">FOTO</th>
              <th class="text-center">AKSI</th>
            </tr>
          </thead>
          <tbody>
            <% journals.forEach(item => { %>
            <% var isMulti = item.tipeInput === 'multihari'; %>
            <tr style="<%= isMulti ? 'background: var(--body-table-row-alt) !important;' : '' %>">
              <td style="min-width:145px;">
                <% if (isMulti && item.tanggalMulai && item.tanggalSelesai) { %>
                  <span class="multi-badge"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> MULTI-HARI</span>
                  <div style="font-size:0.78rem;color:#6600aa;font-weight:600;margin-top:3px;">
                    <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <%= new Date(item.tanggalMulai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                    <% if(item.jamMulai) { %><span style="color:#888;font-size:0.7rem;"> <%= item.jamMulai %></span><% } %>
                  </div>
                  <div style="font-size:0.7rem;color:#888;margin:1px 0;">  ↓</div>
                  <div style="font-size:0.78rem;color:#6600aa;font-weight:600;">
                    <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg> <%= new Date(item.tanggalSelesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                    <% if(item.jamSelesai) { %><span style="color:#888;font-size:0.7rem;"> <%= item.jamSelesai %></span><% } %>
                  </div>
                  <% if(item.durasiMenit) { %><span class="durasi-badge durasi-badge-multi"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <%= formatDurasi(item.durasiMenit) %></span><% } %>
                <% } else { %>
                  <div style="font-family:monospace;font-size:0.8rem;color:#006666;font-weight:600;">
                    <%= new Date(item.tanggalManual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                  </div>
                  <% if(item.jamMulai) { %><div class="jam-info"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 14 14"/></svg> Mulai: <strong><%= item.jamMulai %></strong></div><% } %>
                  <% if(item.jamSelesai) { %><div class="jam-info"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 12"/></svg> Selesai: <strong><%= item.jamSelesai %></strong></div><% } %>
                  <% if(item.durasiMenit) { %><span class="durasi-badge"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <%= formatDurasi(item.durasiMenit) %></span><% } %>
                <% } %>
              </td>
              <td style="white-space:nowrap;">
                <div class="txt-bold"><%= item.divisi %></div>
                <div style="font-size:0.75rem;color:var(--body-text2);">User: <%= item.pemesan %></div>
              </td>
              <td>
                <div class="txt-bold" style="margin-bottom:3px;"><%= item.aktivitas %></div>
                <div style="font-size:0.8rem;color:var(--body-text2);"><%= item.deskripsi %></div>
              </td>
              <td><span class="<%= item.status==='Solved' ? 'status-solved' : 'status-pending' %>"><%= item.status %></span></td>
              <td style="min-width:115px;">
                <% if(item.fotoAwalUrl) { %>
                  <button class="btn-foto btn-foto-awal" onclick="showFoto('<%= item.fotoAwalUrl %>','Kondisi AWAL')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> AWAL</button>
                <% } else { %>
                  <button class="btn-foto btn-tambah-awal" onclick="openUploadAwalModal(<%= item.id %>)">+ Foto Awal</button>
                <% } %>
                <% if(item.fotoUrl) { %>
                  <button class="btn-foto btn-foto-sesudah" onclick="showFoto('<%= item.fotoUrl %>','Kondisi SESUDAH')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> SESUDAH</button>
                <% } else { %>
                  <button class="btn-foto btn-tambah-sesudah" onclick="openUploadModal(<%= item.id %>)">+ Foto Sesudah</button>
                <% } %>
              </td>
              <td class="text-center" style="min-width:110px;">
                <% if(item.status==='Pending') { %>
                  <form action="/update-status/<%= item.id %>" method="POST">
                    <input type="hidden" name="newStatus" value="Solved">
                    <button type="submit" class="btn-action" style="background:#198754;color:#fff;">SET SOLVED</button>
                  </form>
                <% } %>
                <button type="button" class="btn-action" style="background:#0d6efd;color:#fff;margin-bottom:4px;" onclick="openEditModal(
                  <%= item.id %>,
                  `<%- item.aktivitas.replace(/`/g,'\\`') %>`,
                  `<%= item.divisi %>`,
                  `<%- item.pemesan.replace(/`/g,'\\`') %>`,
                  `<%- item.deskripsi.replace(/`/g,'\\`').replace(/\n/g,'\\n') %>`,
                  `<%= item.status %>`,
                  `<%= item.tipeInput || 'harian' %>`,
                  `<%= new Date(item.tanggalManual).toISOString().slice(0,10) %>`,
                  `<%= item.jamMulai || '' %>`,
                  `<%= item.jamSelesai || '' %>`,
                  `<%= item.tanggalMulai ? new Date(item.tanggalMulai).toISOString().slice(0,10) : '' %>`,
                  `<%= item.tanggalSelesai ? new Date(item.tanggalSelesai).toISOString().slice(0,10) : '' %>`
                )">EDIT</button>
                <button type="button" class="btn-action" style="background:#dc3545;color:#fff;" onclick="confirmDelete(<%= item.id %>,`<%- item.aktivitas.replace(/`/g,'\\`') %>`)">HAPUS</button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- MODAL FOTO -->
<div class="modal fade" id="fotoModalAdmin" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);">
      <div class="modal-header" style="border-color:var(--body-border);">
        <h5 class="modal-title" style="color:var(--body-text);" id="fotoModalTitle">Dokumentasi</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0" style="position:relative;background:#000;min-height:200px;">
        <img id="popupImageAdmin" src="" class="img-fluid d-block mx-auto" style="max-height:75vh;object-fit:contain;">
        <button id="adminFotoPrev" onclick="adminSliderNav(-1)"
          style="position:absolute;left:10px;top:50%;transform:translateY(-50%);
                 background:rgba(0,0,0,0.55);border:none;color:#fff;font-size:1.8rem;
                 width:42px;height:42px;border-radius:50%;cursor:pointer;z-index:10;
                 align-items:center;justify-content:center;display:none;">&#8249;</button>
        <button id="adminFotoNext" onclick="adminSliderNav(1)"
          style="position:absolute;right:10px;top:50%;transform:translateY(-50%);
                 background:rgba(0,0,0,0.55);border:none;color:#fff;font-size:1.8rem;
                 width:42px;height:42px;border-radius:50%;cursor:pointer;z-index:10;
                 align-items:center;justify-content:center;display:none;">&#8250;</button>
      </div>
      <div id="adminFotoDots" style="display:flex;justify-content:center;align-items:center;gap:8px;background:var(--body-card);flex-wrap:wrap;"></div>
    </div>
  </div>
</div>

<!-- MODAL UPLOAD SESUDAH -->
<div class="modal fade" id="uploadSusulanModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);">
