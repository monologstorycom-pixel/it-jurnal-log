// ========== NOTES (with EDIT) ==========
async function loadAdminNotes() {
    try {
        var res = await fetch('/api/notes'), notes = await res.json(), el = document.getElementById('adminNotesList');
        if (notes.length === 0) { el.innerHTML = '<p style="color:var(--body-text3);">Belum ada catatan.</p>'; return; }
        el.innerHTML = notes.map(function(n) {
            var d = new Date(n.createdAt).toLocaleString('id-ID', {dateStyle:'short',timeStyle:'short'});
            return '<div class="note-item">' +
                '<div style="flex:1;">' +
                    '<div class="note-item-title">' + escHtml(n.title) + '</div>' +
                    '<p class="note-item-content">' + escHtml(n.content) + '</p>' +
                    '<small class="note-item-date">' + d + '</small>' +
                '</div>' +
                '<div style="display:flex;flex-direction:column;gap:4px;margin-left:8px;">' +
                    '<button onclick="openEditNote(' + n.id + ',`' + escJs(n.title) + '`,`' + escJs(n.content) + '`)" class="btn btn-sm btn-outline-primary fw-bold" style="padding:2px 7px;font-size:0.7rem;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>' +
                    '<button onclick="deleteAdminNote(' + n.id + ')" class="btn btn-sm btn-danger fw-bold" style="padding:2px 7px;font-size:0.7rem;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>' +
                '</div>' +
            '</div>';
        }).join('');
    } catch(e) { document.getElementById('adminNotesList').innerHTML = '<p style="color:#f00;">Error load notes</p>'; }
}

function escHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escJs(s)   { return (s||'').replace(/\\/g,'\\\\').replace(/`/g,'\\`').replace(/\$/g,'\\$'); }

async function addNoteAdmin() {
    var title=document.getElementById('noteTitle').value.trim(), content=document.getElementById('noteContent').value.trim();
    if(!title||!content){alert('Judul dan isi harus diisi!');return;}
    await fetch('/api/notes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({title,content})});
    document.getElementById('noteTitle').value=''; document.getElementById('noteContent').value='';
    loadAdminNotes();
}

function openEditNote(id, title, content) {
    document.getElementById('editNoteId').value = id;
    document.getElementById('editNoteTitle').value = title;
    document.getElementById('editNoteContent').value = content;
    new bootstrap.Modal(document.getElementById('editNoteModal')).show();
}

async function saveEditNote() {
    var id      = document.getElementById('editNoteId').value;
    var title   = document.getElementById('editNoteTitle').value.trim();
    var content = document.getElementById('editNoteContent').value.trim();
    if(!title||!content){alert('Judul dan isi harus diisi!');return;}
    var res = await fetch('/api/notes/'+id, {method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({title,content})});
    if(res.ok){
        bootstrap.Modal.getInstance(document.getElementById('editNoteModal')).hide();
        loadAdminNotes();
    } else { alert('Gagal menyimpan catatan.'); }
}

async function deleteAdminNote(id) {
    if(!confirm('Yakin hapus catatan ini?'))return;
    await fetch('/api/notes/'+id,{method:'DELETE'});
    loadAdminNotes();
}

window.addEventListener('load', function() { loadAdminNotes(); });

// ===== QUICK DATE FILTER =====
function fmtDate(d) { return d.toISOString().split('T')[0]; }
function applyFilter(from, to) {
    document.getElementById('filterFrom').value = from || '';
    document.getElementById('filterTo').value   = to   || '';
    document.getElementById('filterForm').submit();
}
function setToday() {
    var t = fmtDate(new Date()); applyFilter(t, t);
}
function setYesterday() {
    var d = new Date(); d.setDate(d.getDate() - 1); var t = fmtDate(d); applyFilter(t, t);
}
function setLast7() {
    var to = new Date(), from = new Date(); from.setDate(from.getDate() - 6);
    applyFilter(fmtDate(from), fmtDate(to));
}
function setThisMonth() {
    var now = new Date();
    var from = new Date(now.getFullYear(), now.getMonth(), 1);
    var to   = new Date(now.getFullYear(), now.getMonth() + 1, 0);
    applyFilter(fmtDate(from), fmtDate(to));
}
// Sync export button URL saat filter input berubah
(function() {
    var fromEl = document.getElementById('filterFrom');
    var toEl   = document.getElementById('filterTo');
    var expBtn = document.getElementById('exportBtn');
    function syncExport() {
        if (!expBtn) return;
        expBtn.href = '/export?dateFrom=' + (fromEl ? fromEl.value : '') + '&dateTo=' + (toEl ? toEl.value : '');
    }
    if (fromEl) fromEl.addEventListener('change', syncExport);
    if (toEl)   toEl.addEventListener('change', syncExport);
})();
</script>

<script>
// ===== AI GENERATE DESKRIPSI =====
async function aiGenerateDesc() {
  var aktivitas = document.querySelector('input[name="aktivitas"]').value.trim();
  var divisi    = document.querySelector('select[name="divisi"]').value;
  var pemesan   = document.querySelector('input[name="pemesan"]').value.trim();
  var btn       = document.getElementById('btn_ai_desc');
  var textarea  = document.getElementById('add_deskripsi');

  if (!aktivitas) { alert('Isi dulu kolom Aktivitas!'); return; }

  btn.disabled = true;
  btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> ...';

  try {
    var res  = await fetch('/api/ai-describe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ aktivitas, divisi, pemesan })
    });
    var data = await res.json();
    if (data.deskripsi) {
      textarea.value = data.deskripsi;
      textarea.style.borderColor = '#6366f1';
      setTimeout(function(){ textarea.style.borderColor = ''; }, 2000);
    } else {
      alert(data.error || 'Gagal generate deskripsi.');
    }
  } catch(e) {
    alert('Gagal koneksi ke AI.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2a6 6 0 0 1 6 6c0 2.4-1.4 4.5-3.5 5.5L16 21H8l1.5-7.5C7.4 12.5 6 10.4 6 8a6 6 0 0 1 6-6z"/><circle cx="9" cy="8" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="8" r="1" fill="currentColor" stroke="none"/></svg> AI';
  }
}

async function aiGenerateDescEdit() {
  var aktivitas = document.getElementById('edit_aktivitas').value.trim();
  var divisi    = document.getElementById('edit_divisi').value;
  var pemesan   = document.getElementById('edit_pemesan').value.trim();
  var textarea  = document.getElementById('edit_deskripsi');

  if (!aktivitas) { alert('Isi dulu kolom Aktivitas!'); return; }
  textarea.value = '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 22h14M5 2h14M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22M17 2v4.172a2 2 0 0 1-.586 1.414L12 12 7.586 7.586A2 2 0 0 1 7 6.172V2"/></svg> Generating...';

  try {
    var res  = await fetch('/api/ai-describe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ aktivitas, divisi, pemesan })
    });
    var data = await res.json();
    textarea.value = data.deskripsi || data.error || 'Gagal generate.';
    if (data.deskripsi) {
      textarea.style.borderColor = '#6366f1';
      setTimeout(function(){ textarea.style.borderColor = ''; }, 2000);
    }
  } catch(e) {
    textarea.value = 'Gagal koneksi ke AI.';
  }
}
// ===== DRAWER =====
function openDrawer() {
    document.getElementById('drawerPanel').classList.add('open');
    document.getElementById('drawerOverlay').classList.add('open');
    document.getElementById('fabTambah').classList.add('hidden');
    document.body.style.overflow = 'hidden';
}
function closeDrawer() {
    document.getElementById('drawerPanel').classList.remove('open');
    document.getElementById('drawerOverlay').classList.remove('open');
    document.getElementById('fabTambah').classList.remove('hidden');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeDrawer();
    if (e.key === 'n' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA' && document.activeElement.tagName !== 'SELECT') {
        e.preventDefault(); openDrawer();
    }
});
</script>

