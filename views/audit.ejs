<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Audit — IT Support Log</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0f1117">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; transition: background-color 0.25s, color 0.25s; }

        /* AUDIT BANNER */
        .audit-banner { background: linear-gradient(135deg, #2d1a00 0%, #1a1000 100%); border-bottom: 2px solid #92400e; padding: 10px 24px; display: flex; align-items: center; gap: 12px; }
        .audit-banner-icon { font-size: 1.1rem; }
        .audit-banner-text { font-size: 0.75rem; font-weight: 700; color: #f59e0b; letter-spacing: 0.08em; text-transform: uppercase; }
        .audit-banner-sub  { font-size: 0.65rem; color: #d97706; margin-top: 1px; }
        .audit-badge { background: #92400e; color: #fef3c7; border-radius: 4px; padding: 2px 8px; font-size: 0.62rem; font-weight: 800; letter-spacing: 0.06em; margin-left: auto; }

        /* PAGE LAYOUT */
        .page-wrap { max-width: 1400px; margin: 0 auto; padding: 1.25rem 1.5rem; }
        @media (max-width: 640px) {
            .page-wrap { padding: 0.75rem 0.75rem; }
            .section-panel { padding: 0.75rem; }
        }

        /* SECTION PANELS */
        .section-panel { background: var(--body-card); border-radius: 10px; border: 1px solid var(--body-border); padding: 1rem 1.25rem; margin-bottom: 1rem; }
        .section-title  { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #f59e0b; margin-bottom: 1rem; display: flex; align-items: center; gap: 7px; }
        .section-title::before { content: ''; display: inline-block; width: 3px; height: 14px; background: #f59e0b; border-radius: 2px; }

        /* STATS CARDS */
        .stat-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-bottom: 1rem; }
        .stat-card { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 10px; padding: 14px 16px; position: relative; overflow: hidden; }
        .stat-card-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--body-text2); margin-bottom: 4px; }
        .stat-card-value { font-size: 1.6rem; font-weight: 800; line-height: 1; margin-bottom: 2px; }
        .stat-card-sub { font-size: 0.67rem; color: var(--body-text3); }
        .stat-card-icon { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); opacity: 0.12; display:flex; align-items:center; justify-content:center; }
        .stat-card-icon .lc { width:26px; height:26px; }
        .sc-amber  { border-color: #92400e; } .sc-amber .stat-card-value  { color: #f59e0b; }
        .sc-green  { border-color: #1a5c1a; } .sc-green .stat-card-value  { color: #4caf50; }
        .sc-red    { border-color: #5c1a1a; } .sc-red .stat-card-value    { color: #ff6b6b; }
        .sc-blue   { border-color: #0d3d6e; } .sc-blue .stat-card-value   { color: #4da6ff; }
        .sc-purple { border-color: #3d1a6e; } .sc-purple .stat-card-value { color: #c084fc; }
        @media (max-width: 900px)  { .stat-grid { grid-template-columns: repeat(3,1fr); } }
        @media (max-width: 600px)  { .stat-grid { grid-template-columns: repeat(2,1fr); } }

        /* FILTER BAR */
        .filter-bar { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
        .filter-bar .form-select, .filter-bar .form-control { background: var(--body-input) !important; border: 1px solid var(--body-input-border) !important; color: var(--body-text) !important; font-size: 0.8rem; height: 34px; border-radius: 6px; }
        .filter-bar .form-select:focus, .filter-bar .form-control:focus { border-color: #f59e0b !important; box-shadow: none; outline: none; }
        .btn-filter { background: #1a1000; border: 1px solid #92400e; color: #f59e0b; padding: 5px 14px; border-radius: 6px; font-size: 0.78rem; font-weight: 700; cursor: pointer; transition: all 0.15s; }
        .btn-filter:hover { background: #2d1a00; }
        .btn-reset  { background: var(--body-bg); border: 1px solid var(--body-border); color: var(--body-text2); padding: 5px 12px; border-radius: 6px; font-size: 0.78rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.15s; }
        .btn-reset:hover { border-color: var(--body-border2); color: var(--body-text); }

        /* TABLE */
        .table-wrap  { background: var(--body-card); border-radius: 10px; border: 1px solid var(--body-border); overflow-x: auto; overflow-y: hidden; -webkit-overflow-scrolling: touch; }
        .table-audit { width: 100%; border-collapse: collapse; min-width: 680px; table-layout: auto; }
        .table-audit thead tr { background: var(--body-table-head) !important; }
        .table-audit th { padding: 9px 12px; font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.07em; color: var(--body-text3); border-bottom: 1px solid var(--body-border); white-space: nowrap; }
        .table-audit td { padding: 11px 12px; font-size: 0.82rem; color: var(--body-text); border-bottom: 1px solid var(--body-border); vertical-align: middle; }
        .table-audit tr:last-child td { border-bottom: none; }
        .table-audit tr:hover td { background: var(--body-bg3) !important; }

        /* ROW INDEX */
        .row-idx { font-size: 0.62rem; font-weight: 700; color: var(--body-text3); font-family: monospace; }

        /* STATUS BADGES */
        .badge-solved  { display:inline-block;padding:2px 8px;border-radius:12px;font-size:0.62rem;font-weight:800;background:#0d3d1a;color:#4caf50;border:1px solid #1a5c1a;letter-spacing:0.04em; }
        .badge-pending { display:inline-block;padding:2px 8px;border-radius:12px;font-size:0.62rem;font-weight:800;background:#3d2a00;color:#ffc107;border:1px solid #7a5c00;letter-spacing:0.04em; }

        /* DIVISI TAG */
        .div-tag { display:inline-block;padding:2px 7px;border-radius:4px;font-size:0.62rem;font-weight:700;background:#1a2d3d;color:#7eb8f7;border:1px solid #1a3d5c; }

        /* DURASI BADGE */
        .dur-badge       { display:inline-block;background:#0d2d3d;color:#4da6ff;border:1px solid #0d4d6e;border-radius:4px;padding:2px 6px;font-size:0.62rem;font-weight:700;margin-top:2px; }
        .dur-badge-multi { background:#1a0d3d;color:#c084fc;border-color:#3d1a6e; }

        /* READONLY NOTICE */
        .readonly-chip { display:inline-flex;align-items:center;gap:5px;background:#1a1000;border:1px solid #92400e;border-radius:20px;padding:3px 10px;font-size:0.65rem;font-weight:700;color:#d97706; }

        /* FOTO BUTTON */
        .btn-foto-view { display:inline-block;padding:3px 8px;border-radius:4px;font-size:0.62rem;font-weight:700;cursor:pointer;border:1px solid var(--body-border);background:var(--body-bg);color:var(--body-text2);transition:all 0.12s;margin-bottom:3px;width:100%;text-align:center; }
        .btn-foto-view:hover { border-color:#f59e0b;color:#f59e0b; }
        .foto-none { font-size:0.65rem;color:var(--body-text3); }

        /* DIVISI BREAKDOWN TABLE */
        .breakdown-table { width:100%;border-collapse:collapse; }
        .breakdown-table th { font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--body-text3);padding:6px 10px;border-bottom:1px solid var(--body-border);text-align:left; }
        .breakdown-table td { font-size:0.8rem;padding:8px 10px;border-bottom:1px solid var(--body-border);color:var(--body-text); }
        .breakdown-table tr:last-child td { border-bottom:none; }
        .breakdown-table tr:hover td { background:var(--body-bg3); }
        .bar-wrap { height:6px;background:var(--body-border);border-radius:3px;overflow:hidden;margin-top:4px; }
        .bar-fill { height:100%;border-radius:3px;background:#f59e0b;transition:width 0.4s; }

        /* EMPTY STATE */
        .empty-state { text-align:center;padding:3rem 1rem;color:var(--body-text3); }
        .empty-state-icon { margin-bottom:10px; opacity:0.5; display:flex; align-items:center; justify-content:center; }
        .empty-state-icon .lc { width:2.5rem; height:2.5rem; }
        .empty-state-text { font-size:0.85rem; }

        /* EXPORT BTN */
        .btn-export { background:#1a0d3d;border:1px solid #4c3780;color:#c084fc;padding:5px 14px;border-radius:6px;font-size:0.78rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all 0.15s; display:inline-block; }
        .btn-export:hover { background:#250f50;color:#d8b4fe; }

        /* MULTI BADGE */
        .multi-badge { display:inline-block;background:#1a0d3d;color:#9b6dff;border:1px solid #6b3dbf;border-radius:3px;padding:1px 5px;font-size:0.58rem;font-weight:700; }
    </style>
</head>
<body>
<%- include('navbar', {activePage: 'audit'}) %>


<div class="page-wrap">

    <!-- STAT CARDS -->
    <div class="stat-grid">
        <div class="stat-card sc-amber">
            <div class="stat-card-label">Total Log</div>
            <div class="stat-card-value"><%= stats.totalAllTime %></div>
            <div class="stat-card-sub">Semua waktu</div>
            <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
        </div>
        <div class="stat-card sc-green">
            <div class="stat-card-label">Solved</div>
            <div class="stat-card-value"><%= stats.totalSolved %></div>
            <div class="stat-card-sub"><%= stats.totalAllTime > 0 ? Math.round(stats.totalSolved / stats.totalAllTime * 100) : 0 %>% dari total</div>
            <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg></div>
        </div>
        <div class="stat-card sc-red">
            <div class="stat-card-label">Pending</div>
            <div class="stat-card-value"><%= stats.totalPending %></div>
            <div class="stat-card-sub">Belum diselesaikan</div>
            <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 22h14M5 2h14M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22M17 2v4.172a2 2 0 0 1-.586 1.414L12 12 7.586 7.586A2 2 0 0 1 7 6.172V2"/></svg></div>
        </div>
        <div class="stat-card sc-blue">
            <div class="stat-card-label">Divisi Aktif</div>
            <div class="stat-card-value"><%= stats.divisiCount %></div>
            <div class="stat-card-sub">Dari log tercatat</div>
            <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/></svg></div>
        </div>
        <div class="stat-card sc-purple">
            <div class="stat-card-label">Log Bulan Ini</div>
            <div class="stat-card-value"><%= stats.bulanIni %></div>
            <div class="stat-card-sub"><%= new Date().toLocaleDateString('id-ID',{month:'long',year:'numeric'}) %></div>
            <div class="stat-card-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        </div>
    </div>

    <!-- FILTER ANALITIK KHUSUS CHART -->
    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
        <div class="section-title mb-0" style="font-size:0.8rem;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Analisis Audit (Berdasarkan Periode)</div>
        <form action="/audit" method="GET" class="d-flex align-items-center gap-2">
            <!-- Tetap simpan filter harian biar gak hilang pas ganti chart -->
            <input type="hidden" name="date" value="<%= filterDate || '' %>">
            <input type="hidden" name="status" value="<%= filterStatus || '' %>">
            <input type="hidden" name="divisi" value="<%= filterDivisi || '' %>">
            <input type="hidden" name="asetDivisi" value="<%= filterAsetDivisi || '' %>">
            
            <span style="font-size:0.75rem; color:var(--body-text2); font-weight:bold;">Periode Chart:</span>
            <select name="chartPeriod" class="form-select form-select-sm" style="width:auto; background:var(--body-bg)!important; color:var(--body-text)!important; border-color:var(--body-border)!important;" onchange="this.form.submit()">
                <option value="7" <%= chartPeriod === '7' ? 'selected' : '' %>>7 Hari Terakhir</option>
                <option value="30" <%= chartPeriod === '30' ? 'selected' : '' %>>1 Bulan Terakhir</option>
                <option value="90" <%= chartPeriod === '90' ? 'selected' : '' %>>3 Bulan Terakhir</option>
                <option value="all" <%= chartPeriod === 'all' ? 'selected' : '' %>>Semua Waktu</option>
            </select>
        </form>
    </div>

    <!-- CHARTS SECTION -->
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="section-panel" style="height: 100%;">
                <div class="section-title"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Top Divisi Lapor</div>
                <div style="font-size:0.75rem; color:#f59e0b; margin-bottom: 10px; background: #2d1a00; border: 1px solid #92400e; padding: 8px; border-radius: 6px; font-weight: bold;">
                    <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Rata-rata waktu perbaikan: <%= stats.rataRataFormat || '0 menit' %>
                </div>
                <div style="position: relative; height: 250px;">
                    <canvas id="divisiChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="section-panel" style="height: 100%;">
                <div class="section-title">pie chart Masalah</div>
                <div style="position: relative; height: 280px; display: flex; justify-content: center;">
                    <canvas id="masalahChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="section-panel" style="height: 100%;">
                <div class="section-title"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg> Top User / Pemesan</div>
                <div style="font-size:0.75rem; color:var(--body-text2); margin-bottom:10px;">User yang paling sering ditangani</div>
                <div style="position: relative; height: 250px;">
                    <canvas id="userChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- KIRI: TABEL UTAMA -->
        <div class="col-lg-8">
            <!-- LOG JURNAL TABLE -->
            <div class="section-panel mb-3">
                <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                    <div class="section-title mb-0"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> Audit Log Jurnal Harian</div>
                    
                    <div class="d-flex align-items-center gap-2">
                        <span class="readonly-chip d-none d-sm-inline-flex"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Read Only</span>
                        
                        <!-- FORM EXPORT KHUSUS RAW LOG BULANAN -->
                        <% if (typeof currentUser !== 'undefined' && currentUser && userPerms && userPerms.canExport) { %>
                        <form action="/export" method="GET" class="d-flex gap-1 align-items-center" target="_blank">
                            <select name="month" class="form-select form-select-sm" style="width:auto; font-size:0.7rem; background:var(--body-bg)!important; color:var(--body-text)!important; border-color:var(--body-border)!important;" required>
                                <option value="">-Bulan-</option>
                                <% ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'].forEach(function(m,i){ %>
                                <option value="<%= i+1 %>"><%= m %></option>
                                <% }); %>
                            </select>
                            <select name="year" class="form-select form-select-sm" style="width:auto; font-size:0.7rem; background:var(--body-bg)!important; color:var(--body-text)!important; border-color:var(--body-border)!important;" required>
                                <% yearOptions.forEach(function(y){ %>
                                <option value="<%= y %>"><%= y %></option>
                                <% }); %>
                            </select>
                            <button type="submit" class="btn-export" style="padding:4px 10px; font-size:0.7rem;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Export Excel</button>
                        </form>
                        <% } %>
                    </div>
                </div>

                <!-- FILTER TABEL HARIAN -->
                <form action="/audit" method="GET" class="filter-bar mb-3">
                    <input type="hidden" name="chartPeriod" value="<%= chartPeriod %>">
                    <input type="hidden" name="asetDivisi" value="<%= filterAsetDivisi %>">

                    <input type="date" name="date" class="form-control" style="width:auto;" value="<%= filterDate %>" title="Pilih Tanggal">
                    <select name="status" class="form-select" style="width:auto;">
                        <option value="">Semua Status</option>
                        <option value="Solved"  <%= filterStatus === 'Solved'  ? 'selected' : '' %>>SOLVED</option>
                        <option value="Pending" <%= filterStatus === 'Pending' ? 'selected' : '' %>>PENDING</option>
                    </select>
                    <select name="divisi" class="form-select" style="width:auto;">
                        <option value="">Semua Divisi</option>
                        <% stats.divisiList.forEach(function(d){ %>
                        <option value="<%= d %>" <%= filterDivisi === d ? 'selected' : '' %>><%= d %></option>
                        <% }); %>
                    </select>
                    
                    <button type="submit" class="btn-filter">Filter Harian</button>
                    <a href="/audit" class="btn-reset">Reset Semua</a>
                    <span style="font-size:0.7rem;color:var(--body-text3);margin-left:4px;"><%= journals.length %> log hari ini</span>
                </form>

                <div class="table-responsive table-wrap">
                    <table class="table-audit">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tanggal</th>
                                <th>Divisi</th>
                                <th style="width:35%;">Aktivitas</th>
                                <th>Status</th>
                                <th>Durasi</th>
                                <th>Foto</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (journals.length === 0) { %>
                            <tr>
                                <td colspan="7">
                                    <div class="empty-state">
                                        <div class="empty-state-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
                                        <div class="empty-state-text">Tidak ada data log untuk tanggal ini</div>
                                    </div>
                                </td>
                            </tr>
                            <% } %>
                            <% journals.forEach(function(item, idx) { %>
                            <% var isMulti = item.tipeInput === 'multihari'; %>
                            <tr>
                                <td><span class="row-idx"><%= idx + 1 %></span></td>
                                <td style="min-width:130px;">
                                    <% if (isMulti && item.tanggalMulai && item.tanggalSelesai) { %>
                                        <span class="multi-badge"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> MULTI</span>
                                        <div style="font-size:0.72rem;color:#9b6dff;font-weight:600;margin-top:2px;">
                                            <%= new Date(item.tanggalMulai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                                        </div>
                                        <div style="font-size:0.65rem;color:var(--body-text3);">→ <%= new Date(item.tanggalSelesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></div>
                                    <% } else { %>
                                        <div style="font-family:monospace;font-size:0.78rem;color:#4da6ff;font-weight:600;">
                                            <%= new Date(item.tanggalManual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                                        </div>
                                        <% if(item.jamMulai) { %><div style="font-size:0.67rem;color:var(--body-text3);"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 14 14"/></svg> <%= item.jamMulai %><% if(item.jamSelesai) { %> – <%= item.jamSelesai %><% } %></div><% } %>
                                    <% } %>
                                </td>
                                <td style="white-space:nowrap;">
                                    <span class="div-tag"><%= item.divisi %></span>
                                    <div style="font-size:0.67rem;color:var(--body-text3);margin-top:3px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <%= item.pemesan %></div>
                                </td>
                                <td>
                                    <div style="font-weight:700;font-size:0.83rem;margin-bottom:3px;"><%= item.aktivitas %></div>
                                    <div style="font-size:0.77rem;color:var(--body-text2);line-height:1.4;"><%= item.deskripsi %></div>
                                </td>
                                <td>
                                    <span class="<%= item.status === 'Solved' ? 'badge-solved' : 'badge-pending' %>"><%= item.status %></span>
                                </td>
                                <td style="white-space:nowrap;">
                                    <% if(item.durasiMenit) { %>
                                        <span class="<%= isMulti ? 'dur-badge dur-badge-multi' : 'dur-badge' %>"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <%= formatDurasi(item.durasiMenit) %></span>
                                    <% } else { %>
                                        <span style="font-size:0.65rem;color:var(--body-text3);">—</span>
                                    <% } %>
                                </td>
                                <td style="min-width:100px;">
                                    <% if(item.fotoAwalUrl) { %>
                                        <button class="btn-foto-view" onclick="showFoto('<%= item.fotoAwalUrl %>','AWAL','<%= (item.aktivitas||'').replace(/'/g,"\\'") %>')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Awal</button>
                                    <% } %>
                                    <% if(item.fotoUrl) { %>
                                        <button class="btn-foto-view" onclick="showFoto('<%= item.fotoUrl %>','SESUDAH','<%= (item.aktivitas||'').replace(/'/g,"\\'") %>')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Sesudah</button>
                                    <% } %>
                                    <% if(!item.fotoAwalUrl && !item.fotoUrl) { %>
                                        <span class="foto-none">—</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- TABEL SELURUH ASET -->
            <div class="section-panel mb-3">
                <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                    <div class="section-title mb-0"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg> Data Seluruh Aset</div>
                    
                    <form action="/audit" method="GET" class="d-flex gap-2">
                        <input type="hidden" name="date" value="<%= filterDate || '' %>">
                        <input type="hidden" name="status" value="<%= filterStatus || '' %>">
                        <input type="hidden" name="divisi" value="<%= filterDivisi || '' %>">
                        <input type="hidden" name="chartPeriod" value="<%= chartPeriod || '30' %>">
                        
                        <select name="asetDivisi" class="form-select form-select-sm" style="background:var(--body-input)!important; color:var(--body-text)!important; border-color:var(--body-border)!important;" onchange="this.form.submit()">
                            <option value="">-- Pilih Divisi Aset --</option>
                            <% stats.divisiList.forEach(function(d){ %>
                            <option value="<%= d %>" <%= filterAsetDivisi === d ? 'selected' : '' %>><%= d %></option>
                            <% }); %>
                        </select>
                    </form>
                </div>

                <div class="table-responsive table-wrap">
                    <table class="table-audit">
                        <thead>
                            <tr>
                                <th>NO</th>
                                <th>NAMA ASET</th>
                                <th>DIVISI</th>
                                <th>KATEGORI</th>
                                <th>STOK</th>
                                <th>KONDISI</th>
                                <th style="width:110px;min-width:110px;">FOTO</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (auditAsets.length === 0) { %>
                            <tr>
                                <td colspan="7">
                                    <div class="empty-state">
                                        <div class="empty-state-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></div>
                                        <% if (!filterAsetDivisi) { %>
                                            <div class="empty-state-text">Silakan pilih Divisi pada filter di atas untuk melihat daftar aset.</div>
                                        <% } else { %>
                                            <div class="empty-state-text">Tidak ada data aset untuk divisi ini.</div>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% } %>
                            <% auditAsets.forEach(function(a, i) { %>
                            <tr>
                                <td><span class="row-idx"><%= i + 1 %></span></td>
                                <td>
                                    <div style="font-weight:700;font-size:0.83rem;"><%= a.nama %></div>
                                    <% if(a.keterangan) { %><div style="font-size:0.75rem;color:var(--body-text2);"><%= a.keterangan %></div><% } %>
                                </td>
                                <td><span class="div-tag"><%= a.divisi %></span></td>
                                <td><span style="font-size:0.75rem;color:var(--body-text2);"><%= a.kategori %></span></td>
                                <td>
                                    <div style="font-weight:700;font-size:0.85rem;"><%= a.stok %> / <%= a.stokAwal %> <%= a.satuan %></div>
                                    <% if(a.penggunaan && a.penggunaan.length > 0) { %>
                                        <div style="font-size:0.7rem;color:var(--body-text3);">Dipasang: <%= a.penggunaan.length %></div>
                                    <% } %>
                                    <% if(a.pinjaman && a.pinjaman.length > 0) { %>
                                        <div style="font-size:0.7rem;color:#f59e0b;">Dipinjam: <%= a.pinjaman.length %></div>
                                    <% } %>
                                </td>
                                <td>
                                    <span style="font-size:0.75rem; font-weight:bold; color: <%= a.kondisi === 'Baik' ? '#4caf50' : (a.kondisi === 'Rusak' ? '#ff6b6b' : '#f59e0b') %>;">
                                        <%= a.kondisi %>
                                    </span>
                                </td>
                                <td style="width:110px;min-width:110px;">
                                    <% if(a.fotoUrl) { %>
                                        <button class="btn-foto-view" style="width:auto; padding:3px 10px;" onclick="showFoto('<%= a.fotoUrl %>','ASET','<%= (a.nama||'').replace(/'/g,"\\'") %>')">Lihat Foto</button>
                                    <% } else { %>
                                        <span class="foto-none">—</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- KANAN: BREAKDOWN, PENDING & AI CHAT -->
        <div class="col-lg-4">
         
            <!-- BREAKDOWN PER DIVISI -->
            <div class="section-panel">
                <div class="section-title">Breakdown per Divisi</div>
                <% if (stats.divisiBreakdown.length === 0) { %>
                    <div style="font-size:0.8rem;color:var(--body-text3);text-align:center;padding:1rem;">Tidak ada data</div>
                <% } %>
                <table class="breakdown-table">
                    <thead>
                        <tr>
                            <th>Divisi</th>
                            <th style="text-align:right;">Log</th>
                            <th style="text-align:right;">Pending</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% stats.divisiBreakdown.forEach(function(d){ %>
                        <tr>
                            <td>
                                <span class="div-tag"><%= d.divisi %></span>
                                <div class="bar-wrap">
                                    <div class="bar-fill" style="width:<%= stats.totalAllTime > 0 ? Math.round(d.total / stats.totalAllTime * 100) : 0 %>%;"></div>
                                </div>
                            </td>
                            <td style="text-align:right;font-weight:700;font-family:monospace;font-size:0.85rem;"><%= d.total %></td>
                            <td style="text-align:right;">
                                <% if (d.pending > 0) { %>
                                <span class="badge-pending"><%= d.pending %></span>
                                <% } else { %>
                                <span style="font-size:0.7rem;color:var(--body-text3);">—</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- PENDING ITEMS -->
            <% if (stats.pendingItems.length > 0) { %>
            <div class="section-panel">
                <div class="section-title"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 22h14M5 2h14M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22M17 2v4.172a2 2 0 0 1-.586 1.414L12 12 7.586 7.586A2 2 0 0 1 7 6.172V2"/></svg> Item Pending (<%= stats.totalPending %>)</div>
                <% stats.pendingItems.forEach(function(p){ %>
                <div style="background:var(--body-bg);border:1px solid #5c1a1a;border-left:3px solid #ff6b6b;border-radius:6px;padding:9px 11px;margin-bottom:7px;">
                    <div style="font-size:0.78rem;font-weight:700;color:var(--body-text);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.aktivitas %></div>
                    <div style="font-size:0.65rem;color:var(--body-text2);">
                        <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/></svg> <strong><%= p.divisi %></strong> &nbsp;·&nbsp; <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <%= p.pemesan %>
                        &nbsp;·&nbsp; <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <%= new Date(p.tanggalManual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                    </div>
                    <% if (p.hariPending > 0) { %>
                    <div style="margin-top:4px;">
                        <span style="font-size:0.62rem;font-weight:700;padding:2px 7px;border-radius:20px;<%= p.hariPending > 7 ? 'background:#5c0000;color:#ff6b6b;' : p.hariPending > 3 ? 'background:#5c3d00;color:#ffc107;' : 'background:var(--body-bg3);color:var(--body-text3);' %>">
                            <%= p.hariPending %> hari pending
                        </span>
                    </div>
                    <% } %>
                </div>
                <% }); %>
                <% if (stats.totalPending > stats.pendingItems.length) { %>
                <div style="text-align:center;font-size:0.68rem;color:var(--body-text3);margin-top:6px;">+<%= stats.totalPending - stats.pendingItems.length %> item lainnya</div>
                <% } %>
            </div>
            <% } %>

            <!-- INFO AUDIT -->
            <div class="section-panel" style="border-color:#92400e;">
                <div class="section-title">ℹ️ Keterangan Akses</div>
                <div style="font-size:0.78rem;color:var(--body-text2);line-height:1.7;">
                    <div style="margin-bottom:6px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Kamu mengakses sebagai <strong style="color:#f59e0b;">Tim Audit / Internal Control</strong></div>
                    <div style="margin-bottom:6px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Dapat melihat log <strong>semua divisi</strong> tanpa batasan</div>
                    <div style="margin-bottom:6px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Data <strong>tidak dapat diubah</strong> dari tampilan ini</div>
                    <div><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Gunakan filter di atas untuk menyaring data</div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- MODAL FOTO -->
<div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);">
            <div class="modal-header" style="border-color:var(--body-border);">
                <h5 class="modal-title" style="color:var(--body-text);font-size:0.9rem;" id="fotoModalTitle">Dokumentasi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-3">
                <img id="popupImage" src="" class="img-fluid rounded" style="max-height:75vh;">
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- RENDER CHART.JS -->
<script>
    Chart.defaults.color = '#888';
    Chart.defaults.font.family = 'Inter, sans-serif';

    // 1. Chart Divisi
    const divisiLabels = <%- JSON.stringify(stats.divisiBreakdown.map(d => d.divisi).slice(0, 8)) %>;
    const divisiData = <%- JSON.stringify(stats.divisiBreakdown.map(d => d.total).slice(0, 8)) %>;

    new Chart(document.getElementById('divisiChart'), {
        type: 'bar',
        data: {
            labels: divisiLabels,
            datasets: [{
                label: 'Jumlah Tiket/Log',
                data: divisiData,
                backgroundColor: '#f59e0b',
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#333' } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Chart Masalah
    const masalahLabels = <%- JSON.stringify(stats.masalahSering.map(m => m.nama)) %>;
    const masalahData = <%- JSON.stringify(stats.masalahSering.map(m => m.total)) %>;

    new Chart(document.getElementById('masalahChart'), {
        type: 'doughnut',
        data: {
            labels: masalahLabels,
            datasets: [{
                data: masalahData,
                backgroundColor: ['#f59e0b', '#3b82f6', '#10b981', '#ef4444', '#8b5cf6', '#06b6d4', '#f97316', '#eab308', '#ec4899', '#64748b'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'right', labels: { boxWidth: 12, font: { size: 10 } } }
            },
            cutout: '65%'
        }
    });

    // 3. Chart Pemesan (User Paling Sering)
    const pemesanLabels = <%- JSON.stringify(stats.pemesanSering.map(u => u.nama)) %>;
    const pemesanData = <%- JSON.stringify(stats.pemesanSering.map(u => u.total)) %>;

    new Chart(document.getElementById('userChart'), {
        type: 'bar',
        data: {
            labels: pemesanLabels,
            datasets: [{
                label: 'Jumlah Request IT',
                data: pemesanData,
                backgroundColor: '#3b82f6',
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y', // Buat jadi horizontal bar
            plugins: { legend: { display: false } },
            scales: {
                x: { beginAtZero: true, grid: { color: '#333' } },
                y: { grid: { display: false } }
            }
        }
    });

    // FOTO VIEWER
    var camSvg = '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> ';
    function showFoto(url, tipe, nama) {
        document.getElementById('popupImage').src = url;
        var label = tipe === 'AWAL'    ? 'Kondisi AWAL — ' + (nama||'')
                  : tipe === 'SESUDAH' ? 'Kondisi SESUDAH — ' + (nama||'')
                  : tipe === 'ASET'    ? 'Aset: ' + (nama||'')
                  : (nama || tipe || 'Dokumentasi');
        document.getElementById('fotoModalTitle').innerHTML = camSvg + label;
        new bootstrap.Modal(document.getElementById('fotoModal')).show();
    }
</script>

</body>
</html>