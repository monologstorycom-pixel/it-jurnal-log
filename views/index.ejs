<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT LOG | JURNAL</title>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#161b22">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="icon" type="image/png" href="/icon-512.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono&display=swap');
        body { background-color: #0d0d0d !important; color: #fff; font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; }
        .app-nav { border-bottom: 2px solid #262626; padding: 1.2rem 2rem; background: #161b22; display: flex; justify-content: space-between; align-items: center; }
        .table-container { background: #ffffff !important; border-radius: 10px; border: 1px solid #333; margin-top: 15px; }
        .table { min-width: 900px; margin: 0; }
        .table td { padding: 1.2rem 1rem; vertical-align: middle; color: #000000 !important; font-size: 0.85rem; border-bottom: 1px solid #eee; }
        .txt-bold { font-weight: 700; color: #000; font-size: 0.95rem; }
        .status-solved { color: #008000 !important; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; }
        .status-pending { color: #8b6508 !important; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; }
        .btn-lihat { background: #000; color: #fff !important; padding: 5px 12px; border-radius: 4px; border: none; font-size: 0.7rem; font-weight: 700; cursor: pointer; white-space: nowrap; }

        @media (max-width: 768px) {
            .app-nav { flex-direction: column; text-align: center; gap: 15px; padding: 1rem; }
            .container-fluid { padding: 1rem !important; }
            .filter-form .col-auto { width: 100%; margin-bottom: 10px; }
            .filter-form select, .filter-form button, .filter-form a { width: 100%; text-align: center; }
        }
    </style>
</head>
<body>
    <nav class="app-nav">
        <div style="font-family: 'JetBrains Mono'; font-weight: 700; font-size: 1.2rem;">>_ IT SUPPORT LOG</div>
    </nav>
    
    <div class="container-fluid p-4" style="max-width: 1600px;">
        <div class="p-3 mb-4" style="background:#161b22; border-radius:8px; border:1px solid #333;">
            <form action="/" method="GET" class="row g-2 align-items-center m-0 filter-form">
                <div class="col-auto"><span class="small fw-bold text-secondary d-block mb-1">FILTER BULAN:</span></div>
                <div class="col-auto">
                    <select name="month" class="form-select bg-dark text-white border-secondary">
                        <% const months = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"]; %>
                        <% months.forEach((m, i) => { %>
                            <option value="<%= i + 1 %>" <%= filterInfo.month == (i + 1) ? 'selected' : '' %>><%= m %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-auto">
                    <!-- DROPDOWN TAHUN DINAMIS — otomatis nambah tiap tahun baru -->
                    <select name="year" class="form-select bg-dark text-white border-secondary">
                        <% yearOptions.forEach(y => { %>
                            <option value="<%= y %>" <%= filterInfo.year == y ? 'selected' : '' %>><%= y %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary fw-bold">TAMPILKAN</button>
                </div>
                <div class="col-auto ms-md-auto">
                    <a href="/export?month=<%= filterInfo.month %>&year=<%= filterInfo.year %>" class="btn btn-success fw-bold">DOWNLOAD</a>
                </div>
            </form>
        </div>

        <div class="table-container table-responsive">
            <table class="table">
                <thead>
                    <tr style="background:#1f242b; color:#fff;">
                        <th style="padding: 1rem;">WAKTU</th>
                        <th style="padding: 1rem;">UNIT</th>
                        <th style="padding: 1rem; width: 40%;">AKTIVITAS & DESKRIPSI</th>
                        <th style="padding: 1rem;">STATUS</th>
                        <th style="padding: 1rem;" class="text-center">DOKUMENTASI</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(journals.length === 0) { %>
                        <tr><td colspan="5" class="text-center py-5 text-muted">Belum ada log kerja untuk bulan ini.</td></tr>
                    <% } else { %>
                        <% journals.forEach(item => { %>
                            <tr>
                                <td style="font-family: 'JetBrains Mono'; font-size: 0.85rem; color: #006666 !important; font-weight: 600; white-space: nowrap;">
                                    <%= new Date(item.tanggalManual).toLocaleString('id-ID', {day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'}).replace(/\./g, ':') %>
                                </td>
                                <td style="white-space: nowrap;">
                                    <div class="txt-bold"><%= item.divisi %></div>
                                    <div style="font-size: 0.75rem; color: #555;">User: <%= item.pemesan %></div>
                                </td>
                                <td>
                                    <div class="txt-bold" style="margin-bottom: 4px;"><%= item.aktivitas %></div>
                                    <div style="font-size: 0.85rem; color: #444;"><%= item.deskripsi %></div>
                                </td>
                                <td>
                                    <span class="<%= item.status === 'Solved' ? 'status-solved' : 'status-pending' %>"><%= item.status %></span>
                                </td>
                                <td class="text-center">
                                    <% if(item.fotoUrl) { %>
                                        <button type="button" class="btn-lihat" onclick="showFoto('<%= item.fotoUrl %>')">LIHAT FOTO</button>
                                    <% } else { %>
                                        <span style="color:#999; font-size:0.75rem; font-style: italic;">No Photo</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-white">Dokumentasi Jurnal</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-3">
                    <img id="popupImage" src="" class="img-fluid rounded" style="max-height: 75vh;">
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showFoto(url) {
            document.getElementById('popupImage').src = url;
            new bootstrap.Modal(document.getElementById('fotoModal')).show();
        }

        // REGISTER PWA SERVICE WORKER
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('SW OK'))
                    .catch(err => console.log('SW Gagal', err));
            });
        }
    </script>
</body>
</html>
