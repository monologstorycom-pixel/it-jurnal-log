<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT LOG | JURNAL</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#161b22">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="icon" type="image/png" href="/icon-512.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono&display=swap');

        body { background-color: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; transition: background-color 0.25s, color 0.25s; }

        /* TABLE */
        .table-container { background: var(--body-card) !important; border-radius: 10px; border: 1px solid var(--body-border); margin-top: 12px; }
        .table { min-width: 100%; margin: 0; }
        .table thead tr { background: var(--body-table-head) !important; }
        .table thead th { color: var(--body-table-head-text) !important; }
        .table tbody tr { border-bottom: 1px solid var(--body-table-border); }
        .table th, .table td { padding: 0.85rem; vertical-align: middle; color: var(--body-table-text) !important; font-size: 0.82rem; border-bottom: 1px solid var(--body-table-border); }
        .txt-bold { font-weight: 700; color: var(--body-table-text); font-size: 0.9rem; }
        .status-solved { color: #008000 !important; font-weight: 800; font-size: 0.72rem; text-transform: uppercase; }
        .status-pending { color: #8b6508 !important; font-weight: 800; font-size: 0.72rem; text-transform: uppercase; }

        .btn-lihat      { background: #111; color: #fff !important; padding: 4px 10px; border-radius: 4px; border: none; font-size: 0.68rem; font-weight: 700; cursor: pointer; white-space: nowrap; display: block; margin-bottom: 4px; width: 100%; }
        .btn-lihat-awal { background: #5a3e00; color: #ffc107 !important; padding: 4px 10px; border-radius: 4px; border: 1px solid #ffc107; font-size: 0.68rem; font-weight: 700; cursor: pointer; white-space: nowrap; display: block; margin-bottom: 4px; width: 100%; }
        .durasi-badge { display: inline-block; background: #e8f4fd; color: #0066aa; border: 1px solid #b3d7f0; border-radius: 4px; padding: 2px 7px; font-size: 0.68rem; font-weight: 700; margin-top: 3px; white-space: nowrap; }
        .durasi-badge-multi { background: #f0e8fd; color: #6600aa; border-color: #d0b0f0; }
        .multi-badge { display: inline-block; background: #1a0d3d; color: #9b6dff; border: 1px solid #6b3dbf; border-radius: 3px; padding: 1px 5px; font-size: 0.6rem; font-weight: 700; margin-bottom: 3px; }
        .tgl-range { font-size: 0.78rem; color: #6600aa; font-weight: 600; }
        .tgl-arrow { font-size: 0.7rem; color: #999; margin: 1px 0; }
        .jam-info { font-size: 0.72rem; color: var(--body-text2); margin-top: 2px; }

        /* SECTION BOX */
        .section-box { background: var(--body-card); border-radius: 8px; border: 1px solid var(--body-border); padding: 1rem; margin-bottom: 1rem; }
        .section-box .form-control, .section-box .form-select { background: var(--body-input) !important; color: var(--body-text) !important; border-color: var(--body-border) !important; }

        /* FLOATING NOTES */
        .floating-notes { position: fixed; top: 110px; right: 20px; width: 320px; max-height: 75vh; overflow-y: auto; background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; box-shadow: 0 24px 60px rgba(0,0,0,0.35); padding: 1rem; z-index: 1050; }
        .floating-notes .notes-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
        .floating-notes .section-title { margin: 0; font-size: 0.95rem; color: var(--body-text); font-weight: 700; }
        .floating-notes .close-notes { margin-left: auto; border: none; background: transparent; color: var(--body-text); font-size: 1.1rem; cursor: pointer; opacity: 0.8; }
        .floating-notes .close-notes:hover { opacity: 1; }
        .note-card { background: var(--body-bg); padding: 12px; border-radius: 6px; margin-bottom: 8px; border-left: 3px solid #0d6efd; }
        .note-title { color: var(--body-text); font-size: 0.95rem; font-weight: 700; }
        .note-content { color: var(--body-text2); margin: 4px 0 0 0; font-size: 0.85rem; }
        .note-date { color: var(--body-text3); font-size: 0.72rem; }

        @media (max-width: 1200px) { .floating-notes { position: static; width: 100%; max-height: none; box-shadow: none; border-radius: 8px; margin-top: 1rem; } }
        @media (max-width: 768px) { .container-fluid { padding: 1rem !important; } }
    </style>
</head>
<body>
    <%- include('navbar', {activePage: 'view'}) %>

    <div class="container-fluid p-4" style="max-width: 1600px;">
        <!-- DAILY LOG FILTER -->
        <div class="section-box">
            <div style="color:var(--body-text);font-weight:700;margin-bottom:12px;font-size:0.9rem;">📅 DAILY LOG</div>
            <form action="/" method="GET" class="row g-2 align-items-center m-0">
                <div class="col-auto"><input type="date" name="date" value="<%= filterInfo.date %>" class="form-control" style="width:160px;"></div>
                <div class="col-auto"><button type="submit" class="btn btn-primary fw-bold">LIHAT</button></div>
                <div class="col-auto"><a href="/" class="btn btn-outline-secondary fw-bold" style="color:var(--body-text);">HARI INI</a></div>
            </form>
            <div class="mt-2" style="color:var(--body-text2);font-size:0.75rem;">📋 Menampilkan: <strong><%= filterInfo.dateDisplay %></strong></div>
        </div>

        <!-- MONTHLY REPORT / EXPORT -->
        <div class="section-box">
            <div style="color:var(--body-text);font-weight:700;margin-bottom:12px;font-size:0.9rem;">📊 MONTHLY REPORT</div>
            <form action="/export" method="GET" class="row g-2 align-items-center m-0">
                <div class="col-auto">
                    <select name="month" class="form-select form-select-sm">
                        <% ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'].forEach((m, i) => { %>
                            <option value="<%= i+1 %>" <%= filterInfo.month == (i+1) ? 'selected' : '' %>><%= m %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-auto">
                    <select name="year" class="form-select form-select-sm">
                        <% yearOptions.forEach(y => { %><option value="<%= y %>" <%= filterInfo.year == y ? 'selected' : '' %>><%= y %></option><% }) %>
                    </select>
                </div>
                <div class="col-auto"><button type="submit" class="btn btn-sm btn-success fw-bold">DOWNLOAD EXCEL</button></div>
            </form>
        </div>

        <!-- FLOATING NOTES -->
        <div class="floating-notes" id="floatingNotes">
            <div class="notes-header">
                <div class="section-title">📝 CATATAN</div>
                <button type="button" class="close-notes" onclick="hideNotesPanel()">×</button>
            </div>
            <div id="notesList">Loading notes...</div>
        </div>

        <!-- TABLE -->
        <div class="table-container table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>WAKTU & DURASI</th>
                        <th>UNIT</th>
                        <th style="width:38%;">AKTIVITAS & DESKRIPSI</th>
                        <th>STATUS</th>
                        <th class="text-center">DOKUMENTASI</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(journals.length === 0) { %>
                        <tr><td colspan="5" class="text-center py-5" style="color:var(--body-text2);">Belum ada log kerja untuk hari ini.</td></tr>
                    <% } else { %>
                        <% journals.forEach(item => { %>
                        <tr>
                            <td style="white-space:nowrap;min-width:145px;">
                                <% if (item.tipeInput === 'multihari' && item.tanggalMulai && item.tanggalSelesai) { %>
                                    <span class="multi-badge">📆 MULTI-HARI</span>
                                    <div class="tgl-range" style="margin-top:3px;">🗓 <%= new Date(item.tanggalMulai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %><% if(item.jamMulai){%><span style="color:#888;font-size:0.7rem;"> <%= item.jamMulai %></span><%}%></div>
                                    <div class="tgl-arrow">  ↓</div>
                                    <div class="tgl-range">🏁 <%= new Date(item.tanggalSelesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %><% if(item.jamSelesai){%><span style="color:#888;font-size:0.7rem;"> <%= item.jamSelesai %></span><%}%></div>
                                    <% if(item.durasiMenit){%><span class="durasi-badge durasi-badge-multi">⏱ <%= formatDurasi(item.durasiMenit) %></span><%}%>
                                <% } else { %>
                                    <div style="font-family:'JetBrains Mono';font-size:0.8rem;color:#006666;font-weight:600;"><%= new Date(item.tanggalManual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></div>
                                    <% if(item.jamMulai){%><div class="jam-info">🕐 Mulai: <strong><%= item.jamMulai %></strong></div><%}%>
                                    <% if(item.jamSelesai){%><div class="jam-info">🕔 Selesai: <strong><%= item.jamSelesai %></strong></div><%}%>
                                    <% if(item.durasiMenit){%><span class="durasi-badge">⏱ <%= formatDurasi(item.durasiMenit) %></span><%}%>
                                <% } %>
                            </td>
                            <td style="white-space:nowrap;">
                                <div class="txt-bold"><%= item.divisi %></div>
                                <div style="font-size:0.75rem;color:var(--body-text2);">User: <%= item.pemesan %></div>
                            </td>
                            <td>
                                <div class="txt-bold" style="margin-bottom:4px;"><%= item.aktivitas %></div>
                                <div style="font-size:0.85rem;color:var(--body-text2);"><%= item.deskripsi %></div>
                            </td>
                            <td><span class="<%= item.status==='Solved'?'status-solved':'status-pending' %>"><%= item.status %></span></td>
                            <td class="text-center" style="min-width:110px;">
                                <% if(item.fotoAwalUrl){%><button type="button" class="btn-lihat-awal" onclick="showFoto('<%= item.fotoAwalUrl %>','Kondisi AWAL')">📷 AWAL</button><%}%>
                                <% if(item.fotoUrl){%><button type="button" class="btn-lihat" onclick="showFoto('<%= item.fotoUrl %>','Kondisi SESUDAH')">📷 SESUDAH</button><%}%>
                                <% if(!item.fotoAwalUrl && !item.fotoUrl){%><span style="color:var(--body-text2);font-size:0.75rem;font-style:italic;">No Photo</span><%}%>
                            </td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- MODAL FOTO -->
    <div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);">
                <div class="modal-header" style="border-color:var(--body-border);"><h5 class="modal-title" style="color:var(--body-text);" id="fotoModalLabel">Dokumentasi</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body text-center p-3"><img id="popupImage" src="" class="img-fluid rounded" style="max-height:75vh;"></div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showFoto(url,judul){document.getElementById('popupImage').src=url;document.getElementById('fotoModalLabel').textContent='📷 '+(judul||'Dokumentasi');new bootstrap.Modal(document.getElementById('fotoModal')).show();}

        async function loadNotes() {
            try {
                var res=await fetch('/api/notes'), notes=await res.json(), el=document.getElementById('notesList');
                if(notes.length===0){el.innerHTML='<p style="color:var(--body-text3);">Belum ada catatan.</p>';return;}
                el.innerHTML=notes.map(function(n){
                    var d=new Date(n.createdAt).toLocaleString('id-ID',{dateStyle:'short',timeStyle:'short'});
                    return '<div class="note-card"><strong class="note-title">'+n.title+'</strong><p class="note-content">'+n.content+'</p><small class="note-date">'+d+'</small></div>';
                }).join('');
            } catch(err){document.getElementById('notesList').innerHTML='<p style="color:#f00;">Error loading notes</p>';}
        }

        function hideNotesPanel(){document.getElementById('floatingNotes').style.display='none';}

        window.addEventListener('load',function(){loadNotes();});
        if('serviceWorker' in navigator){window.addEventListener('load',function(){navigator.serviceWorker.register('/sw.js').catch(function(err){console.log('SW Gagal',err);});});}
    </script>
    <script src="/offline-sync.js"></script>
</body>
</html>
