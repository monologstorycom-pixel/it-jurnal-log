<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#1a3a1a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="IT Log">
    <link rel="icon" type="image/x-icon"   href="/favicon.ico">
    <link rel="icon" type="image/svg+xml"  href="/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180x180.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT Support Log — View Harian</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            background-color: var(--body-bg) !important;
            color: var(--body-text) !important;
            font-family: 'Inter', sans-serif;
            margin: 0; overflow-x: hidden;
            transition: background-color 0.2s, color 0.2s;
        }

        .page-wrap { max-width: 1400px; margin: 0 auto; padding: 1.5rem; }

        /* FILTER BAR */
        .filter-bar {
            background: var(--body-card);
            border: 0.5px solid var(--body-border);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .filter-bar .filter-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--body-text2);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            white-space: nowrap;
        }
        .filter-bar input[type="date"],
        .filter-bar select {
            background: var(--body-input) !important;
            border: 0.5px solid var(--body-input-border) !important;
            border-radius: 8px;
            color: var(--body-text) !important;
            padding: 6px 10px;
            font-size: 13px;
            outline: none;
        }
        .filter-bar input[type="date"]:focus,
        .filter-bar select:focus { border-color: var(--body-input-focus) !important; }
        .btn-filter {
            padding: 6px 14px; border-radius: 8px;
            background: var(--body-bg3);
            border: 0.5px solid var(--body-border2);
            color: var(--body-text2);
            font-size: 13px; font-weight: 500; cursor: pointer;
            text-decoration: none; display: inline-flex; align-items: center;
            transition: all 0.12s;
        }
        .btn-filter:hover { color: var(--body-text); border-color: var(--body-border2); }
        .btn-filter.primary {
            background: var(--body-accent-bg);
            border-color: var(--body-accent);
            color: var(--body-accent);
        }

        /* DATE DISPLAY */
        .date-display {
            font-size: 12px; color: var(--body-text2);
            padding: 4px 10px; border-radius: 20px;
            background: var(--body-bg3);
            border: 0.5px solid var(--body-border);
        }
        .date-display strong { color: var(--body-text); }

        /* SEARCH BAR */
        .search-bar {
            background: var(--body-card);
            border: 0.5px solid var(--body-border);
            border-radius: 12px;
            padding: 0.75rem 1.25rem;
            margin-bottom: 1rem;
            display: flex; align-items: center; gap: 10px;
        }
        .search-bar input[type="text"] {
            flex: 1; background: var(--body-input) !important;
            border: 0.5px solid var(--body-input-border) !important;
            border-radius: 8px; color: var(--body-text) !important;
            padding: 7px 12px; font-size: 13px; outline: none;
        }
        .search-bar input[type="text"]:focus { border-color: var(--body-input-focus) !important; }
        .search-bar input::placeholder { color: var(--body-text3); }
        .search-result-info {
            font-size: 12px; color: var(--body-text2);
            padding: 4px 12px; border-radius: 20px;
            background: var(--body-accent-bg);
            border: 0.5px solid var(--body-accent);
            color: var(--body-accent); white-space: nowrap;
        }

        /* TABLE */
        .table-wrap {
            background: var(--body-card);
            border: 0.5px solid var(--body-border);
            border-radius: 12px;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
        }
        .table { min-width: 900px; margin: 0; }
        .table, .table > :not(caption) > * > * { background-color: transparent !important; }
        .table thead tr { background: var(--body-table-head) !important; }
        .table thead th {
            color: var(--body-table-head-text) !important;
            font-size: 11px; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.07em;
            padding: 12px 14px; border-bottom: 0.5px solid var(--body-border) !important;
            white-space: nowrap;
            background: var(--body-table-head) !important;
        }
        .table tbody tr { border-bottom: 0.5px solid var(--body-table-border) !important; }
        .table tbody tr:hover td { background: var(--body-bg3) !important; }
        .table td {
            padding: 12px 14px; vertical-align: middle;
            color: var(--body-text) !important;
            font-size: 13px; line-height: 1.5;
            border-bottom: 0.5px solid var(--body-table-border) !important;
            background: transparent !important;
        }

        /* STATUS */
        .badge-solved  { display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;background:#dcfce7;color:#15803d; }
        .badge-pending { display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;background:#fef9c3;color:#a16207; }

        /* DURASI */
        .durasi-badge { display:inline-block;background:var(--body-bg3);color:var(--body-text2);border:0.5px solid var(--body-border);border-radius:20px;padding:2px 8px;font-size:11px;font-weight:500;margin-top:3px;white-space:nowrap; }
        .durasi-badge-multi { background:var(--body-accent-bg, #f0e8fd);color:var(--body-accent, #6600aa);border-color:var(--body-accent, #d0b0f0); }
        .multi-badge { display:inline-block;background:var(--body-accent-bg, #f0e8fd);color:var(--body-accent, #6600aa);border:0.5px solid var(--body-accent, #d0b0f0);border-radius:4px;padding:1px 6px;font-size:10px;font-weight:600;margin-bottom:4px; }
        .jam-info { font-size:12px;color:var(--body-text2);margin-top:2px; }
        .tgl-range { font-size:12px;color:var(--body-accent, #6600aa);font-weight:500; }

        /* FOTO BTN */
        .btn-foto {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 4px 10px; border-radius: 6px;
            font-size: 11px; font-weight: 500;
            cursor: pointer; margin-bottom: 3px;
            width: 100%; justify-content: center;
            text-align: center; border: none;
        }
        .btn-foto-awal    { background: #5a3e00; color: #ffc107; }
        .btn-foto-sesudah { background: #1a1a1a; color: #ffffff; }

        /* EMPTY */
        .empty-state { text-align: center; padding: 4rem 2rem; color: var(--body-text3); font-size: 14px; }
        .empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }

        /* ANIMASI ROW MASUK */
        @keyframes rowFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .table tbody tr.data-row {
            animation: rowFadeIn 0.3s ease both;
            cursor: pointer;
        }
        .table tbody tr.data-row.row-active td {
            background: var(--body-bg3) !important;
        }

        /* EXPAND DETAIL ROW */
        .detail-row td {
            padding: 0 !important;
            border-bottom: 0.5px solid var(--body-table-border) !important;
            background: var(--body-bg3) !important;
        }
        .detail-inner {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 12px;
            padding: 14px 18px;
            animation: rowFadeIn 0.2s ease both;
        }
        .detail-item { display: flex; flex-direction: column; gap: 2px; }
        .detail-label {
            font-size: 10px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.07em; color: var(--body-text3);
        }
        .detail-value { font-size: 13px; color: var(--body-text); line-height: 1.5; }
        .chevron-icon {
            display: inline-block; transition: transform 0.2s ease;
            margin-left: 6px; vertical-align: middle; color: var(--body-text3);
        }
        .row-active .chevron-icon { transform: rotate(180deg); }

        /* SKELETON LOADING */
        @keyframes skeletonShimmer {
            0%   { background-position: -600px 0; }
            100% { background-position: 600px 0; }
        }
        .skeleton-line {
            border-radius: 6px;
            background: linear-gradient(90deg, var(--body-bg3) 25%, var(--body-border) 50%, var(--body-bg3) 75%);
            background-size: 600px 100%;
            animation: skeletonShimmer 1.4s infinite linear;
        }
        .skeleton-wrap {
            background: var(--body-card);
            border: 0.5px solid var(--body-border);
            border-radius: 12px;
            overflow: hidden;
        }
        .skeleton-thead {
            padding: 12px 14px;
            background: var(--body-table-head);
            border-bottom: 0.5px solid var(--body-border);
            display: flex; gap: 16px; align-items: center;
        }
        .skeleton-row {
            padding: 16px 14px;
            border-bottom: 0.5px solid var(--body-table-border);
            display: flex; gap: 16px; align-items: center;
        }
        .skeleton-row:last-child { border-bottom: none; }
        .sk-cell { flex-shrink: 0; display: flex; flex-direction: column; gap: 6px; }

        /* Sembunyiin tabel asli saat loading */
        .table-wrap.is-loading { display: none; }


    </style>
</head>
<body>
    <%- include('navbar-public', {activePage: 'home'}) %>

    <div class="page-wrap">



        <div class="row g-3">

            <!-- SEARCH BAR -->
            <div class="col-12">
                <form action="/" method="GET" class="search-bar">
                    <span style="font-size:16px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
                    <input type="text" name="q" value="<%= searchQuery %>"
                        placeholder="Cari aktivitas, nama, divisi, deskripsi...">
                    <button type="submit" class="btn-filter primary">Cari</button>
                    <% if (isSearch) { %>
                        <a href="/" class="btn-filter"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Reset</a>
                        <span class="search-result-info"><%= journals.length %> hasil untuk "<%= searchQuery %>"</span>
                    <% } %>
                </form>
            </div>

            <!-- FILTER TANGGAL — sembunyikan kalau mode search -->
            <% if (!isSearch) { %>
            <div class="col-12">
                <form action="/" method="GET" class="filter-bar">
                    <span class="filter-label"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> Tanggal</span>
                    <input type="date" name="date" value="<%= filterInfo.date %>" style="width:160px;">
                    <button type="submit" class="btn-filter primary">Lihat</button>
                    <a href="/" class="btn-filter">Hari Ini</a>

                    <span class="date-display">
                        <strong><%= filterInfo.dateDisplay %></strong>
                    </span>
                </form>
            </div>
            <% } %>

            <!-- TABLE -->
            <div class="col-12">

                <!-- SKELETON -->
                <div class="skeleton-wrap" id="skeletonTable">
                    <div class="skeleton-thead">
                        <div class="skeleton-line" style="height:10px;width:110px;"></div>
                        <div class="skeleton-line" style="height:10px;width:70px;"></div>
                        <div class="skeleton-line" style="height:10px;flex:1;"></div>
                        <div class="skeleton-line" style="height:10px;width:55px;"></div>
                        <div class="skeleton-line" style="height:10px;width:60px;"></div>
                    </div>
                    <% for(var s=0; s<5; s++) { %>
                    <div class="skeleton-row">
                        <div class="sk-cell" style="width:130px;">
                            <div class="skeleton-line" style="height:11px;width:90px;"></div>
                            <div class="skeleton-line" style="height:10px;width:110px;"></div>
                            <div class="skeleton-line" style="height:10px;width:75px;"></div>
                            <div class="skeleton-line" style="height:18px;width:70px;border-radius:20px;margin-top:2px;"></div>
                        </div>
                        <div class="sk-cell" style="width:110px;">
                            <div class="skeleton-line" style="height:11px;width:90px;"></div>
                            <div class="skeleton-line" style="height:10px;width:75px;"></div>
                        </div>
                        <div class="sk-cell" style="flex:1;">
                            <div class="skeleton-line" style="height:12px;width:60%;"></div>
                            <div class="skeleton-line" style="height:10px;width:90%;"></div>
                            <div class="skeleton-line" style="height:10px;width:75%;"></div>
                        </div>
                        <div class="sk-cell" style="width:65px;">
                            <div class="skeleton-line" style="height:20px;width:60px;border-radius:20px;"></div>
                        </div>
                        <div class="sk-cell" style="width:100px;align-items:center;">
                            <div class="skeleton-line" style="height:26px;width:90px;border-radius:6px;"></div>
                            <div class="skeleton-line" style="height:26px;width:90px;border-radius:6px;"></div>
                        </div>
                    </div>
                    <% } %>
                </div>

                <div class="table-wrap table-responsive is-loading" id="realTable">
                    <table class="table table-borderless mb-0">
                        <thead>
                            <tr>
                                <th>Waktu & Durasi</th>
                                <th>Divisi</th>
                                <th style="width:38%;">Aktivitas & Deskripsi</th>
                                <th>Status</th>
                                <th class="text-center">Foto</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(journals.length === 0) { %>
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">
                                        <% if (isSearch) { %>
                                        <div class="empty-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
                                        <div>Tidak ada hasil untuk "<strong><%= searchQuery %></strong>".</div>
                                        <div style="margin-top:8px;font-size:12px;">Coba kata kunci lain atau <a href="/" style="color:var(--body-accent);">lihat log hari ini</a>.</div>
                                        <% } else { %>
                                        <div class="empty-icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></div>
                                        <div>Belum ada log kerja untuk hari ini.</div>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% } else { %>
                            <% journals.forEach(function(item, idx) { %>
                            <tr class="data-row"
                                style="animation-delay:<%= idx * 45 %>ms"
                                onclick="toggleDetail(this)"
                                data-aktivitas="<%= encodeURIComponent(item.aktivitas||'') %>"
                                data-deskripsi="<%= encodeURIComponent(item.deskripsi||'') %>"
                                data-divisi="<%= encodeURIComponent(item.divisi||'') %>"
                                data-pemesan="<%= encodeURIComponent(item.pemesan||'') %>"
                                data-status="<%= item.status %>"
                                data-durasi="<%= item.durasiMenit ? formatDurasi(item.durasiMenit) : '' %>"
                                data-foto-awal="<%= item.fotoAwalUrl || '' %>"
                                data-foto-sesudah="<%= item.fotoUrl || '' %>"
                            >
                                <td style="white-space:nowrap;min-width:140px;">
                                    <% if (item.tipeInput === 'multihari' && item.tanggalMulai && item.tanggalSelesai) { %>
                                        <span class="multi-badge"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> MULTI-HARI</span>
                                        <div class="tgl-range"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <%= new Date(item.tanggalMulai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %><% if(item.jamMulai){%> <span style="color:var(--body-text3);font-size:11px;"><%= item.jamMulai %></span><%}%></div>
                                        <div style="font-size:11px;color:var(--body-text3);margin:1px 0;">↓</div>
                                        <div class="tgl-range"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg> <%= new Date(item.tanggalSelesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %><% if(item.jamSelesai){%> <span style="color:var(--body-text3);font-size:11px;"><%= item.jamSelesai %></span><%}%></div>
                                        <% if(item.durasiMenit){%><span class="durasi-badge durasi-badge-multi"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <%= formatDurasi(item.durasiMenit) %></span><%}%>
                                    <% } else { %>
                                        <div style="font-size:13px;color:var(--body-text);font-weight:500;"><%= new Date(item.tanggalManual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></div>
                                        <% if(item.jamMulai){%><div class="jam-info"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 14 14"/></svg> Mulai: <strong><%= item.jamMulai %></strong></div><%}%>
                                        <% if(item.jamSelesai){%><div class="jam-info"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 12"/></svg> Selesai: <strong><%= item.jamSelesai %></strong></div><%}%>
                                        <% if(item.durasiMenit){%><span class="durasi-badge"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <%= formatDurasi(item.durasiMenit) %></span><%}%>
                                    <% } %>
                                </td>
                                <td style="white-space:nowrap;">
                                    <div style="font-weight:600;"><%= item.divisi %></div>
                                    <div style="font-size:12px;color:var(--body-text2);">User: <%= item.pemesan %></div>
                                </td>
                                <td>
                                    <div style="font-weight:600;margin-bottom:3px;">
                                        <%= item.aktivitas %>
                                        <svg class="lc chevron-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="13" height="13"><polyline points="6 9 12 15 18 9"/></svg>
                                    </div>
                                    <div style="font-size:12px;color:var(--body-text2);"><%= item.deskripsi %></div>
                                </td>
                                <td>
                                    <% if(item.status==='Solved'){%>
                                        <span class="badge-solved">Solved</span>
                                    <%}else{%>
                                        <span class="badge-pending">Pending</span>
                                    <%}%>
                                </td>
                                <td style="min-width:110px;" onclick="event.stopPropagation()">
                                    <% if(item.fotoAwalUrl){%>
                                        <button class="btn-foto btn-foto-awal" onclick="showFoto('<%= item.fotoAwalUrl %>','Kondisi AWAL')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Awal</button>
                                    <%}%>
                                    <% if(item.fotoUrl){%>
                                        <button class="btn-foto btn-foto-sesudah" onclick="showFoto('<%= item.fotoUrl %>','Kondisi SESUDAH')"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Sesudah</button>
                                    <%}%>
                                    <% if(!item.fotoAwalUrl && !item.fotoUrl){%>
                                        <span style="color:var(--body-text3);font-size:12px;">—</span>
                                    <%}%>
                                </td>
                            </tr>
                            <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL FOTO -->
    <div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="background:var(--body-card);border:0.5px solid var(--body-border);">
                <div class="modal-header" style="border-color:var(--body-border);">
                    <h5 class="modal-title" style="color:var(--body-text);font-size:14px;" id="fotoModalLabel">Dokumentasi</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-3">
                    <img id="popupImage" src="" class="img-fluid rounded" style="max-height:75vh;">
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDetail(row) {
            var isActive = row.classList.contains('row-active');

            // Tutup semua detail row yang terbuka
            document.querySelectorAll('.detail-row').forEach(function(r) { r.remove(); });
            document.querySelectorAll('.row-active').forEach(function(r) { r.classList.remove('row-active'); });

            if (isActive) return; // klik row sama = tutup

            row.classList.add('row-active');

            var d = row.dataset;
            var aktivitas  = decodeURIComponent(d.aktivitas  || '');
            var deskripsi  = decodeURIComponent(d.deskripsi  || '');
            var divisi     = decodeURIComponent(d.divisi     || '');
            var pemesan    = decodeURIComponent(d.pemesan    || '');
            var status     = d.status    || '';
            var durasi     = d.durasi    || '';
            var fotoAwal   = d.fotoAwal  || '';
            var fotoSesudah= d.fotoSesudah || '';

            var colCount = row.cells.length;

            // Foto buttons HTML
            var fotoHtml = '';
            if (fotoAwal) {
                fotoHtml += '<button class="btn-foto btn-foto-awal" style="width:auto;margin-right:6px;" onclick="showFoto(\'' + fotoAwal + '\',\'Kondisi AWAL\')">'
                    + '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto Awal</button>';
            }
            if (fotoSesudah) {
                fotoHtml += '<button class="btn-foto btn-foto-sesudah" style="width:auto;" onclick="showFoto(\'' + fotoSesudah + '\',\'Kondisi SESUDAH\')">'
                    + '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto Sesudah</button>';
            }
            if (!fotoAwal && !fotoSesudah) fotoHtml = '<span style="color:var(--body-text3);font-size:12px;">Tidak ada foto</span>';

            var badgeHtml = status === 'Solved'
                ? '<span class="badge-solved">Solved</span>'
                : '<span class="badge-pending">Pending</span>';

            var detailHtml = '<tr class="detail-row"><td colspan="' + colCount + '">'
                + '<div class="detail-inner">'
                + '<div class="detail-item"><div class="detail-label">Aktivitas</div><div class="detail-value" style="font-weight:600;">' + escHtml(aktivitas) + '</div></div>'
                + '<div class="detail-item"><div class="detail-label">Deskripsi</div><div class="detail-value">' + escHtml(deskripsi || '—') + '</div></div>'
                + '<div class="detail-item"><div class="detail-label">Divisi</div><div class="detail-value">' + escHtml(divisi) + '</div></div>'
                + '<div class="detail-item"><div class="detail-label">User / Pemesan</div><div class="detail-value">' + escHtml(pemesan) + '</div></div>'
                + '<div class="detail-item"><div class="detail-label">Status</div><div class="detail-value">' + badgeHtml + '</div></div>'
                + (durasi ? '<div class="detail-item"><div class="detail-label">Durasi</div><div class="detail-value">' + escHtml(durasi) + '</div></div>' : '')
                + '<div class="detail-item" style="grid-column:1/-1;"><div class="detail-label">Dokumentasi</div><div class="detail-value" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;">' + fotoHtml + '</div></div>'
                + '</div></td></tr>';

            row.insertAdjacentHTML('afterend', detailHtml);
        }

        function escHtml(str) {
            return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function showFoto(url, judul) {
            document.getElementById('popupImage').src = url;
            // FIX: Pisah SVG (innerHTML) dan judul teks (createTextNode) untuk cegah XSS
            var label = document.getElementById('fotoModalLabel');
            label.innerHTML = '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> ';
            label.appendChild(document.createTextNode(judul || 'Dokumentasi'));
            // FIX: Reuse instance modal agar tidak menumpuk di memory
            var modalEl = document.getElementById('fotoModal');
            var existing = bootstrap.Modal.getInstance(modalEl);
            if (existing) { existing.dispose(); }
            new bootstrap.Modal(modalEl).show();
        }

        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function() {
                navigator.serviceWorker.register('/sw.js').catch(function() {});
            });
        }

        // SKELETON → TABEL
        // Sembunyiin skeleton, tampilkan tabel asli setelah semua konten siap
        document.addEventListener('DOMContentLoaded', function() {
            var skeleton = document.getElementById('skeletonTable');
            var realTable = document.getElementById('realTable');
            // Simulasi minimum shimmer 400ms biar keliatan (UX feel)
            var minDelay = 400;
            var start = Date.now();
            function reveal() {
                var elapsed = Date.now() - start;
                var remaining = Math.max(0, minDelay - elapsed);
                setTimeout(function() {
                    if (skeleton) {
                        skeleton.style.transition = 'opacity 0.25s ease';
                        skeleton.style.opacity = '0';
                        setTimeout(function() { skeleton.style.display = 'none'; }, 250);
                    }
                    if (realTable) {
                        realTable.classList.remove('is-loading');
                        realTable.style.opacity = '0';
                        realTable.style.transition = 'opacity 0.25s ease';
                        setTimeout(function() { realTable.style.opacity = '1'; }, 20);
                    }
                }, remaining);
            }
            // Kalau gambar/resource masih loading, tunggu window load
            if (document.readyState === 'complete') {
                reveal();
            } else {
                window.addEventListener('load', reveal);
                // Fallback maksimal 1.5 detik
                setTimeout(reveal, 1500);
            }
        });
    </script>
</body>
</html>
