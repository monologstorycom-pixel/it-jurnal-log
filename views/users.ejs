<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen User — IT Support Log</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0f1117">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { background: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', -apple-system, sans-serif; margin: 0; transition: background 0.25s, color 0.25s; }
        .page-wrap { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }

        /* FORM PANEL */
        .form-panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; padding: 1.25rem; position: sticky; top: 72px; }
        .form-panel h6 { font-size: 0.78rem; font-weight: 700; color: #4ade80; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; }
        .f-label { display: block; font-size: 0.68rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
        .f-input { background: var(--body-input) !important; border: 1px solid var(--body-input-border) !important; border-radius: 6px; color: var(--body-text) !important; padding: 8px 10px; width: 100%; margin-bottom: 0.65rem; font-size: 0.83rem; outline: none; transition: border-color 0.15s; }
        .f-input:focus { border-color: var(--body-input-focus) !important; }
        .btn-add { background: #1a3a2a; border: 1px solid #2d6a4a; color: #4ade80; width: 100%; padding: 9px; border-radius: 6px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all 0.15s; margin-top: 4px; }
        .btn-add:hover { background: #224a36; }

        /* PERMISSIONS GRID */
        .perm-section { margin-bottom: 0.75rem; }
        .perm-section-title { font-size: 0.65rem; font-weight: 700; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 6px; }
        .perm-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }
        .perm-check { display: flex; align-items: center; gap: 7px; padding: 6px 9px; background: var(--body-bg); border: 1px solid var(--body-border); border-radius: 6px; cursor: pointer; transition: all 0.15s; user-select: none; }
        .perm-check:hover { border-color: var(--body-border2); }
        .perm-check.checked { border-color: #2d6a4a; background: #0d2a18; }
        .perm-check.checked-delete { border-color: #5c1a1a; background: #2a0d0d; }
        .perm-check.checked-users { border-color: #4c3780; background: #1a0d3d; }
        .perm-check.checked-viewlog { border-color: #0e4d6a; background: #0d2234; }
        .perm-check.checked-audit { border-color: #92400e; background: #2d1a00; }
        .perm-check.checked-vendor { border-color: #0d3d6e; background: #0d1a38; }
        .perm-check input[type="checkbox"] { display: none; }
        .perm-box { width: 16px; height: 16px; border: 1.5px solid var(--body-border2); border-radius: 3px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s; font-size: 10px; }
        .perm-check.checked .perm-box { background: #4ade80; border-color: #4ade80; color: #0d2a18; }
        .perm-check.checked-delete .perm-box { background: #f87171; border-color: #f87171; color: #2a0d0d; }
        .perm-check.checked-users .perm-box { background: #a78bfa; border-color: #a78bfa; color: #1a0d3d; }
        .perm-check.checked-viewlog .perm-box { background: #67e8f9; border-color: #67e8f9; color: #0d2234; }
        .perm-check.checked-audit .perm-box { background: #f59e0b; border-color: #f59e0b; color: #2d1a00; }
        .perm-check.checked-vendor .perm-box { background: #4da6ff; border-color: #4da6ff; color: #0d1a38; }
        .perm-label-text { font-size: 0.72rem; font-weight: 600; color: var(--body-text2); }
        .perm-check.checked .perm-label-text { color: #4ade80; }
        .perm-check.checked-delete .perm-label-text { color: #f87171; }
        .perm-check.checked-users .perm-label-text { color: #a78bfa; }
        .perm-check.checked-viewlog .perm-label-text { color: #67e8f9; }
        .perm-check.checked-audit .perm-label-text { color: #f59e0b; }
        .perm-check.checked-vendor .perm-label-text { color: #4da6ff; }
        .perm-icon { display:inline-flex; align-items:center; justify-content:center; width:16px; height:16px; flex-shrink:0; }
        .perm-icon .lc { width:12px !important; height:12px !important; flex-shrink:0; }
        .pt .lc { width:8px !important; height:8px !important; vertical-align:0; flex-shrink:0; }

        /* PRESET BUTTONS */
        .preset-row { display: flex; gap: 5px; margin-bottom: 0.75rem; flex-wrap: wrap; }
        .preset-btn { padding: 4px 10px; border-radius: 4px; font-size: 0.68rem; font-weight: 700; cursor: pointer; border: 1px solid; transition: all 0.15s; }
        .preset-admin  { background: #1a0d3d; color: #a78bfa; border-color: #4c3780; }
        .preset-admin:hover { background: #250f50; }
        .preset-user   { background: #0d2a18; color: #4ade80; border-color: #2d6a4a; }
        .preset-user:hover { background: #0f3020; }
        .preset-viewer { background: #0d1a38; color: #7eb8f7; border-color: #2a3d6a; }
        .preset-viewer:hover { background: #0f2040; }
        .preset-clear  { background: var(--body-bg); color: var(--body-text2); border-color: var(--body-border); }
        .preset-clear:hover { border-color: var(--body-border2); color: var(--body-text); }

        /* MAIN PANEL */
        .main-panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; overflow: hidden; }
        .panel-header { padding: 1rem 1.25rem; border-bottom: 1px solid var(--body-border); }
        .panel-title { font-size: 0.82rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.07em; }

        /* TABLE */
        .user-table { width: 100%; border-collapse: collapse; }
        .user-table th { padding: 10px 14px; font-size: 0.65rem; font-weight: 700; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--body-border); background: var(--body-bg); text-align: left; white-space: nowrap; }
        .user-table td { padding: 11px 14px; font-size: 0.83rem; color: var(--body-text); border-bottom: 1px solid var(--body-border); vertical-align: middle; }
        .user-table tr:last-child td { border-bottom: none; }
        .user-table tr:hover td { background: var(--body-bg3); }

        /* PERM TAGS inline di tabel */
        .perm-tags { display: flex; flex-wrap: wrap; gap: 3px; }
        .pt { display: inline-flex; align-items:center; gap:3px; padding: 1px 6px; border-radius: 3px; font-size: 0.6rem; font-weight: 700; line-height:1.6; }
        .pt-view   { background: #0d1a38; color: #7eb8f7; border: 1px solid #1a2d5c; }
        .pt-add    { background: #0d2a18; color: #4ade80; border: 1px solid #1a5c30; }
        .pt-edit   { background: #0d2210; color: #86efac; border: 1px solid #145c28; }
        .pt-delete { background: #2a0d0d; color: #f87171; border: 1px solid #5c1a1a; }
        .pt-asset  { background: #1a1a0d; color: #fde68a; border: 1px solid #5c4a00; }
        .pt-export { background: #1a0d2a; color: #d8b4fe; border: 1px solid #4c1a7a; }
        .pt-users  { background: #1a0d3d; color: #a78bfa; border: 1px solid #4c3780; }
        .pt-viewlog { background: #0d2234; color: #67e8f9; border: 1px solid #0e4d6a; }
        .pt-audit  { background: #2d1a00; color: #f59e0b; border: 1px solid #92400e; }
        .pt-vendor { background: #0d1a38; color: #4da6ff; border: 1px solid #0d3d6e; }

        /* ROLE BADGE */
        .role-admin  { display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.65rem;font-weight:700;background:#1a0d3d;color:#a78bfa;border:1px solid #4c3780; }
        .role-user   { display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.65rem;font-weight:700;background:#0d2a18;color:#4ade80;border:1px solid #1a5c30; }
        .role-viewer { display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.65rem;font-weight:700;background:#1a2a3a;color:#7eb8f7;border:1px solid #2a4a6a; }
        .role-custom { display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.65rem;font-weight:700;background:#2a1a0d;color:#fb923c;border:1px solid #5c3010; }

        /* ACTION BTN */
        .act-btn { background: none; border: 1px solid var(--body-border); color: var(--body-text2); padding: 4px 9px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; cursor: pointer; transition: all 0.12s; }
        .act-btn.blue:hover  { border-color: #2a3d6a; color: #7eb8f7; background: #0d1a38; }
        .act-btn.red:hover   { border-color: #5c1a1a; color: #f87171; background: #2a0d0d; }

        /* MODAL */
        .m-content { background: var(--body-card) !important; border: 1px solid var(--body-border) !important; }
        .m-header  { border-bottom: 1px solid var(--body-border) !important; }
        .m-footer  { border-top: 1px solid var(--body-border) !important; }
        .m-content .modal-title { color: var(--body-text) !important; }

        /* ALERT */
        .alert-success-custom { background: #0d2a18; border: 1px solid #1a5c30; color: #4ade80; border-radius: 8px; padding: 10px 14px; font-size: 0.82rem; font-weight: 600; margin-bottom: 1rem; }
        .alert-error-custom   { background: #2a0d0d; border: 1px solid #5c1a1a; color: #f87171; border-radius: 8px; padding: 10px 14px; font-size: 0.82rem; font-weight: 600; margin-bottom: 1rem; }
        .you-badge { display: inline-block; background: #1a2a0d; color: #86efac; border: 1px solid #2d5c1a; border-radius: 3px; padding: 1px 6px; font-size: 0.6rem; font-weight: 700; margin-left: 6px; vertical-align: middle; }

        /* PASS STRENGTH */
        .pass-strength { height: 3px; border-radius: 2px; margin-top: 4px; margin-bottom: 0.65rem; background: var(--body-border); overflow: hidden; }
        .pass-strength-fill { height: 100%; border-radius: 2px; transition: width 0.3s, background 0.3s; width: 0%; }

        @media (max-width: 768px) { .page-wrap { padding: 1rem; } .form-panel { position: static; margin-bottom: 1rem; } .perm-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
<%- include('navbar', {activePage: 'users'}) %>

<div class="page-wrap">
  <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="<%= msgType === 'error' ? 'alert-error-custom' : 'alert-success-custom' %>">
      <%- msgType === 'error' ? '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' : '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>' %> <%= msg %>
    </div>
  <% } %>

  <div class="row g-4">

    <!-- FORM SIDEBAR -->
    <div class="col-md-4">
      <div class="form-panel">
        <h6>+ Tambah User Baru</h6>
        <form action="/users/tambah" method="POST" id="formTambah">

          <label class="f-label">Nama Lengkap</label>
          <input type="text" name="nama" class="f-input" placeholder="cth: Rizqi Subagyo" required>

          <label class="f-label">Username</label>
          <input type="text" name="username" class="f-input" placeholder="huruf kecil, tanpa spasi" required pattern="[a-z0-9_]+" title="Hanya huruf kecil, angka, underscore">

          <label class="f-label">Password</label>
          <input type="password" name="password" id="newPass" class="f-input" placeholder="Min 6 karakter" required minlength="6" oninput="checkStrength(this.value, 'passStrengthBar')">
          <div class="pass-strength"><div class="pass-strength-fill" id="passStrengthBar"></div></div>

          <label class="f-label">Label Role <span style="color:var(--body-text3);font-size:0.62rem;font-weight:400;">(bebas, hanya untuk tampilan)</span></label>
          <input type="text" name="role" class="f-input" placeholder="cth: IT Support, Supervisor, Operator..." value="user">

          <label class="f-label">Divisi <span style="color:var(--body-text3);font-size:0.62rem;font-weight:400;">(menentukan akses data aset)</span></label>
          <input type="text" name="divisi" class="f-input" placeholder="cth: IT, GA, FINANCE, HR..." value="IT" style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()">

          <!-- PERMISSION BUILDER -->
          <div style="border: 1px solid var(--body-border); border-radius: 8px; padding: 10px; margin-bottom: 0.75rem; background: var(--body-bg);">
            <div style="font-size:0.68rem;font-weight:700;color:var(--body-text2);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:8px;">
              <svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Hak Akses
            </div>

            <!-- PRESET BUTTONS -->
            <div class="preset-row">
              <button type="button" class="preset-btn preset-admin"  onclick="setPreset('add', 'admin')">Admin</button>
              <button type="button" class="preset-btn preset-user"   onclick="setPreset('add', 'user')">User</button>
              <button type="button" class="preset-btn preset-viewer" onclick="setPreset('add', 'viewer')">Viewer</button>
              <button type="button" class="preset-btn preset-clear"  onclick="setPreset('add', 'clear')">Clear</button>
            </div>

            <div class="perm-grid" id="permGrid_add">
              <div class="perm-check" id="lbl_add_canView" data-form="add" data-perm="canView">
                <input type="checkbox" name="canView" id="add_canView">
                <div class="perm-box" id="box_add_canView"></div>
                <span class="perm-label-text">Lihat</span>
              </div>
              <div class="perm-check" id="lbl_add_canAdd" data-form="add" data-perm="canAdd">
                <input type="checkbox" name="canAdd" id="add_canAdd">
                <div class="perm-box" id="box_add_canAdd"></div>
                <span class="perm-label-text">Tambah</span>
              </div>
              <div class="perm-check" id="lbl_add_canEdit" data-form="add" data-perm="canEdit">
                <input type="checkbox" name="canEdit" id="add_canEdit">
                <div class="perm-box" id="box_add_canEdit"></div>
                <span class="perm-label-text">Edit</span>
              </div>
              <div class="perm-check" id="lbl_add_canDelete" data-form="add" data-perm="canDelete">
                <input type="checkbox" name="canDelete" id="add_canDelete">
                <div class="perm-box" id="box_add_canDelete"></div>
                <span class="perm-label-text">Hapus</span>
              </div>
              <div class="perm-check" id="lbl_add_canAsset" data-form="add" data-perm="canAsset">
                <input type="checkbox" name="canAsset" id="add_canAsset">
                <div class="perm-box" id="box_add_canAsset"></div>
                <span class="perm-label-text">Aset</span>
              </div>
              <div class="perm-check" id="lbl_add_canExport" data-form="add" data-perm="canExport">
                <input type="checkbox" name="canExport" id="add_canExport">
                <div class="perm-box" id="box_add_canExport"></div>
                <span class="perm-label-text">Export</span>
              </div>
              <div class="perm-check" id="lbl_add_canUsers" data-form="add" data-perm="canUsers">
                <input type="checkbox" name="canUsers" id="add_canUsers">
                <div class="perm-box" id="box_add_canUsers"></div>
                <span class="perm-label-text">Kelola User</span>
              </div>
              <div class="perm-check" id="lbl_add_canViewLog" data-form="add" data-perm="canViewLog">
                <input type="checkbox" name="canViewLog" id="add_canViewLog">
                <div class="perm-box" id="box_add_canViewLog"></div>
                <span class="perm-label-text">Lihat Log</span>
              </div>
              <div class="perm-check" id="lbl_add_canAudit" data-form="add" data-perm="canAudit" style="border:1px solid #7c3aed33;background:rgba(124,58,237,0.06);">
                <input type="checkbox" name="canAudit" id="add_canAudit">
                <div class="perm-box" id="box_add_canAudit"></div>
                <span class="perm-label-text">Audit (Lht Smua Aset)</span>
              </div>
              <!-- TAMBAHAN: Akses Vendor -->
              <div class="perm-check" id="lbl_add_canVendor" data-form="add" data-perm="canVendor" style="border:1px solid #1e3a8a33;background:rgba(30,58,138,0.06);">
                <input type="checkbox" name="canVendor" id="add_canVendor">
                <div class="perm-box" id="box_add_canVendor"></div>
                <span class="perm-label-text">Akses Vendor</span>
              </div>
            </div>
          </div>

          <button type="submit" class="btn-add">SIMPAN USER</button>
        </form>
      </div>
    </div>

    <!-- TABLE -->
    <div class="col-md-8">
      <div class="main-panel">
        <div class="panel-header">
          <div class="panel-title">Daftar User (<%= users.length %> akun)</div>
        </div>
        <div style="overflow-x:auto;">
          <table class="user-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Nama</th>
                <th>Username</th>
                <th>Divisi</th>
                <th>Hak Akses</th>
                <th>Dibuat</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((u, i) => {
                let perms = {};
                if (u.permissions) {
                  try { perms = JSON.parse(u.permissions); } catch(e) {}
                }
                if (!Object.keys(perms).length) {
                  const defaults = {
                    admin:  { canView:true,canAdd:true,canEdit:true,canDelete:true,canAsset:true,canExport:true,canUsers:true,canViewLog:true,canVendor:true },
                    user:   { canView:true,canAdd:true,canEdit:true,canDelete:false,canAsset:true,canExport:true,canUsers:false,canViewLog:true,canVendor:false },
                    viewer: { canView:true,canAdd:false,canEdit:false,canDelete:false,canAsset:false,canExport:false,canUsers:false,canViewLog:true,canVendor:false }
                  };
                  perms = defaults[u.role] || defaults.viewer;
                }
              %>
              <tr>
                <td style="color:var(--body-text3);font-size:0.75rem;"><%= i+1 %></td>
                <td>
                  <strong><%= u.nama %></strong>
                  <% if (currentUser && u.id === currentUser.id) { %><span class="you-badge">KAMU</span><% } %>
                  <div style="font-size:0.72rem;margin-top:3px;">
                    <span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.65rem;font-weight:700;background:var(--body-bg);color:var(--body-text2);border:1px solid var(--body-border2);"><%= u.role %></span>
                  </div>
                </td>
                <td><code style="color:#4ade80;background:var(--body-bg);padding:2px 6px;border-radius:3px;font-size:0.78rem;"><%= u.username %></code></td>
                <td>
                  <span style="display:inline-block;padding:2px 9px;border-radius:4px;font-size:0.68rem;font-weight:700;background:var(--body-bg3);color:var(--body-text2);border:1px solid var(--body-border2);letter-spacing:0.05em;">
                    <%= u.divisi || 'IT' %>
                  </span>
                </td>
                <td>
                  <div class="perm-tags">
                    <% if(perms.canView)   { %><span class="pt pt-view"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Lihat</span><% } %>
                    <% if(perms.canAdd)    { %><span class="pt pt-add"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Tambah</span><% } %>
                    <% if(perms.canEdit)   { %><span class="pt pt-edit"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</span><% } %>
                    <% if(perms.canDelete) { %><span class="pt pt-delete"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg> Hapus</span><% } %>
                    <% if(perms.canAsset)  { %><span class="pt pt-asset"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg> Aset</span><% } %>
                    <% if(perms.canExport) { %><span class="pt pt-export"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Export</span><% } %>
                    <% if(perms.canUsers)  { %><span class="pt pt-users"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg> User</span><% } %>
                    <% if(perms.canViewLog){ %><span class="pt pt-viewlog"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> Lihat Log</span><% } %>
                    <% if(perms.canAudit)  { %><span class="pt pt-audit"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Audit</span><% } %>
                    <% if(perms.canVendor) { %><span class="pt pt-vendor"><svg class="lc" width="8" height="8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg> Vendor</span><% } %>
                  </div>
                </td>
                <td style="color:var(--body-text2);font-size:0.75rem;white-space:nowrap;">
                  <%= new Date(u.createdAt).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                </td>
                <td>
                  <div style="display:flex;gap:5px;">
                    <button class="act-btn blue" onclick="openEditModal(
                      <%= u.id %>,
                      `<%= u.nama.replace(/`/g,'\\`') %>`,
                      `<%= u.username %>`,
                      `<%= u.role %>`,
                      `<%= u.divisi || 'IT' %>`,
                      <%= JSON.stringify(perms) %>
                    )">Edit</button>
                    <% if (!currentUser || u.id !== currentUser.id) { %>
                    <button class="act-btn red" onclick="confirmHapus(<%= u.id %>, `<%= u.nama.replace(/`/g,'\\`') %>`)">Hapus</button>
                    <% } else { %>
                    <button class="act-btn" style="opacity:0.3;cursor:not-allowed;" disabled>Hapus</button>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL EDIT USER -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content m-content">
      <div class="modal-header m-header">
        <h5 class="modal-title"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formEdit" action="" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="f-label">Nama Lengkap</label>
              <input type="text" name="nama" id="edit_nama" class="f-input" required>
              <label class="f-label">Username</label>
              <input type="text" name="username" id="edit_username" class="f-input" required pattern="[a-z0-9_]+">
              <label class="f-label">Label Role <span style="color:var(--body-text3);font-size:0.62rem;font-weight:400;">(bebas, hanya untuk tampilan)</span></label>
              <input type="text" name="role" id="edit_role" class="f-input" placeholder="cth: IT Support, Supervisor...">
              <label class="f-label">Divisi <span style="color:var(--body-text3);font-size:0.62rem;font-weight:400;">(menentukan akses data aset)</span></label>
              <input type="text" name="divisi" id="edit_divisi" class="f-input" placeholder="cth: IT, GA, FINANCE..." style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()">
              <label class="f-label">Password Baru <span style="color:var(--body-text3);font-size:0.6rem;font-weight:400;">(kosongkan jika tidak diganti)</span></label>
              <input type="password" name="password" id="edit_pass" class="f-input" placeholder="Min 6 karakter (opsional)" minlength="6" oninput="checkStrength(this.value, 'passStrengthBarEdit')">
              <div class="pass-strength"><div class="pass-strength-fill" id="passStrengthBarEdit"></div></div>
            </div>
            <div class="col-md-6">
              <!-- PERMISSION BUILDER EDIT -->
              <div style="border: 1px solid var(--body-border); border-radius: 8px; padding: 10px; background: var(--body-bg); height: 100%;">
                <div style="font-size:0.68rem;font-weight:700;color:var(--body-text2);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:8px;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Hak Akses</div>
                <div class="preset-row">
                  <button type="button" class="preset-btn preset-admin"  onclick="setPreset('edit', 'admin')">Admin</button>
                  <button type="button" class="preset-btn preset-user"   onclick="setPreset('edit', 'user')">User</button>
                  <button type="button" class="preset-btn preset-viewer" onclick="setPreset('edit', 'viewer')">Viewer</button>
                  <button type="button" class="preset-btn preset-clear"  onclick="setPreset('edit', 'clear')">Clear</button>
                </div>
                <div class="perm-grid" id="permGrid_edit">
                  <div class="perm-check" id="lbl_edit_canView" data-form="edit" data-perm="canView">
                    <input type="checkbox" name="canView" id="edit_canView">
                    <div class="perm-box" id="box_edit_canView"></div><span class="perm-label-text">Lihat</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canAdd" data-form="edit" data-perm="canAdd">
                    <input type="checkbox" name="canAdd" id="edit_canAdd">
                    <div class="perm-box" id="box_edit_canAdd"></div><span class="perm-label-text">Tambah</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canEdit" data-form="edit" data-perm="canEdit">
                    <input type="checkbox" name="canEdit" id="edit_canEdit">
                    <div class="perm-box" id="box_edit_canEdit"></div><span class="perm-label-text">Edit</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canDelete" data-form="edit" data-perm="canDelete">
                    <input type="checkbox" name="canDelete" id="edit_canDelete">
                    <div class="perm-box" id="box_edit_canDelete"></div><span class="perm-label-text">Hapus</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canAsset" data-form="edit" data-perm="canAsset">
                    <input type="checkbox" name="canAsset" id="edit_canAsset">
                    <div class="perm-box" id="box_edit_canAsset"></div><span class="perm-label-text">Aset</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canExport" data-form="edit" data-perm="canExport">
                    <input type="checkbox" name="canExport" id="edit_canExport">
                    <div class="perm-box" id="box_edit_canExport"></div><span class="perm-label-text">Export</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canUsers" data-form="edit" data-perm="canUsers">
                    <input type="checkbox" name="canUsers" id="edit_canUsers">
                    <div class="perm-box" id="box_edit_canUsers"></div><span class="perm-label-text">Kelola User</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canViewLog" data-form="edit" data-perm="canViewLog">
                    <input type="checkbox" name="canViewLog" id="edit_canViewLog">
                    <div class="perm-box" id="box_edit_canViewLog"></div><span class="perm-label-text">Lihat Log</span>
                  </div>
                  <div class="perm-check" id="lbl_edit_canAudit" data-form="edit" data-perm="canAudit" style="border:1px solid #7c3aed33;background:rgba(124,58,237,0.06);">
                    <input type="checkbox" name="canAudit" id="edit_canAudit">
                    <div class="perm-box" id="box_edit_canAudit"></div><span class="perm-label-text">Audit (Lht Smua Aset)</span>
                  </div>
                  <!-- TAMBAHAN: Akses Vendor Edit -->
                  <div class="perm-check" id="lbl_edit_canVendor" data-form="edit" data-perm="canVendor" style="border:1px solid #1e3a8a33;background:rgba(30,58,138,0.06);">
                    <input type="checkbox" name="canVendor" id="edit_canVendor">
                    <div class="perm-box" id="box_edit_canVendor"></div>
                    <span class="perm-label-text">Akses Vendor</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer m-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary fw-bold">Simpan Perubahan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- MODAL HAPUS -->
<div class="modal fade" id="hapusModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content m-content" style="border-color:#5c1a1a !important;">
      <div class="modal-header" style="border-color:#5c1a1a;">
        <h5 class="modal-title"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg> Hapus User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p style="color:var(--body-text);" class="mb-2">Yakin hapus user ini?</p>
        <p id="hapusNama" style="color:#f87171;font-weight:700;font-size:0.95rem;"></p>
        <p style="color:var(--body-text2);font-size:0.8rem;"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> Tidak bisa dikembalikan.</p>
      </div>
      <div class="modal-footer" style="border-color:#5c1a1a;">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <form id="formHapus" action="" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-danger fw-bold">Ya, Hapus</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ===========================
// PERMISSION STATE
// ===========================
var permState = {
  add:  { canView:false, canAdd:false, canEdit:false, canDelete:false, canAsset:false, canExport:false, canUsers:false, canViewLog:false, canAudit:false, canVendor:false },
  edit: { canView:false, canAdd:false, canEdit:false, canDelete:false, canAsset:false, canExport:false, canUsers:false, canViewLog:false, canAudit:false, canVendor:false }
};

var PRESETS = {
  admin:  { canView:true, canAdd:true, canEdit:true, canDelete:true, canAsset:true, canExport:true, canUsers:true, canViewLog:true, canAudit:false, canVendor:true },
  user:   { canView:true, canAdd:true, canEdit:true, canDelete:false, canAsset:true, canExport:true, canUsers:false, canViewLog:true, canAudit:false, canVendor:false },
  viewer: { canView:true, canAdd:false, canEdit:false, canDelete:false, canAsset:false, canExport:false, canUsers:false, canViewLog:true, canAudit:false, canVendor:false },
  clear:  { canView:false, canAdd:false, canEdit:false, canDelete:false, canAsset:false, canExport:false, canUsers:false, canViewLog:false, canAudit:false, canVendor:false }
};

var PERM_KEYS = ['canView','canAdd','canEdit','canDelete','canAsset','canExport','canUsers','canViewLog','canAudit','canVendor'];

// Toggle satu permission
function togglePerm(form, perm) {
  permState[form][perm] = !permState[form][perm];
  renderPerms(form);
  syncCheckboxes(form);
}

// Set preset
function setPreset(form, preset) {
  permState[form] = Object.assign({}, PRESETS[preset]);
  renderPerms(form);
  syncCheckboxes(form);
}

// Set dari object (untuk load data edit)
function setPermState(form, obj) {
  permState[form] = Object.assign({}, PRESETS.clear, obj);
  renderPerms(form);
  syncCheckboxes(form);
}

// Render visual state ke DOM
function renderPerms(form) {
  PERM_KEYS.forEach(function(perm) {
    var val = permState[form][perm];
    var el  = document.getElementById('lbl_' + form + '_' + perm);
    var box = document.getElementById('box_' + form + '_' + perm);
    if (!el || !box) return;

    el.className = 'perm-check';
    box.textContent = '';

    if (val) {
      if (perm === 'canDelete') {
        el.className = 'perm-check checked-delete';
      } else if (perm === 'canUsers') {
        el.className = 'perm-check checked-users';
      } else if (perm === 'canViewLog') {
        el.className = 'perm-check checked-viewlog';
      } else if (perm === 'canAudit') {
        el.className = 'perm-check checked-audit';
      } else if (perm === 'canVendor') {
        el.className = 'perm-check checked-vendor';
      } else {
        el.className = 'perm-check checked';
      }
      box.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    }
  });
}

// Sync hidden checkbox values (untuk dikirim form)
function syncCheckboxes(form) {
  PERM_KEYS.forEach(function(perm) {
    var input = document.getElementById(form + '_' + perm);
    if (input) input.checked = permState[form][perm];
  });
}

// ===========================
// PASANG CLICK LISTENER — pakai event delegation
// Attach SETELAH DOM ready, satu listener per grid
// ===========================
document.addEventListener('DOMContentLoaded', function() {
  // Pasang listener ke semua div.perm-check yang punya data-form dan data-perm
  document.querySelectorAll('.perm-check[data-form][data-perm]').forEach(function(el) {
    el.addEventListener('click', function(e) {
      // Cegah event bubble ke mana-mana
      e.stopPropagation();
      var form = el.getAttribute('data-form');
      var perm = el.getAttribute('data-perm');
      togglePerm(form, perm);
    });
  });

  // Init default: form tambah mulai dengan preset user
  setPreset('add', 'user');
});

// ===========================
// MODALS
// ===========================
function openEditModal(id, nama, username, role, divisi, perms) {
  document.getElementById('formEdit').action     = '/users/edit/' + id;
  document.getElementById('edit_nama').value     = nama;
  document.getElementById('edit_username').value = username;
  document.getElementById('edit_role').value     = role;
  document.getElementById('edit_divisi').value   = divisi || 'IT';
  document.getElementById('edit_pass').value     = '';
  document.getElementById('passStrengthBarEdit').style.width = '0%';
  setPermState('edit', perms || {});
  new bootstrap.Modal(document.getElementById('editModal')).show();
}

function confirmHapus(id, nama) {
  document.getElementById('formHapus').action = '/users/hapus/' + id;
  document.getElementById('hapusNama').textContent = '"' + nama + '"';
  new bootstrap.Modal(document.getElementById('hapusModal')).show();
}

// ===========================
// PASSWORD STRENGTH
// ===========================
function checkStrength(v, barId) {
  var el = document.getElementById(barId);
  if (!v) { el.style.width = '0%'; return; }
  var score = 0;
  if (v.length >= 6)  score++;
  if (v.length >= 10) score++;
  if (/[A-Z]/.test(v)) score++;
  if (/[0-9]/.test(v)) score++;
  if (/[^a-zA-Z0-9]/.test(v)) score++;
  var pct = Math.min(100, score * 20);
  var colors = ['#f87171','#fb923c','#fbbf24','#4ade80','#22c55e'];
  el.style.width = pct + '%';
  el.style.background = colors[Math.max(0, score - 1)] || '#f87171';
}
</script>
<script src="/offline-sync.js"></script>
<script>
if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
        navigator.serviceWorker.register('/sw.js').catch(function() {});
    });
}
</script>
</body>
</html>