<!-- ===== MODAL TAMBAH ASET ===== -->
<div class="modal fade" id="modalTambahAset" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:520px;margin:1rem auto;">
    <div class="modal-content" style="background:var(--body-card);border:1px solid var(--body-border);border-radius:14px;max-height:90vh;display:flex;flex-direction:column;">
      <div class="modal-header" style="border-color:var(--body-border);padding:14px 20px;flex-shrink:0;">
        <h6 class="modal-title" style="color:#4ade80;font-weight:700;font-size:0.85rem;letter-spacing:0.06em;text-transform:uppercase;margin:0;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Tambah Aset Baru
        </h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/aset/tambah" method="POST" enctype="multipart/form-data" style="display:flex;flex-direction:column;flex:1;min-height:0;">
        <div class="modal-body" style="padding:20px;overflow-y:auto;flex:1;">

          <!-- FOTO -->
          <label class="f-label"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto Aset <span style="font-weight:400;text-transform:none;color:var(--body-text3);">(maks 3)</span></label>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:0.75rem;">
            <div>
              <div class="foto-preview-box" style="height:80px;" onclick="document.getElementById('mAddFoto1').click()">
                <img id="mAddFoto1Preview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;">
                <div class="foto-preview-placeholder" id="mAddFoto1Ph"><span class="icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></span><span style="font-size:0.65rem;">Foto 1</span></div>
              </div>
              <input type="file" id="mAddFoto1" name="foto" accept="image/*" style="display:none;" onchange="previewFoto(this,'mAddFoto1Preview','mAddFoto1Ph')">
            </div>
            <div>
              <div class="foto-preview-box" style="height:80px;" onclick="document.getElementById('mAddFoto2').click()">
                <img id="mAddFoto2Preview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;">
                <div class="foto-preview-placeholder" id="mAddFoto2Ph"><span class="icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></span><span style="font-size:0.65rem;">Foto 2</span></div>
              </div>
              <input type="file" id="mAddFoto2" name="foto2" accept="image/*" style="display:none;" onchange="previewFoto(this,'mAddFoto2Preview','mAddFoto2Ph')">
            </div>
            <div>
              <div class="foto-preview-box" style="height:80px;" onclick="document.getElementById('mAddFoto3').click()">
                <img id="mAddFoto3Preview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;">
                <div class="foto-preview-placeholder" id="mAddFoto3Ph"><span class="icon"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></span><span style="font-size:0.65rem;">Foto 3</span></div>
              </div>
              <input type="file" id="mAddFoto3" name="foto3" accept="image/*" style="display:none;" onchange="previewFoto(this,'mAddFoto3Preview','mAddFoto3Ph')">
            </div>
          </div>

          <label class="f-label">Nama Aset *</label>
          <input type="text" name="nama" class="f-input" placeholder="cth: Switch TP-Link 8 Port" required>

          <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <label class="f-label">Divisi Aset</label>
          <input type="text" name="divisi" class="f-input" placeholder="IT, GA, HR, FINANCE..." value="<%= typeof userDivisi !== 'undefined' ? userDivisi : 'IT' %>" style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()">
          <% } else { %>
          <input type="hidden" name="divisi" value="<%= typeof userDivisi !== 'undefined' ? userDivisi : 'IT' %>">
          <% } %>

          <label class="f-label">Kategori</label>
          <input type="text" name="kategori" class="f-input" placeholder="Jaringan, Komputer, Aksesoris..." list="kategoriListM">
          <datalist id="kategoriListM">
            <option value="Jaringan"><option value="Komputer"><option value="Aksesoris">
            <option value="Kabel"><option value="Printer"><option value="CCTV">
            <option value="Telepon"><option value="ATK"><option value="Lainnya">
          </datalist>

          <label class="f-label">Satuan *</label>
          <input type="text" name="satuan" class="f-input" placeholder="pcs / unit / meter..." list="satuanListM" required>
          <datalist id="satuanListM">
            <option value="pcs"><option value="unit"><option value="meter">
            <option value="bungkus"><option value="roll"><option value="box">
            <option value="set"><option value="rim"><option value="pack"><option value="pasang">
          </datalist>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div>
              <label class="f-label">Jumlah Stok *</label>
              <input type="number" name="stok" class="f-input" min="0" value="1" required>
            </div>
            <div>
              <label class="f-label">Kondisi</label>
              <select name="kondisi" class="f-input">
                <option value="Baik">Baik</option>
                <option value="Perlu Service">Perlu Service</option>
                <option value="Rusak">Rusak</option>
              </select>
            </div>
          </div>

          <label class="f-label">Keterangan</label>
          <textarea name="keterangan" class="f-input" rows="2" placeholder="Merk, seri, catatan..."></textarea>
        </div>
        <div class="modal-footer" style="border-color:var(--body-border);padding:12px 20px;flex-shrink:0;">
          <button type="button" class="btn btn-sm fw-bold" data-bs-dismiss="modal" style="background:var(--body-bg3);border:1px solid var(--body-border);color:var(--body-text2);">Batal</button>
          <button type="submit" class="btn-add" style="width:auto;margin:0;padding:8px 24px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:5px;"><polyline points="20 6 9 17 4 12"/></svg>
            Simpan Aset
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

</body>
