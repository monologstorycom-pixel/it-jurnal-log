// ===== MODAL EDIT =====
function openModalEdit(id, nama, kat, sat, stok, kon, ket, f1, f2, f3) {
    document.getElementById('formEdit').action = '/aset/edit/' + id;
    document.getElementById('eNama').value = nama;
    document.getElementById('eKat').value  = kat;
    document.getElementById('eSat').value  = sat;
    document.getElementById('eStok').value = stok;
    document.getElementById('eKon').value  = kon;
    document.getElementById('eKet').value  = ket;

    // Reset checkbox hapus
    ['editCbHapus1','editCbHapus2','editCbHapus3'].forEach(function(cbId) {
        var cb = document.getElementById(cbId);
        if (cb) cb.checked = false;
    });

    // Set preview foto existing
    setEditFotoPreview('editFoto1Preview', 'editFoto1Placeholder', 'editHapus1Wrap', f1);
    setEditFotoPreview('editFoto2Preview', 'editFoto2Placeholder', 'editHapus2Wrap', f2);
    setEditFotoPreview('editFoto3Preview', 'editFoto3Placeholder', 'editHapus3Wrap', f3);

    new bootstrap.Modal(document.getElementById('modalEdit')).show();
}

function setEditFotoPreview(imgId, phId, hapusWrapId, url) {
    var img  = document.getElementById(imgId);
    var ph   = document.getElementById(phId);
    var wrap = document.getElementById(hapusWrapId);
    if (url && url !== 'null' && url !== '') {
        img.src = url; img.style.display = 'block';
        if (ph)   ph.style.display = 'none';
        if (wrap) wrap.style.display = 'block';
    } else {
        img.src = ''; img.style.display = 'none';
        if (ph)   ph.style.display = '';
        if (wrap) wrap.style.display = 'none';
    }
}

function toggleHapusFoto(cb, imgId, phId, wrapId) {
    var img = document.getElementById(imgId);
    var ph  = document.getElementById(phId);
    if (cb.checked) {
        img.src = ''; img.style.display = 'none';
        if (ph) ph.style.display = '';
    }
}

// ===== HAPUS ASET =====
function hapusAset(id, nama) {
    document.getElementById('formHapus').action = '/aset/hapus/' + id;
    document.getElementById('hapusNama').textContent = '"' + nama + '"';
    new bootstrap.Modal(document.getElementById('modalHapus')).show();
}

function openModalService(id, nama) {
    document.getElementById('formService').action = '/aset/service/' + id;
    document.getElementById('serviceInfo').innerHTML = '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg> Service: ' + nama;
    document.getElementById('serviceTgl').value = new Date().toISOString().split('T')[0];
    
    // Reset dropdown vendor
    document.getElementById('esVendorSelectMain').value = '';
    document.getElementById('esVendorMain').value = '';
    document.getElementById('esVendorMain').style.display = 'none';

    // Reset foto preview
    document.getElementById('serviceFotoPreview').style.display = 'none';
    document.getElementById('serviceFotoPlaceholder').style.display = 'flex';
    new bootstrap.Modal(document.getElementById('modalService')).show();
}
</script>
