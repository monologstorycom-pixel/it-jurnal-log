<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Aset IT</title>
    <link rel="manifest" href="/manifest.json">
        <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="icon" type="image/png" href="/icon-512.png">
    <meta name="theme-color" content="#161b22">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #0d0d0d !important; color: #fff; font-family: 'Inter', sans-serif; margin: 0; }
        .app-nav { border-bottom: 2px solid #262626; padding: 1rem 2rem; background: #161b22; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        .nav-links a { color: #aaa; text-decoration: none; font-size: 0.85rem; font-weight: 600; margin-left: 1.5rem; }
        .nav-links a:hover, .nav-links a.active { color: #fff; }
        .input-custom { background: #1a1a1a !important; border: 1px solid #444 !important; border-radius: 6px; color: #fff !important; padding: 10px; width: 100%; margin-bottom: 0.75rem; font-size: 0.85rem; }
        .input-custom:focus { outline: none; border-color: #888 !important; }
        .label-text { color: #878787; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 4px; display: block; }
        .card-aset { background: #161b22; border: 1px solid #2a2a2a; border-radius: 10px; padding: 1rem 1.25rem; transition: border-color 0.2s; }
        .card-aset:hover { border-color: #444; }
        .stok-num { font-size: 1.8rem; font-weight: 800; line-height: 1; }
        .stok-label { font-size: 0.7rem; color: #666; font-weight: 600; text-transform: uppercase; }
        .badge-kondisi-baik    { background: #0d2a0d; color: #4caf50; border: 1px solid #1a5c1a; }
        .badge-kondisi-rusak   { background: #2a0d0d; color: #f44336; border: 1px solid #5c1a1a; }
        .badge-kondisi-service { background: #2a200d; color: #ff9800; border: 1px solid #5c3d0d; }
        .badge-kondisi { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.68rem; font-weight: 700; }
        .stok-bar { height: 4px; background: #222; border-radius: 2px; margin-top: 6px; overflow: hidden; }
        .stok-bar-fill { height: 100%; border-radius: 2px; transition: width 0.3s; }
        .btn-sm-dark { background: #1a1a1a; border: 1px solid #444; color: #fff; padding: 4px 10px; border-radius: 4px; font-size: 0.7rem; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-block; }
        .btn-sm-dark:hover { background: #333; color: #fff; }
        .search-box { background: #1a1a1a; border: 1px solid #333; border-radius: 8px; padding: 8px 14px; color: #fff; width: 260px; font-size: 0.85rem; }
        .search-box:focus { outline: none; border-color: #555; }
        .empty-state { text-align: center; padding: 3rem; color: #555; }
        @media (max-width: 768px) { .app-nav { padding: 1rem; } .search-box { width: 100%; } }
    </style>
</head>
<body>
<nav class="app-nav">
    <div style="font-weight:700;">>_ IT SUPPORT LOG</div>
    <div class="nav-links">
        <a href="/kerja">Dashboard</a>
        <a href="/aset" class="active">Aset IT</a>
        <a href="/">Viewer</a>
    </div>
</nav>

<div class="container-fluid p-4">
    <div class="row">

        <!-- SIDEBAR FORM TAMBAH -->
        <div class="col-md-3 mb-4">
            <div style="background:#161b22;border:1px solid #2a2a2a;border-radius:10px;padding:1.25rem;">
                <div style="font-weight:700;font-size:0.9rem;margin-bottom:1rem;color:#fff;">➕ Tambah Aset Baru</div>
                <form action="/aset/tambah" method="POST">
                    <span class="label-text">Nama Aset</span>
                    <input type="text" name="nama" class="input-custom" placeholder="cth: Switch TP-Link" required>

                    <span class="label-text">Kategori</span>
                    <input type="text" name="kategori" class="input-custom" placeholder="cth: Jaringan, Komputer, Aksesoris" list="kategoriList">
                    <datalist id="kategoriList">
                        <option value="Jaringan">
                        <option value="Komputer">
                        <option value="Aksesoris">
                        <option value="Kabel">
                        <option value="Printer">
                        <option value="CCTV">
                        <option value="Telepon">
                        <option value="Software">
                        <option value="Lainnya">
                    </datalist>

                    <span class="label-text">Satuan</span>
                    <input type="text" name="satuan" class="input-custom" placeholder="cth: pcs, meter, unit, bungkus" list="satuanList" required>
                    <datalist id="satuanList">
                        <option value="pcs">
                        <option value="unit">
                        <option value="meter">
                        <option value="bungkus">
                        <option value="roll">
                        <option value="box">
                        <option value="set">
                        <option value="buah">
                        <option value="pasang">
                    </datalist>

                    <span class="label-text">Jumlah Stok</span>
                    <input type="number" name="stok" class="input-custom" min="0" value="1" required>

                    <span class="label-text">Kondisi</span>
                    <select name="kondisi" class="input-custom">
                        <option value="Baik">Baik</option>
                        <option value="Perlu Service">Perlu Service</option>
                        <option value="Rusak">Rusak</option>
                    </select>

                    <span class="label-text">Keterangan (opsional)</span>
                    <textarea name="keterangan" class="input-custom" rows="2" placeholder="Merk, seri, atau info tambahan..."></textarea>

                    <button type="submit" class="btn btn-light w-100 fw-bold mt-1">SIMPAN ASET</button>
                </form>
            </div>
        </div>

        <!-- DAFTAR ASET -->
        <div class="col-md-9">
            <!-- HEADER & FILTER -->
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <div>
                    <h5 style="font-weight:700;margin:0;">📦 Inventaris Aset IT</h5>
                    <small style="color:#666;"><%= aset.length %> aset terdaftar</small>
                </div>
                <form action="/aset" method="GET" class="d-flex gap-2 flex-wrap align-items-center">
                    <input type="text" name="q" value="<%= q %>" class="search-box" placeholder="🔍 Cari nama / kategori...">
                    <select name="kategori" class="input-custom" style="width:150px;margin:0;">
                        <option value="">Semua Kategori</option>
                        <% allKategori.forEach(k => { %>
                            <option value="<%= k %>" <%= kategori === k ? 'selected' : '' %>><%= k %></option>
                        <% }) %>
                    </select>
                    <button type="submit" class="btn btn-sm btn-primary fw-bold">CARI</button>
                    <% if (q || kategori) { %><a href="/aset" class="btn btn-sm btn-outline-secondary text-white">RESET</a><% } %>
                </form>
            </div>

            <% if (aset.length === 0) { %>
                <div class="empty-state">
                    <div style="font-size:2rem;margin-bottom:1rem;">📦</div>
                    <p style="font-size:1rem;">Belum ada aset terdaftar.</p>
                    <p style="font-size:0.85rem;">Tambahkan aset pertama menggunakan form di kiri.</p>
                </div>
            <% } else { %>
            <div class="row g-3">
                <% aset.forEach(item => { %>
                <%
                    const pct = item.stokAwal > 0 ? Math.round((item.stok / item.stokAwal) * 100) : 0;
                    const barColor = pct > 50 ? '#4caf50' : pct > 20 ? '#ff9800' : '#f44336';
                    const kondisiClass = item.kondisi === 'Baik' ? 'badge-kondisi-baik' : item.kondisi === 'Rusak' ? 'badge-kondisi-rusak' : 'badge-kondisi-service';
                %>
                <div class="col-md-6 col-lg-4">
                    <div class="card-aset h-100">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div style="flex:1;">
                                <div style="font-weight:700;font-size:0.95rem;color:#fff;"><%= item.nama %></div>
                                <div style="font-size:0.72rem;color:#666;margin-top:2px;"><%= item.kategori %></div>
                            </div>
                            <span class="badge-kondisi <%= kondisiClass %>"><%= item.kondisi %></span>
                        </div>

                        <!-- STOK -->
                        <div class="d-flex align-items-baseline gap-2 mt-2">
                            <span class="stok-num" style="color:<%= barColor %>"><%= item.stok %></span>
                            <span style="color:#555;font-size:0.8rem;">/ <%= item.stokAwal %> <%= item.satuan %></span>
                            <% if (item._count.pinjaman > 0) { %>
                                <span style="background:#1a0d2a;color:#c9aaff;border:1px solid #6b3dbf;border-radius:3px;padding:1px 6px;font-size:0.62rem;font-weight:700;"><%= item._count.pinjaman %> dipinjam</span>
                            <% } %>
                        </div>
                        <div class="stok-bar">
                            <div class="stok-bar-fill" style="width:<%= pct %>%;background:<%= barColor %>;"></div>
                        </div>

                        <% if (item.keterangan) { %>
                            <div style="font-size:0.75rem;color:#555;margin-top:8px;"><%= item.keterangan %></div>
                        <% } %>

                        <!-- AKSI -->
                        <div class="d-flex gap-2 mt-3 flex-wrap">
                            <a href="/aset/<%= item.id %>" class="btn-sm-dark" style="background:#0d3d0d;border-color:#1a5c1a;color:#4caf50;">📋 Riwayat</a>
                            <button class="btn-sm-dark" style="background:#0d1a3d;border-color:#1a2d5c;color:#64b5f6;"
                                onclick="openModalPakai(<%= item.id %>, '<%= item.nama.replace(/'/g, `\\'`) %>', <%= item.stok %>, '<%= item.satuan %>')">
                                🔧 Pakai
                            </button>
                            <button class="btn-sm-dark" style="background:#1a0d3d;border-color:#3d1a5c;color:#c9aaff;"
                                onclick="openModalPinjam(<%= item.id %>, '<%= item.nama.replace(/'/g, `\\'`) %>', <%= item.stok %>, '<%= item.satuan %>')">
                                📤 Pinjam
                            </button>
                            <button class="btn-sm-dark"
                                onclick="openModalEdit(<%= item.id %>, '<%= item.nama.replace(/'/g, `\\'`) %>', '<%= item.kategori %>', '<%= item.satuan %>', <%= item.stokAwal %>, '<%= item.kondisi %>', `<%- (item.keterangan || '').replace(/`/g,'\\`') %>`)">
                                ✏️ Edit
                            </button>
                            <button class="btn-sm-dark" style="background:#2a0d0d;border-color:#5c1a1a;color:#f44336;"
                                onclick="hapusAset(<%= item.id %>, '<%= item.nama.replace(/'/g, `\\'`) %>')">
                                🗑️
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- MODAL PAKAI -->
<div class="modal fade" id="modalPakai" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-success">
            <div class="modal-header border-success">
                <h5 class="modal-title text-white" id="modalPakaiTitle">🔧 Catat Penggunaan</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formPakai" action="" method="POST">
                <div class="modal-body">
                    <div id="pakaiStokInfo" style="background:#0d2a0d;border:1px solid #1a5c1a;border-radius:6px;padding:10px;margin-bottom:1rem;font-size:0.85rem;color:#4caf50;font-weight:700;"></div>
                    <span class="label-text">Jumlah Digunakan</span>
                    <input type="number" name="jumlah" class="input-custom" min="1" value="1" required id="pakaiJumlah">
                    <span class="label-text">Dipasang di Divisi</span>
                    <select name="divisi" class="input-custom">
                        <option value="IT & IC">IT &amp; IC</option>
                        <option value="HRGA">HRGA</option>
                        <option value="Accounting">Accounting</option>
                        <option value="Exim & Pembelian">Exim &amp; Pembelian</option>
                        <option value="Operasional">Operasional</option>
                        <option value="Finance">Finance</option>
                        <option value="Produksi">Produksi</option>
                        <option value="Bahanbaku">Bahanbaku</option>
                        <option value="MAINTENANCE">MAINTENANCE</option>
                        <option value="Admin Sales">Admin Sales</option>
                    </select>
                    <span class="label-text">Lokasi Pemasangan</span>
                    <input type="text" name="lokasi" class="input-custom" placeholder="cth: Ruang server lt.1, Meja kepala HRD" required>
                    <span class="label-text">Tanggal Pemasangan</span>
                    <input type="date" name="tanggal" class="input-custom" id="pakaiTanggal">
                    <span class="label-text">Keterangan (opsional)</span>
                    <textarea name="keterangan" class="input-custom" rows="2" placeholder="Info tambahan..."></textarea>
                </div>
                <div class="modal-footer border-success">
                    <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
                    <button type="submit" class="btn btn-success fw-bold">CATAT PENGGUNAAN</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL PINJAM -->
<div class="modal fade" id="modalPinjam" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark" style="border:1px solid #6b3dbf;">
            <div class="modal-header" style="border-bottom:1px solid #6b3dbf;">
                <h5 class="modal-title text-white" id="modalPinjamTitle">📤 Catat Peminjaman</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formPinjam" action="" method="POST">
                <div class="modal-body">
                    <div id="pinjamStokInfo" style="background:#1a0d3d;border:1px solid #6b3dbf;border-radius:6px;padding:10px;margin-bottom:1rem;font-size:0.85rem;color:#c9aaff;font-weight:700;"></div>
                    <span class="label-text">Jumlah Dipinjam</span>
                    <input type="number" name="jumlah" class="input-custom" min="1" value="1" required>
                    <span class="label-text">Nama Peminjam</span>
                    <input type="text" name="peminjam" class="input-custom" placeholder="cth: Roby, Bagyo" required>
                    <span class="label-text">Dari Divisi</span>
                    <select name="divisi" class="input-custom">
                        <option value="IT & IC">IT &amp; IC</option>
                        <option value="HRGA">HRGA</option>
                        <option value="Accounting">Accounting</option>
                        <option value="Exim & Pembelian">Exim &amp; Pembelian</option>
                        <option value="Operasional">Operasional</option>
                        <option value="Finance">Finance</option>
                        <option value="Produksi">Produksi</option>
                        <option value="Bahanbaku">Bahanbaku</option>
                        <option value="MAINTENANCE">MAINTENANCE</option>
                        <option value="Admin Sales">Admin Sales</option>
                    </select>
                    <span class="label-text">Keperluan</span>
                    <textarea name="keperluan" class="input-custom" rows="2" placeholder="cth: Presentasi jobfair, Transfer data..." required></textarea>
                    <span class="label-text">Tanggal Pinjam</span>
                    <input type="date" name="tanggalPinjam" class="input-custom" id="pinjamTanggal">
                </div>
                <div class="modal-footer" style="border-top:1px solid #6b3dbf;">
                    <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
                    <button type="submit" class="btn fw-bold" style="background:#6b3dbf;color:#fff;">CATAT PINJAMAN</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL EDIT -->
<div class="modal fade" id="modalEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white">✏️ Edit Aset</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formEdit" action="" method="POST">
                <div class="modal-body">
                    <span class="label-text">Nama Aset</span>
                    <input type="text" name="nama" id="editNama" class="input-custom" required>
                    <span class="label-text">Kategori</span>
                    <input type="text" name="kategori" id="editKategori" class="input-custom" list="kategoriList">
                    <span class="label-text">Satuan</span>
                    <input type="text" name="satuan" id="editSatuan" class="input-custom" list="satuanList" required>
                    <span class="label-text">Stok Awal (total yang dimiliki)</span>
                    <input type="number" name="stokAwal" id="editStokAwal" class="input-custom" min="0" required>
                    <div style="background:#1a1a0d;border:1px solid #444;border-radius:6px;padding:8px;margin-bottom:0.75rem;font-size:0.78rem;color:#aaa;">
                        ⚠️ Mengubah stok awal akan otomatis menyesuaikan stok sisa (dikurangi total penggunaan & pinjaman aktif)
                    </div>
                    <span class="label-text">Kondisi</span>
                    <select name="kondisi" id="editKondisi" class="input-custom">
                        <option value="Baik">Baik</option>
                        <option value="Perlu Service">Perlu Service</option>
                        <option value="Rusak">Rusak</option>
                    </select>
                    <span class="label-text">Keterangan</span>
                    <textarea name="keterangan" id="editKeterangan" class="input-custom" rows="2"></textarea>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
                    <button type="submit" class="btn btn-primary fw-bold">SIMPAN</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL HAPUS -->
<div class="modal fade" id="modalHapus" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-danger">
            <div class="modal-header border-danger">
                <h5 class="modal-title text-white">🗑️ Hapus Aset</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-white">Yakin hapus aset ini?</p>
                <p id="hapusNama" class="fw-bold" style="color:#f44336;"></p>
                <p class="text-secondary" style="font-size:0.8rem;">⚠️ Semua riwayat penggunaan dan pinjaman aset ini juga akan terhapus.</p>
            </div>
            <div class="modal-footer border-danger">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">BATAL</button>
                <form id="formHapus" action="" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger fw-bold">YA, HAPUS</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
var today = new Date().toISOString().split('T')[0];
document.getElementById('pakaiTanggal').value = today;
document.getElementById('pinjamTanggal').value = today;

function openModalPakai(id, nama, stok, satuan) {
    document.getElementById('formPakai').action = '/aset/pakai/' + id;
    document.getElementById('modalPakaiTitle').textContent = '🔧 Pakai: ' + nama;
    document.getElementById('pakaiStokInfo').textContent = 'Stok tersedia: ' + stok + ' ' + satuan;
    document.getElementById('pakaiJumlah').max = stok;
    new bootstrap.Modal(document.getElementById('modalPakai')).show();
}
function openModalPinjam(id, nama, stok, satuan) {
    document.getElementById('formPinjam').action = '/aset/pinjam/' + id;
    document.getElementById('modalPinjamTitle').textContent = '📤 Pinjam: ' + nama;
    document.getElementById('pinjamStokInfo').textContent = 'Stok tersedia: ' + stok + ' ' + satuan;
    new bootstrap.Modal(document.getElementById('modalPinjam')).show();
}
function openModalEdit(id, nama, kategori, satuan, stokAwal, kondisi, keterangan) {
    document.getElementById('formEdit').action = '/aset/edit/' + id;
    document.getElementById('editNama').value = nama;
    document.getElementById('editKategori').value = kategori;
    document.getElementById('editSatuan').value = satuan;
    document.getElementById('editStokAwal').value = stokAwal;
    document.getElementById('editKondisi').value = kondisi;
    document.getElementById('editKeterangan').value = keterangan;
    new bootstrap.Modal(document.getElementById('modalEdit')).show();
}
function hapusAset(id, nama) {
    document.getElementById('formHapus').action = '/aset/hapus/' + id;
    document.getElementById('hapusNama').textContent = '"' + nama + '"';
    new bootstrap.Modal(document.getElementById('modalHapus')).show();
}
</script>
</body>
</html>
