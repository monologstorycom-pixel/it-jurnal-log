<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventaris Aset IT</title>
    <link rel="manifest" href="/manifest.json">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { background: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', -apple-system, sans-serif; margin: 0; transition: background 0.25s, color 0.25s; }
        .page-wrap { max-width: 1500px; margin: 0 auto; padding: 1.5rem; }

        /* SIDEBAR */
        .form-panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; padding: 1.25rem; position: sticky; top: 72px; }
        .form-panel h6 { font-size: 0.78rem; font-weight: 700; color: #4ade80; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; }
        .f-label { display: block; font-size: 0.68rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
        .f-input { background: var(--body-input) !important; border: 1px solid var(--body-input-border) !important; border-radius: 6px; color: var(--body-text) !important; padding: 8px 10px; width: 100%; margin-bottom: 0.65rem; font-size: 0.83rem; outline: none; transition: border-color 0.15s; }
        .f-input:focus { border-color: var(--body-input-focus) !important; }
        .btn-add { background: #1a3a2a; border: 1px solid #2d6a4a; color: #4ade80; width: 100%; padding: 9px; border-radius: 6px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all 0.15s; margin-top: 4px; }
        .btn-add:hover { background: #224a36; }

        /* FOTO PREVIEW di sidebar */
        .foto-preview-box {
            width: 100%; height: 120px; border: 1px dashed var(--body-border2);
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            margin-bottom: 0.65rem; overflow: hidden; background: var(--body-bg);
            cursor: pointer; position: relative; transition: border-color 0.15s;
        }
        .foto-preview-box:hover { border-color: #4ade80; }
        .foto-preview-box img { width: 100%; height: 100%; object-fit: cover; }
        .foto-preview-placeholder { text-align: center; color: var(--body-text3); font-size: 0.75rem; }
        .foto-preview-placeholder .icon { font-size: 1.8rem; margin-bottom: 4px; display: block; }

        /* MAIN TABLE */
        .main-panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; overflow: hidden; }
        .panel-header { padding: 1rem 1.25rem; border-bottom: 1px solid var(--body-border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
        .panel-title { font-size: 0.82rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.07em; }
        .panel-count { font-size: 0.78rem; color: var(--body-text3); }
        .search-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
        .s-input { background: var(--body-input); border: 1px solid var(--body-input-border); border-radius: 6px; color: var(--body-text); padding: 6px 10px; font-size: 0.8rem; outline: none; }
        .s-input:focus { border-color: var(--body-input-focus); }
        .s-btn { background: var(--body-bg2); border: 1px solid var(--body-border); color: var(--body-text2); padding: 6px 12px; border-radius: 6px; font-size: 0.78rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
        .s-btn:hover { border-color: var(--body-border2); color: var(--body-text); }
        .s-btn-primary { background: #1a2a4a; border-color: #2a3d6a; color: #7eb8f7; }
        .s-btn-export { background: #2a1a0a; border-color: #5a3a1a; color: #f5a623; }

        /* TABLE */
        .aset-table { width: 100%; border-collapse: collapse; }
        .aset-table thead tr { background: var(--body-bg); }
        .aset-table th { padding: 10px 14px; text-align: left; font-size: 0.67rem; font-weight: 700; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--body-border); white-space: nowrap; }
        .aset-table tbody tr { border-bottom: 1px solid var(--body-border); transition: background 0.1s; }
        .aset-table tbody tr:hover { background: var(--body-bg3); }
        .aset-table td { padding: 11px 14px; font-size: 0.83rem; color: var(--body-text); vertical-align: middle; }
        .aset-name { font-weight: 600; color: var(--body-text); }

        /* FOTO THUMBNAIL di tabel */
        .aset-thumb {
            width: 44px; height: 44px; border-radius: 8px; object-fit: cover;
            border: 1px solid var(--body-border); cursor: pointer;
            transition: transform 0.15s, border-color 0.15s;
        }
        .aset-thumb:hover { transform: scale(1.08); border-color: #4ade80; }
        .aset-no-foto {
            width: 44px; height: 44px; border-radius: 8px;
            background: var(--body-bg3); border: 1px dashed var(--body-border2);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; color: var(--body-text3);
        }

        /* STOK */
        .stok-val { font-weight: 700; font-size: 0.95rem; }
        .stok-mini-bar { width: 60px; height: 3px; background: var(--body-border); border-radius: 2px; margin-top: 4px; overflow: hidden; display: inline-block; }
        .stok-mini-fill { height: 100%; border-radius: 2px; }

        /* BADGES */
        .badge-kondisi { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.04em; }
        .k-baik    { background: #0d2a18; color: #4ade80; border: 1px solid #1a5c30; }
        .k-rusak   { background: #2a0d0d; color: #f87171; border: 1px solid #5c1a1a; }
        .k-service { background: #2a1a0d; color: #fb923c; border: 1px solid #5c3010; }
        .badge-pinjam { display: inline-block; background: #1a0d3d; color: #a78bfa; border: 1px solid #4c3780; border-radius: 3px; padding: 1px 6px; font-size: 0.62rem; font-weight: 700; margin-left: 4px; }

        /* ACTION BTNS */
        .act-btn { background: none; border: 1px solid var(--body-border); color: var(--body-text2); padding: 4px 9px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; cursor: pointer; transition: all 0.12s; white-space: nowrap; }
        .act-btn:hover { border-color: var(--body-border2); color: var(--body-text); }
        .act-btn.green:hover  { border-color: #2d6a4a; color: #4ade80; background: #0d2a18; }
        .act-btn.blue:hover   { border-color: #2a3d6a; color: #7eb8f7; background: #0d1a38; }
        .act-btn.purple:hover { border-color: #4c3780; color: #a78bfa; background: #1a0d3d; }
        .act-btn.red:hover    { border-color: #5c1a1a; color: #f87171; background: #2a0d0d; }

        /* MODAL */
        .m-content { background: var(--body-card) !important; border: 1px solid var(--body-border) !important; }
        .m-header  { border-bottom: 1px solid var(--body-border) !important; }
        .m-footer  { border-top: 1px solid var(--body-border) !important; }
        .m-content .modal-title { color: var(--body-text); }

        /* FOTO UPLOAD di MODAL */
        .modal-foto-area {
            border: 1px dashed var(--body-border2); border-radius: 8px;
            overflow: hidden; margin-bottom: 0.65rem; cursor: pointer;
            transition: border-color 0.15s; position: relative;
        }
        .modal-foto-area:hover { border-color: #4ade80; }
        .modal-foto-placeholder {
            padding: 1.25rem; text-align: center; color: var(--body-text3); font-size: 0.78rem;
        }
        .modal-foto-placeholder .icon { font-size: 2rem; display: block; margin-bottom: 6px; }
        .modal-foto-preview { width: 100%; max-height: 180px; object-fit: cover; display: none; }
        .modal-foto-area input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; }

        .empty-row td { text-align: center; padding: 3rem; color: var(--body-text3); font-size: 0.85rem; }

        @media (max-width: 768px) { .page-wrap { padding: 1rem; } .form-panel { position: static; margin-bottom: 1rem; } }
    </style>
</head>
<body>
<%- include('navbar', {activePage: 'aset'}) %>

<div class="page-wrap">
  <div class="row g-4">

    <!-- ========== FORM SIDEBAR ========== -->
    <div class="col-md-3">
      <div class="form-panel">
        <h6>+ Tambah Aset</h6>
        <form action="/aset/tambah" method="POST" enctype="multipart/form-data">

          <!-- FOTO ASET -->
          <label class="f-label">📷 Foto Aset</label>
          <div class="foto-preview-box" onclick="document.getElementById('addFotoInput').click()">
            <img id="addFotoPreview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;">
            <div class="foto-preview-placeholder" id="addFotoPlaceholder">
              <span class="icon">📷</span>
              <span>Klik untuk ambil / pilih foto</span>
            </div>
          </div>
          <input type="file" id="addFotoInput" name="foto" accept="image/*" capture="environment" style="display:none;"
            onchange="previewFoto(this, 'addFotoPreview', 'addFotoPlaceholder')">
          <small class="compress-msg" style="display:none;color:#22c55e;font-weight:600;">✅ Foto dikompres!</small>

          <label class="f-label">Nama Aset</label>
          <input type="text" name="nama" class="f-input" placeholder="cth: Switch TP-Link 8 Port" required>
          <label class="f-label">Kategori</label>
          <input type="text" name="kategori" class="f-input" placeholder="Jaringan, Komputer, Aksesoris..." list="kategoriList">
          <datalist id="kategoriList">
            <option value="Jaringan"><option value="Komputer"><option value="Aksesoris">
            <option value="Kabel"><option value="Printer"><option value="CCTV">
            <option value="Telepon"><option value="ATK"><option value="Lainnya">
          </datalist>
          <label class="f-label">Satuan</label>
          <input type="text" name="satuan" class="f-input" placeholder="pcs / unit / meter..." list="satuanList" required>
          <datalist id="satuanList">
            <option value="pcs"><option value="unit"><option value="meter">
            <option value="bungkus"><option value="roll"><option value="box">
            <option value="set"><option value="rim"><option value="pack"><option value="pasang">
          </datalist>
          <label class="f-label">Jumlah Stok</label>
          <input type="number" name="stok" class="f-input" min="0" value="1" required>
          <label class="f-label">Kondisi</label>
          <select name="kondisi" class="f-input">
            <option value="Baik">Baik</option>
            <option value="Perlu Service">Perlu Service</option>
            <option value="Rusak">Rusak</option>
          </select>
          <label class="f-label">Keterangan</label>
          <textarea name="keterangan" class="f-input" rows="2" placeholder="Merk, seri, catatan..."></textarea>
          <button type="submit" class="btn-add">SIMPAN ASET</button>
        </form>
      </div>
    </div>

    <!-- ========== MAIN TABLE ========== -->
    <div class="col-md-9">
      <div class="main-panel">
        <div class="panel-header">
          <div>
            <div class="panel-title">Inventaris Aset IT</div>
            <div class="panel-count"><%= aset.length %> item terdaftar</div>
          </div>
          <div class="search-row">
            <form action="/aset" method="GET" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
              <input type="text" name="q" value="<%= q %>" class="s-input" placeholder="Cari nama / kategori..." style="width:180px;">
              <select name="kategori" class="s-input">
                <option value="">Semua Kategori</option>
                <% allKategori.forEach(k => { %><option value="<%= k %>" <%= kategori === k ? 'selected' : '' %>><%= k %></option><% }) %>
              </select>
              <button type="submit" class="s-btn s-btn-primary">Cari</button>
              <% if (q || kategori) { %><a href="/aset" class="s-btn">Reset</a><% } %>
            </form>
            <a href="/aset/export-pdf" target="_blank" class="s-btn s-btn-export">⬇ Export PDF</a>
          </div>
        </div>

        <div style="overflow-x:auto;">
          <table class="aset-table">
            <thead>
              <tr>
                <th style="width:32px;">#</th>
                <th style="width:60px;">Foto</th>
                <th>Nama Aset</th>
                <th>Kategori</th>
                <th>Kondisi</th>
                <th>Stok Awal</th>
                <th>Stok Sisa</th>
                <th>Dipinjam</th>
                <th style="width:220px;">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if(aset.length === 0) { %>
                <tr class="empty-row"><td colspan="9">Belum ada aset. Tambahkan menggunakan form di kiri.</td></tr>
              <% } %>
              <% aset.forEach((item, i) => {
                const pct = item.stokAwal > 0 ? Math.round((item.stok / item.stokAwal) * 100) : 0;
                const barColor = pct > 50 ? '#4ade80' : pct > 20 ? '#fb923c' : '#f87171';
                const kondisiClass = item.kondisi === 'Baik' ? 'k-baik' : item.kondisi === 'Rusak' ? 'k-rusak' : 'k-service';
              %>
              <tr>
                <td style="color:var(--body-text3);font-size:0.75rem;"><%= i+1 %></td>
                <td>
                  <% if(item.fotoUrl) { %>
                    <img src="<%= item.fotoUrl %>" class="aset-thumb"
                      onclick="showFotoModal('<%= item.fotoUrl %>', '<%= item.nama.replace(/'/g, `\\'`) %>')"
                      alt="<%= item.nama %>">
                  <% } else { %>
                    <div class="aset-no-foto" title="Belum ada foto">📦</div>
                  <% } %>
                </td>
                <td>
                  <div class="aset-name"><%= item.nama %></div>
                  <% if(item.keterangan){%><div style="font-size:0.72rem;color:var(--body-text3);margin-top:2px;"><%= item.keterangan %></div><%}%>
                </td>
                <td><span style="font-size:0.75rem;color:var(--body-text2);"><%= item.kategori || '—' %></span></td>
                <td><span class="badge-kondisi <%= kondisiClass %>"><%= item.kondisi %></span></td>
                <td style="color:var(--body-text2);font-size:0.82rem;"><%= item.stokAwal %> <span style="color:var(--body-text3);"><%= item.satuan %></span></td>
                <td>
                  <div class="stok-val" style="color:<%= barColor %>"><%= item.stok %> <span style="font-size:0.72rem;color:var(--body-text3);font-weight:400;"><%= item.satuan %></span></div>
                  <div><div class="stok-mini-bar"><div class="stok-mini-fill" style="width:<%= pct %>%;background:<%= barColor %>;"></div></div></div>
                </td>
                <td>
                  <% if(item.pinjaman && item.pinjaman.length > 0) { %>
                    <span class="badge-pinjam"><%= item.pinjaman.length %> item</span>
                  <% } else { %>
                    <span style="color:var(--body-border2);font-size:0.75rem;">—</span>
                  <% } %>
                </td>
                <td>
                  <div style="display:flex;gap:5px;flex-wrap:wrap;">
                    <a href="/aset/<%= item.id %>" class="act-btn green">Riwayat</a>
                    <button class="act-btn blue" onclick="openModalPakai(<%= item.id %>, '<%= item.nama.replace(/'/g,`\\'`) %>', <%= item.stok %>, '<%= item.satuan %>')">Pakai</button>
                    <button class="act-btn purple" onclick="openModalPinjam(<%= item.id %>, '<%= item.nama.replace(/'/g,`\\'`) %>', <%= item.stok %>, '<%= item.satuan %>')">Pinjam</button>
                    <button class="act-btn" onclick="openModalEdit(<%= item.id %>, '<%= item.nama.replace(/'/g,`\\'`) %>', '<%= item.kategori %>', '<%= item.satuan %>', <%= item.stokAwal %>, '<%= item.kondisi %>', `<%- (item.keterangan||'').replace(/`/g,'\\`') %>`)">Edit</button>
                    <button class="act-btn red" onclick="hapusAset(<%= item.id %>, '<%= item.nama.replace(/'/g,`\\'`) %>')">Hapus</button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== MODAL LIHAT FOTO ========== -->
<div class="modal fade" id="modalFoto" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content m-content">
      <div class="modal-header m-header">
        <h5 class="modal-title" id="modalFotoTitle">Foto Aset</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-3">
        <img id="modalFotoImg" src="" class="img-fluid rounded" style="max-height:75vh;">
      </div>
    </div>
  </div>
</div>

<!-- ========== MODAL PAKAI ========== -->
<div class="modal fade" id="modalPakai" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content m-content">
      <div class="modal-header m-header"><h5 class="modal-title" id="modalPakaiTitle">Catat Penggunaan</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form id="formPakai" action="" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div id="pakaiInfo" style="background:#0d2a18;border:1px solid #1a5c30;border-radius:6px;padding:9px 12px;margin-bottom:1rem;font-size:0.82rem;color:#4ade80;font-weight:700;"></div>

          <!-- FOTO PENGGUNAAN -->
          <label class="f-label">📷 Foto Pemasangan / Lokasi</label>
          <div class="modal-foto-area" id="pakaiAreaFoto">
            <img id="pakaiFotoPreview" class="modal-foto-preview" alt="">
            <div class="modal-foto-placeholder" id="pakaiFotoPlaceholder">
              <span class="icon">📸</span>
              Foto kondisi aset saat dipasang (opsional)
            </div>
            <input type="file" name="foto" accept="image/*" capture="environment"
              onchange="previewModalFoto(this, 'pakaiFotoPreview', 'pakaiFotoPlaceholder')">
            <small class="compress-msg" style="display:none;color:#22c55e;font-weight:600;">✅ Foto dikompres!</small>
          </div>

          <label class="f-label">Jumlah</label>
          <input type="number" name="jumlah" class="f-input" min="1" value="1" required id="pakaiJml">
          <label class="f-label">Divisi Tujuan</label>
          <select name="divisi" class="f-input">
            <option value="IT & IC">IT & IC</option><option value="HRGA">HRGA</option>
            <option value="Accounting">Accounting</option><option value="Exim & Pembelian">Exim & Pembelian</option>
            <option value="Operasional">Operasional</option><option value="Finance">Finance</option>
            <option value="Produksi">Produksi</option><option value="Bahanbaku">Bahanbaku</option>
            <option value="MAINTENANCE">MAINTENANCE</option><option value="Admin Sales">Admin Sales</option>
          </select>
          <label class="f-label">Lokasi Pemasangan</label>
          <input type="text" name="lokasi" class="f-input" placeholder="cth: Ruang server lt.1" required>
          <label class="f-label">Tanggal</label>
          <input type="date" name="tanggal" class="f-input" id="pakaiTgl">
          <label class="f-label">Keterangan</label>
          <textarea name="keterangan" class="f-input" rows="2"></textarea>
        </div>
        <div class="modal-footer m-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-success fw-bold">Catat Penggunaan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== MODAL PINJAM ========== -->
<div class="modal fade" id="modalPinjam" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content m-content">
      <div class="modal-header m-header"><h5 class="modal-title" id="modalPinjamTitle">Catat Peminjaman</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form id="formPinjam" action="" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div id="pinjamInfo" style="background:#1a0d3d;border:1px solid #4c3780;border-radius:6px;padding:9px 12px;margin-bottom:1rem;font-size:0.82rem;color:#a78bfa;font-weight:700;"></div>

          <!-- FOTO PINJAM -->
          <label class="f-label">📷 Foto Kondisi Aset</label>
          <div class="modal-foto-area" id="pinjamAreaFoto">
            <img id="pinjamFotoPreview" class="modal-foto-preview" alt="">
            <div class="modal-foto-placeholder" id="pinjamFotoPlaceholder">
              <span class="icon">📸</span>
              Foto kondisi aset sebelum dipinjam (opsional)
            </div>
            <input type="file" name="foto" accept="image/*" capture="environment"
              onchange="previewModalFoto(this, 'pinjamFotoPreview', 'pinjamFotoPlaceholder')">
            <small class="compress-msg" style="display:none;color:#22c55e;font-weight:600;">✅ Foto dikompres!</small>
          </div>

          <label class="f-label">Jumlah</label>
          <input type="number" name="jumlah" class="f-input" min="1" value="1" required>
          <label class="f-label">Nama Peminjam</label>
          <input type="text" name="peminjam" class="f-input" placeholder="cth: Roby, Bagyo" required>
          <label class="f-label">Divisi</label>
          <select name="divisi" class="f-input">
            <option value="IT & IC">IT & IC</option><option value="HRGA">HRGA</option>
            <option value="Accounting">Accounting</option><option value="Exim & Pembelian">Exim & Pembelian</option>
            <option value="Operasional">Operasional</option><option value="Finance">Finance</option>
            <option value="Produksi">Produksi</option><option value="Bahanbaku">Bahanbaku</option>
            <option value="MAINTENANCE">MAINTENANCE</option><option value="Admin Sales">Admin Sales</option>
          </select>
          <label class="f-label">Keperluan</label>
          <textarea name="keperluan" class="f-input" rows="2" placeholder="cth: Presentasi jobfair..." required></textarea>
          <label class="f-label">Tanggal Pinjam</label>
          <input type="date" name="tanggalPinjam" class="f-input" id="pinjamTgl">
        </div>
        <div class="modal-footer m-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn fw-bold" style="background:#5b21b6;color:#fff;border:none;">Catat Pinjaman</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== MODAL EDIT ========== -->
<div class="modal fade" id="modalEdit" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content m-content">
      <div class="modal-header m-header"><h5 class="modal-title">Edit Aset</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form id="formEdit" action="" method="POST" enctype="multipart/form-data">
        <div class="modal-body">

          <!-- GANTI FOTO ASET -->
          <label class="f-label">📷 Ganti Foto Aset (opsional)</label>
          <div class="modal-foto-area" id="editAreaFoto">
            <img id="editFotoPreview" class="modal-foto-preview" alt="" id="editFotoExisting">
            <div class="modal-foto-placeholder" id="editFotoPlaceholder">
              <span class="icon">🔄</span>
              Klik untuk ganti foto aset
            </div>
            <input type="file" name="foto" accept="image/*"
              onchange="previewModalFoto(this, 'editFotoPreview', 'editFotoPlaceholder')">
            <small class="compress-msg" style="display:none;color:#22c55e;font-weight:600;">✅ Foto dikompres!</small>
          </div>

          <label class="f-label">Nama Aset</label><input type="text" name="nama" id="eNama" class="f-input" required>
          <label class="f-label">Kategori</label><input type="text" name="kategori" id="eKat" class="f-input" list="kategoriList">
          <label class="f-label">Satuan</label><input type="text" name="satuan" id="eSat" class="f-input" list="satuanList" required>
          <label class="f-label">Stok Awal</label><input type="number" name="stokAwal" id="eStok" class="f-input" min="0" required>
          <label class="f-label">Kondisi</label>
          <select name="kondisi" id="eKon" class="f-input"><option value="Baik">Baik</option><option value="Perlu Service">Perlu Service</option><option value="Rusak">Rusak</option></select>
          <label class="f-label">Keterangan</label><textarea name="keterangan" id="eKet" class="f-input" rows="2"></textarea>
        </div>
        <div class="modal-footer m-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary fw-bold">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== MODAL HAPUS ========== -->
<div class="modal fade" id="modalHapus" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content m-content" style="border-color:#5c1a1a !important;">
      <div class="modal-header" style="border-color:#5c1a1a;"><h5 class="modal-title">Hapus Aset</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <p style="color:var(--body-text);" class="mb-1">Yakin hapus aset ini?</p>
        <p id="hapusNama" style="color:#f87171;font-weight:700;"></p>
        <p style="color:var(--body-text2);font-size:0.8rem;">Semua riwayat penggunaan dan pinjaman ikut terhapus.</p>
      </div>
      <div class="modal-footer" style="border-color:#5c1a1a;">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <form id="formHapus" action="" method="POST" style="display:inline;"><button type="submit" class="btn btn-danger fw-bold">Ya, Hapus</button></form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
var today = new Date().toISOString().split('T')[0];
if (document.getElementById('pakaiTgl'))  document.getElementById('pakaiTgl').value  = today;
if (document.getElementById('pinjamTgl')) document.getElementById('pinjamTgl').value = today;

// ===== COMPRESS IMAGE (canvas, max 1000px, JPEG 60%) =====
async function compressImage(file) {
    return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = function(e) {
            var img = new Image();
            img.src = e.target.result;
            img.onload = function() {
                var w = img.width, h = img.height, max = 1000;
                if (w > h) { if (w > max) { h = Math.round(h * max / w); w = max; } }
                else       { if (h > max) { w = Math.round(w * max / h); h = max; } }
                var canvas = document.createElement('canvas');
                canvas.width = w; canvas.height = h;
                canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                canvas.toBlob(function(blob) {
                    resolve(new File([blob], file.name.replace(/\.[^/.]+$/, '.jpg'), { type: 'image/jpeg', lastModified: Date.now() }));
                }, 'image/jpeg', 0.6);
            };
        };
        reader.onerror = reject;
    });
}

// Helper: tampilkan preview dari blob/file ke elemen img
function showPreview(file, imgId, placeholderId) {
    var img = document.getElementById(imgId);
    var ph  = document.getElementById(placeholderId);
    var url = URL.createObjectURL(file);
    img.src = url;
    img.style.display = 'block';
    if (ph) ph.style.display = 'none';
}

// Helper: replace file di input + tampilkan label kompres
function replaceInputFile(input, compressedFile) {
    var dt = new DataTransfer();
    dt.items.add(compressedFile);
    input.files = dt.files;
    // Cari label compress terdekat (nextElementSibling atau sibling lainnya)
    var msg = input.nextElementSibling;
    if (msg && msg.classList && msg.classList.contains('compress-msg')) {
        msg.style.display = 'inline-block';
    }
}

// ===== FOTO PREVIEW (sidebar form tambah aset) =====
async function previewFoto(input, imgId, placeholderId) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    if (!file.type.startsWith('image/')) return;
    try {
        var compressed = await compressImage(file);
        replaceInputFile(input, compressed);
        showPreview(compressed, imgId, placeholderId);
    } catch(err) {
        console.error('Gagal kompres:', err);
        // fallback: preview tanpa compress
        showPreview(file, imgId, placeholderId);
    }
}

// ===== FOTO PREVIEW (modal: pakai, pinjam, edit) =====
async function previewModalFoto(input, imgId, placeholderId) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    if (!file.type.startsWith('image/')) return;
    try {
        var compressed = await compressImage(file);
        replaceInputFile(input, compressed);
        showPreview(compressed, imgId, placeholderId);
    } catch(err) {
        console.error('Gagal kompres:', err);
        showPreview(file, imgId, placeholderId);
    }
}

// ===== MODAL LIHAT FOTO =====
function showFotoModal(url, nama) {
    document.getElementById('modalFotoImg').src   = url;
    document.getElementById('modalFotoTitle').textContent = '📷 ' + nama;
    new bootstrap.Modal(document.getElementById('modalFoto')).show();
}

// ===== MODAL PAKAI =====
function openModalPakai(id, nama, stok, sat) {
    document.getElementById('formPakai').action = '/aset/pakai/' + id;
    document.getElementById('modalPakaiTitle').textContent = 'Catat Penggunaan: ' + nama;
    document.getElementById('pakaiInfo').textContent = 'Stok tersedia: ' + stok + ' ' + sat;
    document.getElementById('pakaiJml').max = stok;
    // Reset foto
    var img = document.getElementById('pakaiFotoPreview');
    var ph  = document.getElementById('pakaiFotoPlaceholder');
    img.src = ''; img.style.display = 'none'; if(ph) ph.style.display = '';
    document.getElementById('formPakai').reset();
    document.getElementById('pakaiTgl').value = today;
    document.getElementById('pakaiJml').max = stok;
    new bootstrap.Modal(document.getElementById('modalPakai')).show();
}

// ===== MODAL PINJAM =====
function openModalPinjam(id, nama, stok, sat) {
    document.getElementById('formPinjam').action = '/aset/pinjam/' + id;
    document.getElementById('modalPinjamTitle').textContent = 'Catat Peminjaman: ' + nama;
    document.getElementById('pinjamInfo').textContent = 'Stok tersedia: ' + stok + ' ' + sat;
    // Reset foto
    var img = document.getElementById('pinjamFotoPreview');
    var ph  = document.getElementById('pinjamFotoPlaceholder');
    img.src = ''; img.style.display = 'none'; if(ph) ph.style.display = '';
    document.getElementById('formPinjam').reset();
    document.getElementById('pinjamTgl').value = today;
    new bootstrap.Modal(document.getElementById('modalPinjam')).show();
}

// ===== MODAL EDIT =====
function openModalEdit(id, nama, kat, sat, stok, kon, ket) {
    document.getElementById('formEdit').action = '/aset/edit/' + id;
    document.getElementById('eNama').value = nama;
    document.getElementById('eKat').value  = kat;
    document.getElementById('eSat').value  = sat;
    document.getElementById('eStok').value = stok;
    document.getElementById('eKon').value  = kon;
    document.getElementById('eKet').value  = ket;
    // Reset preview foto (foto existing tidak ditampilkan di preview, hanya kalau upload baru)
    var img = document.getElementById('editFotoPreview');
    var ph  = document.getElementById('editFotoPlaceholder');
    img.src = ''; img.style.display = 'none'; if(ph) ph.style.display = '';
    new bootstrap.Modal(document.getElementById('modalEdit')).show();
}

// ===== HAPUS ASET =====
function hapusAset(id, nama) {
    document.getElementById('formHapus').action = '/aset/hapus/' + id;
    document.getElementById('hapusNama').textContent = '"' + nama + '"';
    new bootstrap.Modal(document.getElementById('modalHapus')).show();
}
</script>
</body>
</html>
