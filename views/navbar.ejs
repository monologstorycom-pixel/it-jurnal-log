<style>
  .it-nav { position: sticky; top: 0; z-index: 999; background: #0f1117; border-bottom: 1px solid #1e2130; }
  .it-nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 1.5rem; height: 52px; max-width: 1600px; margin: 0 auto; }
  .it-nav-brand { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.9rem; color: #fff; letter-spacing: 0.02em; text-decoration: none; display: flex; align-items: center; gap: 8px; }
  .it-nav-brand span { color: #4ade80; }
  .it-nav-links { display: flex; align-items: center; gap: 2px; }
  .it-nav-link { display: flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 6px; color: #8b8fa8; font-size: 0.82rem; font-weight: 600; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
  .it-nav-link:hover { background: #1a1d2e; color: #c9d1e0; }
  .it-nav-link.active { background: #1a1d2e; color: #fff; }
  .it-nav-link .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: 0.5; }
  .it-nav-link.active .dot { opacity: 1; background: #4ade80; }
  .it-nav-link .icon { font-size: 14px; opacity: 0.7; }
  .it-nav-link.active .icon { opacity: 1; }
  .it-nav-hamburger { display: none; background: none; border: 1px solid #2a2d3e; border-radius: 6px; padding: 6px 10px; color: #8b8fa8; cursor: pointer; font-size: 16px; }
  .it-nav-hamburger:hover { color: #fff; border-color: #444; }
  .it-nav-mobile { display: none; background: #0f1117; border-top: 1px solid #1e2130; padding: 0.75rem 1rem; }
  .it-nav-mobile.open { display: block; }
  .it-nav-mobile a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; color: #8b8fa8; font-size: 0.85rem; font-weight: 600; text-decoration: none; margin-bottom: 4px; }
  .it-nav-mobile a:hover, .it-nav-mobile a.active { background: #1a1d2e; color: #fff; }
  .it-nav-mobile a .m-icon { font-size: 16px; width: 22px; text-align: center; }
  @media (max-width: 640px) {
    .it-nav-links { display: none; }
    .it-nav-hamburger { display: block; }
  }
</style>

<nav class="it-nav">
  <div class="it-nav-inner">
    <a href="/kerja" class="it-nav-brand">&gt;_ IT <span>SUPPORT</span> LOG</a>
    <div class="it-nav-links">
      <a href="/"       class="it-nav-link <%= activePage === 'view' ? 'active' : '' %>">
        <span class="icon">◉</span> Home
      </a>   
      <a href="/aset"   class="it-nav-link <%= activePage === 'aset' ? 'active' : '' %>">
        <span class="icon">▦</span> Aset IT
      </a>
      <a href="/kerja"  class="it-nav-link <%= activePage === 'dashboard' ? 'active' : '' %>">
        <span class="icon">⚙</span> Dashboard
      </a>
    </div>
    <button class="it-nav-hamburger" onclick="toggleMobileNav()" id="navHamburger">☰</button>
  </div>
  <div class="it-nav-mobile" id="mobileNav">
    <a href="/" class="<%= activePage === 'view' ? 'active' : '' %>">
      <span class="m-icon">◉</span> Home
    </a>  
    <a href="/aset" class="<%= activePage === 'aset' ? 'active' : '' %>">
      <span class="m-icon">▦</span> Aset IT
    </a>
    <a href="/kerja" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
      <span class="m-icon">⚙</span> Dashboard
    </a>
  </div>
</nav>
<script>
function toggleMobileNav() {
  var nav = document.getElementById('mobileNav');
  nav.classList.toggle('open');
}
</script>
