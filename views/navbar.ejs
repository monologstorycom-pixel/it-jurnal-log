<!-- RSBY-AI CHATBOT WIDGET                                        -->
<!-- ============================================================ -->
<style>
  /* Floating button */
  #ai-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 18px rgba(99,102,241,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  #ai-fab:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(99,102,241,0.55); }
  #ai-fab svg { width: 24px; height: 24px; }
  #ai-fab .ai-notif {
    position: absolute;
    top: 2px; right: 2px;
    width: 10px; height: 10px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid #fff;
    display: none;
  }

  /* Chat panel */
  #ai-panel {
    position: fixed;
    bottom: 88px;
    right: 24px;
    width: 360px;
    max-height: 540px;
    background: var(--body-card, #fff);
    border: 1px solid var(--body-border, rgba(0,0,0,0.1));
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.18);
    display: none;
    flex-direction: column;
    z-index: 9999;
    overflow: hidden;
    font-family: inherit;
  }
  #ai-panel.open { display: flex; }

  /* Header */
  .ai-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    border-radius: 16px 16px 0 0;
    flex-shrink: 0;
  }
  .ai-header-icon {
    width: 34px; height: 34px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ai-header-title { font-weight: 700; font-size: 14px; line-height: 1.2; }
  .ai-header-sub { font-size: 11px; opacity: 0.8; }
  .ai-header-close {
    margin-left: auto;
    background: none; border: none; color: #fff;
    cursor: pointer; padding: 4px; border-radius: 6px;
    display: flex; align-items: center;
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .ai-header-close:hover { opacity: 1; background: rgba(255,255,255,0.15); }

  /* Messages area */
  #ai-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px 14px 8px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
  }
  #ai-messages::-webkit-scrollbar { width: 4px; }
  #ai-messages::-webkit-scrollbar-thumb { background: var(--body-border2, #ccc); border-radius: 4px; }

  .ai-msg {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    animation: aiMsgIn 0.2s ease;
  }
  @keyframes aiMsgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

  .ai-msg.user { flex-direction: row-reverse; }
  .ai-bubble {
    max-width: 80%;
    padding: 9px 13px;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.55;
    word-break: break-word;
    white-space: pre-wrap;
  }
  .ai-msg.bot .ai-bubble {
    background: var(--body-bg3, #f3f4f6);
    color: var(--body-text, #111827);
    border-radius: 4px 14px 14px 14px;
  }
  .ai-msg.user .ai-bubble {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    border-radius: 14px 4px 14px 14px;
  }
  .ai-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700;
    flex-shrink: 0;
  }
  .ai-msg.bot .ai-avatar { background: linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff; }
  .ai-msg.user .ai-avatar { background: var(--body-bg3,#e5e7eb); color: var(--body-text,#374151); }

  /* Typing indicator */
  .ai-typing .ai-bubble {
    display: flex; gap: 4px; align-items: center; padding: 12px 16px;
  }
  .ai-typing .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--body-text2, #6b7280);
    animation: typingDot 1.2s infinite;
  }
  .ai-typing .dot:nth-child(2) { animation-delay: 0.2s; }
  .ai-typing .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingDot {
    0%,60%,100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  /* Quick prompts */
  .ai-quick {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding: 0 14px 10px;
    flex-shrink: 0;
  }
  .ai-quick-btn {
    font-size: 11px; padding: 5px 10px;
    border: 1px solid var(--body-border2, rgba(0,0,0,0.14));
    background: var(--body-bg, #f9fafb);
    color: var(--body-text2, #6b7280);
    border-radius: 20px; cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .ai-quick-btn:hover { background: #6366f1; color: #fff; border-color: #6366f1; }

  /* Input area */
  .ai-input-area {
    display: flex; gap: 8px; align-items: flex-end;
    padding: 10px 14px 14px;
    border-top: 1px solid var(--body-border, rgba(0,0,0,0.08));
    flex-shrink: 0;
    background: var(--body-card, #fff);
  }
  #ai-input {
    flex: 1;
    border: 1px solid var(--body-input-border, rgba(0,0,0,0.12));
    background: var(--body-input, #f9fafb);
    color: var(--body-text, #111827);
    border-radius: 10px;
    padding: 9px 12px;
    font-size: 13px;
    resize: none;
    outline: none;
    max-height: 100px;
    min-height: 38px;
    font-family: inherit;
    line-height: 1.4;
    transition: border-color 0.15s;
  }
  #ai-input:focus { border-color: #6366f1; }
  #ai-input::placeholder { color: var(--body-text3, #9ca3af); }
  #ai-send {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border: none; border-radius: 10px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: opacity 0.15s, transform 0.15s;
    color: #fff;
  }
  #ai-send:hover { opacity: 0.9; transform: scale(1.05); }
  #ai-send:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  #ai-send svg { width: 17px; height: 17px; }

  /* Mobile adjustment */
  @media (max-width: 480px) {
    #ai-panel { width: calc(100vw - 24px); right: 12px; bottom: 80px; }
    #ai-fab { right: 16px; bottom: 16px; }
  }
</style>

<!-- FAB Button -->
<button id="ai-fab" onclick="toggleAiPanel()" title="AI Assistant">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M12 2a6 6 0 0 1 6 6c0 2.4-1.4 4.5-3.5 5.5L16 21H8l1.5-7.5C7.4 12.5 6 10.4 6 8a6 6 0 0 1 6-6z"/>
    <circle cx="9" cy="8" r="1" fill="currentColor" stroke="none"/>
    <circle cx="12" cy="7" r="1" fill="currentColor" stroke="none"/>
    <circle cx="15" cy="8" r="1" fill="currentColor" stroke="none"/>
  </svg>
  <span class="ai-notif" id="aiNotif"></span>
</button>

<!-- Chat Panel -->
<div id="ai-panel">
  <div class="ai-header">
    <div class="ai-header-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
      </svg>
    </div>
    <div>
      <div class="ai-header-title">RSBY-AI Assistant</div>
      <div class="ai-header-sub">Powered by Gemini · IT Support</div>
    </div>
    <button class="ai-header-close" onclick="toggleAiPanel()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div id="ai-messages">
    <div class="ai-msg bot">
      <div class="ai-avatar">AI</div>
      <div class="ai-bubble">Halo! Saya <strong>RSBY-AI</strong>, asisten IT Support kamu. 👋<br>Tanya apa saja seputar tiket, log, atau troubleshooting!</div>
    </div>
  </div>

  <div class="ai-quick" id="aiQuickPrompts">
    <button class="ai-quick-btn" onclick="sendQuick('Tiket pending apa saja hari ini?')">📋 Tiket pending</button>
    <button class="ai-quick-btn" onclick="sendQuick('Aset IT apa saja yang tersedia dan stoknya?')">🖥️ Cek stok aset</button>
    <button class="ai-quick-btn" onclick="sendQuick('Aset apa yang sedang dipinjam sekarang?')">🔄 Aset dipinjam</button>
    <button class="ai-quick-btn" onclick="sendQuick('Rangkum aktivitas IT terbaru')">📊 Rangkuman log</button>
  </div>

  <div class="ai-input-area">
    <textarea id="ai-input" placeholder="Tanya sesuatu..." rows="1" onkeydown="aiKeydown(event)" oninput="autoResize(this)"></textarea>
    <button id="ai-send" onclick="sendAiMessage()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/>
      </svg>
    </button>
  </div>
</div>

<script>
(function() {
  var aiHistory = [];
  var aiOpen = false;

  window.toggleAiPanel = function() {
    aiOpen = !aiOpen;
    var panel = document.getElementById('ai-panel');
    if (aiOpen) {
      panel.classList.add('open');
      document.getElementById('ai-input').focus();
      document.getElementById('aiNotif').style.display = 'none';
    } else {
      panel.classList.remove('open');
    }
  };

  window.autoResize = function(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 100) + 'px';
  };

  window.aiKeydown = function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendAiMessage();
    }
  };

  window.sendQuick = function(msg) {
    document.getElementById('ai-input').value = msg;
    sendAiMessage();
    // Hide quick prompts after first use
    document.getElementById('aiQuickPrompts').style.display = 'none';
  };

  function appendMsg(role, text) {
    var msgs = document.getElementById('ai-messages');
    var div = document.createElement('div');
    div.className = 'ai-msg ' + role;
    var avatar = role === 'bot' ? 'AI' : '<%= typeof currentUser !== "undefined" && currentUser ? currentUser.nama.substring(0,2).toUpperCase() : "U" %>';
    div.innerHTML = '<div class="ai-avatar">' + avatar + '</div><div class="ai-bubble">' + escHtml(text) + '</div>';
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return div;
  }

  function showTyping() {
    var msgs = document.getElementById('ai-messages');
    var div = document.createElement('div');
    div.className = 'ai-msg bot ai-typing';
    div.id = 'ai-typing-indicator';
    div.innerHTML = '<div class="ai-avatar">AI</div><div class="ai-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function removeTyping() {
    var t = document.getElementById('ai-typing-indicator');
    if (t) t.remove();
  }

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
  }

  window.sendAiMessage = async function() {
    var input = document.getElementById('ai-input');
    var msg = input.value.trim();
    if (!msg) return;

    var sendBtn = document.getElementById('ai-send');
    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;

    appendMsg('user', msg);
    showTyping();

    // Hide quick prompts after first message
    document.getElementById('aiQuickPrompts').style.display = 'none';

    try {
      var res = await fetch('/api/ai-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, history: aiHistory })
      });
      var data = await res.json();
      removeTyping();

      var reply = data.reply || data.error || 'Tidak ada respons.';
      appendMsg('bot', reply);

      // Update history (max 10 turns)
      aiHistory.push({ role: 'user', content: msg });
      aiHistory.push({ role: 'assistant', content: reply });
      if (aiHistory.length > 20) aiHistory = aiHistory.slice(-20);

    } catch(err) {
      removeTyping();
      appendMsg('bot', '⚠️ Gagal terhubung ke AI. Cek koneksi atau API key.');
    } finally {
      sendBtn.disabled = false;
      input.focus();
    }
  };
})();
</script>
