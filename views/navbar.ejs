<script>
(function() {
  function getTheme() { return localStorage.getItem('itlog-theme') || 'dark'; }

  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('itlog-theme', t);
    var lbl   = document.getElementById('navThemeLabel');
    var thumb = document.getElementById('navThumb');
    if (lbl)   lbl.textContent = t === 'dark' ? 'Light' : 'Dark';
    if (thumb) {
      thumb.style.transform  = t === 'light' ? 'translateX(12px)' : '';
      thumb.style.background = t === 'light' ? '#ffffff' : '';
    }
  }

  window.toggleTheme = function() {
    applyTheme(getTheme() === 'dark' ? 'light' : 'dark');
  };

  function updateSidebarThemeLabel(t) {
    var lbl = document.getElementById('sidebarThemeLabel');
    if (lbl) lbl.textContent = t === 'dark' ? 'Light Mode' : 'Dark Mode';
  }

  window.openSidebar = function() {
    var nav = document.getElementById('mobileNav');
    var overlay = document.getElementById('sidebarOverlay');
    if (nav) nav.classList.add('open');
    if (overlay) overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  };

  window.closeSidebar = function() {
    var nav = document.getElementById('mobileNav');
    var overlay = document.getElementById('sidebarOverlay');
    if (nav) nav.classList.remove('open');
    if (overlay) overlay.classList.remove('open');
    document.body.style.overflow = '';
  };

  // Swipe left to close sidebar
  (function() {
    var startX = 0;
    var nav = document.getElementById('mobileNav');
    if (!nav) return;
    nav.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    nav.addEventListener('touchend', function(e) {
      if (startX - e.changedTouches[0].clientX > 60) closeSidebar();
    }, { passive: true });
  })();

  // Keep hamburger onclick pointing to openSidebar
  window.toggleMobileNav = window.openSidebar;

  applyTheme(getTheme());
  updateSidebarThemeLabel(getTheme());
})();

// User dropdown toggle
window.toggleUserDropdown = function(e) {
  e.stopPropagation();
  var dd = document.getElementById('userDropdown');
  if (dd) dd.classList.toggle('open');
};
document.addEventListener('click', function() {
  var dd = document.getElementById('userDropdown');
  if (dd) dd.classList.remove('open');
});
</script>

