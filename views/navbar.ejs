<style>
  /* ===== LUCIDE ICON STYLE ===== */
  .lc { display:inline-block; vertical-align:-0.15em; width:1em; height:1em; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; flex-shrink:0; }
  .lc-sm { width:0.75em !important; height:0.75em !important; }
  .lc-lg { width:1.3em !important; height:1.3em !important; }
  /* stat card icons */
  .stat-card-icon { display:flex; align-items:center; justify-content:center; }
  .stat-card-icon .lc { width:1.4em; height:1.4em; }
  /* empty state */
  .empty-state-icon { display:flex; align-items:center; justify-content:center; }
  .empty-state-icon .lc { width:2.2em; height:2.2em; opacity:0.35; }
  /* label headings with icon */
  .f-label .lc, label .lc { width:0.9em; height:0.9em; vertical-align:-0.1em; }
  /* modal title icons */
  .modal-title .lc { width:0.9em; height:0.9em; vertical-align:-0.1em; }
  /* button icons */
  button .lc, a .lc { vertical-align:-0.15em; }

  /* ===== GLOBAL THEME VARS ===== */
  :root {
    --nav-bg: #ffffff;
    --nav-border: rgba(0,0,0,0.08);
    --nav-text: #111827;
    --nav-text2: #6b7280;
    --nav-hover-bg: #f9fafb;
    --nav-active-bg: #f3f4f6;
    --body-bg: #f9fafb;
    --body-bg2: #ffffff;
    --body-bg3: #f3f4f6;
    --body-text: #111827;
    --body-text2: #6b7280;
    --body-text3: #9ca3af;
    --body-border: rgba(0,0,0,0.08);
    --body-border2: rgba(0,0,0,0.14);
    --body-card: #ffffff;
    --body-input: #f9fafb;
    --body-input-border: rgba(0,0,0,0.1);
    --body-input-focus: #6366f1;
    --body-accent: #16a34a;
    --body-accent-bg: #dcfce7;
    --body-err-bg: #fff0f0;
    --body-err-text: #dc2626;
    --body-err-border: #fca5a5;
    --body-table-row: #ffffff;
    --body-table-row-alt: #f9fafb;
    --body-table-text: #111827;
    --body-table-border: rgba(0,0,0,0.07);
    --body-table-head: #f9fafb;
    --body-table-head-text: #374151;
    --avatar-bg: #dcfce7;
    --avatar-text: #15803d;
    --role-admin-bg: #ede9fe;
    --role-admin-text: #6d28d9;
    --role-user-bg: #dcfce7;
    --role-user-text: #15803d;
    --role-viewer-bg: #dbeafe;
    --role-viewer-text: #1d4ed8;
  }

  [data-theme="dark"] {
    --nav-bg: #0f1117;
    --nav-border: rgba(255,255,255,0.07);
    --nav-text: #f1f5f9;
    --nav-text2: #94a3b8;
    --nav-hover-bg: #1e2130;
    --nav-active-bg: #1a1d2e;
    --body-bg: #080a10;
    --body-bg2: #0f1117;
    --body-bg3: #13161f;
    --body-text: #e2e8f0;
    --body-text2: #8b8fa8;
    --body-text3: #3b4263;
    --body-border: rgba(255,255,255,0.07);
    --body-border2: rgba(255,255,255,0.12);
    --body-card: #0f1117;
    --body-input: #080a10;
    --body-input-border: rgba(255,255,255,0.08);
    --body-input-focus: #818cf8;
    --body-accent: #4ade80;
    --body-accent-bg: #0d2a18;
    --body-err-bg: #2a0d0d;
    --body-err-text: #f87171;
    --body-err-border: #5c1a1a;
    --body-table-row: #ffffff;
    --body-table-row-alt: #f4f4f4;
    --body-table-text: #000000;
    --body-table-border: #dddddd;
    --body-table-head: #1f242b;
    --body-table-head-text: #ffffff;
    --avatar-bg: #0d2a18;
    --avatar-text: #4ade80;
    --role-admin-bg: #1a0d3d;
    --role-admin-text: #a78bfa;
    --role-user-bg: #0d2a18;
    --role-user-text: #4ade80;
    --role-viewer-bg: #0d1a38;
    --role-viewer-text: #7eb8f7;
  }

  body {
    background-color: var(--body-bg) !important;
    color: var(--body-text) !important;
    transition: background-color 0.2s, color 0.2s;
  }

  /* ===== NAVBAR ===== */
  .it-nav {
    position: sticky;
    top: 0;
    z-index: 999;
    background: var(--nav-bg);
    border-bottom: 0.5px solid var(--nav-border);
    height: 56px;
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  /* BRAND */
  .it-nav-brand {
    font-size: 13px;
    font-weight: 600;
    color: var(--nav-text);
    letter-spacing: 0.03em;
    text-decoration: none;
    margin-right: 28px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .it-nav-brand span { color: var(--body-accent); }

  /* LINKS */
  .it-nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
  }
  .it-nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 13px;
    color: var(--nav-text2);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    white-space: nowrap;
    line-height: 1;
  }
  .it-nav-link:hover { background: var(--nav-hover-bg); color: var(--nav-text); }
  .it-nav-link.active { background: var(--nav-active-bg); color: var(--nav-text); font-weight: 500; }
  .it-nav-link svg { width: 14px; height: 14px; flex-shrink: 0; }

  /* RIGHT SIDE */
  .it-nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
    flex-shrink: 0;
  }

  /* DIVIDER */
  .it-nav-divider {
    width: 0.5px;
    height: 20px;
    background: var(--nav-border);
    margin: 0 2px;
  }

  /* THEME TOGGLE */
  .it-nav-theme {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: 20px;
    border: 0.5px solid var(--nav-border);
    cursor: pointer;
    font-size: 12px;
    color: var(--nav-text2);
    background: transparent;
    transition: border-color 0.12s, color 0.12s;
  }
  .it-nav-theme:hover { border-color: var(--body-border2); color: var(--nav-text); }
  .t-track {
    width: 26px;
    height: 14px;
    background: var(--nav-border);
    border-radius: 7px;
    position: relative;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .t-thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--nav-text2);
    transition: transform 0.2s, background 0.2s;
  }
  [data-theme="light"] .t-track { background: #16a34a; }
  [data-theme="light"] .t-thumb { transform: translateX(12px); background: #ffffff; }

  /* USER PILL + DROPDOWN */
  .it-nav-user-wrap { position: relative; }
  .it-nav-user {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px 4px 4px;
    border-radius: 24px;
    border: 0.5px solid var(--nav-border);
    cursor: pointer;
    transition: background 0.12s;
    user-select: none;
  }
  .it-nav-user:hover { background: var(--nav-hover-bg); }
  .it-user-dropdown {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    background: var(--body-card, #1a1d27);
    border: 1px solid var(--body-border, #2a2d3a);
    border-radius: 12px;
    min-width: 180px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.35);
    z-index: 9999;
    overflow: hidden;
    animation: ddFadeIn 0.15s ease;
  }
  @keyframes ddFadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }
  .it-user-dropdown.open { display: block; }
  .it-dd-header { padding: 12px 14px 10px; border-bottom: 1px solid var(--body-border, #2a2d3a); }
  .it-dd-name { font-size: 0.82rem; font-weight: 700; color: var(--body-text, #e2e8f0); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .it-dd-username { font-size: 0.72rem; color: var(--body-text3, #6b7280); margin-top: 2px; }
  .it-dd-item {
    display: flex; align-items: center; gap: 9px;
    padding: 10px 14px;
    font-size: 0.8rem; font-weight: 600;
    color: var(--body-text2, #94a3b8);
    text-decoration: none;
    transition: background 0.12s, color 0.12s;
    cursor: pointer; border: none; background: none; width: 100%; text-align: left;
  }
  .it-dd-item:hover { background: var(--body-bg3, #1e2433); color: var(--body-text, #e2e8f0); }
  .it-dd-item.danger { color: #dc2626; }
  .it-dd-item.danger:hover { background: rgba(220,38,38,0.08); color: #dc2626; }
  .it-dd-divider { height: 1px; background: var(--body-border, #2a2d3a); margin: 2px 0; }

  /* AVATAR */
  .it-nav-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--avatar-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 600;
    color: var(--avatar-text);
    flex-shrink: 0;
    letter-spacing: 0.03em;
    overflow: hidden;
  }
  .it-nav-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .it-nav-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--nav-text);
    white-space: nowrap;
  }

  /* ROLE BADGE */
  .it-nav-role {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 10px;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }
  .role-admin  { background: var(--role-admin-bg);  color: var(--role-admin-text); }
  .role-user   { background: var(--role-user-bg);   color: var(--role-user-text); }
  .role-viewer { background: var(--role-viewer-bg); color: var(--role-viewer-text); }
  .role-custom { background: var(--role-viewer-bg); color: var(--role-viewer-text); }


  /* VERIFIED BADGE — Instagram corner style */
  .avatar-verified-wrap {
    position: relative;
    flex-shrink: 0;
    display: inline-flex;
  }
  .verified-corner {
    position: absolute;
    bottom: -1px;
    right: -2px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--nav-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1px;
    box-shadow: 0 0 0 1.5px var(--nav-bg);
  }
  .verified-corner svg {
    width: 11px;
    height: 11px;
    display: block;
    filter: drop-shadow(0 0 2px rgba(29,155,240,0.6));
  }
  /* Sidebar — badge lebih besar */
  .avatar-verified-wrap.lg .verified-corner {
    width: 15px;
    height: 15px;
    bottom: -1px;
    right: -3px;
  }
  .avatar-verified-wrap.lg .verified-corner svg { width: 13px; height: 13px; }

  /* LOGOUT BTN */
  .it-nav-logout {
    padding: 5px 12px;
    border-radius: 8px;
    border: 0.5px solid var(--nav-border);
    font-size: 12px;
    font-weight: 500;
    color: var(--nav-text2);
    cursor: pointer;
    background: transparent;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: border-color 0.12s, color 0.12s, background 0.12s;
  }
  .it-nav-logout:hover {
    border-color: #fca5a5;
    color: #dc2626;
    background: var(--body-err-bg);
  }

  /* HAMBURGER MOBILE */
  /* HAMBURGER BUTTON */
  .it-nav-hamburger {
    display: none;
    background: none;
    border: 0.5px solid var(--nav-border);
    border-radius: 8px;
    padding: 6px 9px;
    color: var(--nav-text2);
    cursor: pointer;
    margin-left: auto;
    transition: color 0.15s, border-color 0.15s;
  }
  .it-nav-hamburger:hover { color: var(--nav-text); border-color: var(--nav-border2, rgba(0,0,0,0.18)); }

  /* SIDEBAR OVERLAY */
  .it-sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 1099;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .it-sidebar-overlay.open {
    display: block;
    opacity: 1;
  }

  /* SIDEBAR PANEL */
  .it-nav-mobile {
    position: fixed;
    top: 0;
    left: 0;
    height: 100dvh;
    width: 270px;
    max-width: 82vw;
    background: var(--nav-bg);
    border-right: 0.5px solid var(--nav-border);
    z-index: 1100;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }
  .it-nav-mobile.open {
    transform: translateX(0);
  }

  /* SIDEBAR HEADER */
  .it-sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 16px 14px;
    border-bottom: 0.5px solid var(--nav-border);
    flex-shrink: 0;
  }
  .it-sidebar-brand {
    font-size: 13px;
    font-weight: 700;
    color: var(--nav-text);
    letter-spacing: -0.01em;
    text-decoration: none;
  }
  .it-sidebar-brand span { color: #16a34a; }
  .it-sidebar-close {
    background: none;
    border: none;
    color: var(--nav-text2);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.12s, color 0.12s;
  }
  .it-sidebar-close:hover { background: var(--nav-hover-bg); color: var(--nav-text); }

  /* SIDEBAR NAV LINKS */
  .it-sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 10px 10px 0;
  }
  .it-sidebar-nav::-webkit-scrollbar { width: 3px; }
  .it-sidebar-nav::-webkit-scrollbar-thumb { background: var(--nav-border); border-radius: 4px; }

  .it-nav-mobile a {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 10px 12px;
    border-radius: 9px;
    color: var(--nav-text2);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 2px;
    transition: background 0.12s, color 0.12s;
  }
  .it-nav-mobile a:hover { background: var(--nav-hover-bg); color: var(--nav-text); }
  .it-nav-mobile a.active {
    background: var(--nav-active-bg);
    color: var(--nav-text);
    font-weight: 600;
  }
  .it-nav-mobile a svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* SIDEBAR SEPARATOR */
  .it-nav-mobile .m-sep {
    border: none;
    border-top: 0.5px solid var(--nav-border);
    margin: 8px 2px;
  }

  /* SIDEBAR FOOTER: user info + logout */
  .it-sidebar-footer {
    border-top: 0.5px solid var(--nav-border);
    padding: 12px 10px;
    flex-shrink: 0;
  }
  .it-nav-mobile .m-user {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 12px;
    border-radius: 9px;
    background: var(--nav-active-bg);
    margin-bottom: 6px;
  }
  .m-user-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .m-user-name { font-size: 12px; font-weight: 600; color: var(--nav-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .m-user-role-wrap { display: flex; align-items: center; gap: 4px; }

  /* SIDEBAR THEME TOGGLE */
  .it-sidebar-theme {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 9px;
    cursor: pointer;
    background: none;
    border: none;
    color: var(--nav-text2);
    font-size: 12px;
    font-weight: 500;
    width: 100%;
    text-align: left;
    transition: background 0.12s, color 0.12s;
    margin-bottom: 4px;
  }
  .it-sidebar-theme:hover { background: var(--nav-hover-bg); color: var(--nav-text); }

  @media (max-width: 768px) {
    .it-nav-links, .it-nav-right { display: none; }
    .it-nav-hamburger { display: flex; align-items: center; }
    .it-nav { padding: 0 16px; }
  }

  /* ===== AI CHATBOX MOBILE RESPONSIVE ===== */
  @media (max-width: 480px) {
    #ai-panel {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      max-height: 75vh;
      border-radius: 20px 20px 0 0;
      border-bottom: none;
    }
    #ai-fab {
      bottom: 16px;
      right: 16px;
      width: 48px;
      height: 48px;
    }
  }
</style>

<%
  /* LOGIKA AKSES MENU YANG SUDAH DIPERKETAT */
  // 1. Cek apakah yang login adalah Admin Utama (punya hak kelola User)
  var isAdmin = currentUser && userPerms && userPerms.canUsers;
  
  // 2. KUNCI AUDIT: Jika dia dicentang Audit DAN bukan Admin Utama, kunci total menunya!
  var isAuditOnly = currentUser && userPerms && userPerms.canAudit && !isAdmin;
  
  // 3. Logika untuk user IT atau Admin
  var isItOrAdmin = currentUser && !isAuditOnly && (
    isAdmin ||
    (currentUser.divisi && currentUser.divisi.toLowerCase() === 'it')
  );
  
  // 4. Logika untuk user divisi biasa (non-IT, non-Audit)
  var isNonItUser = currentUser && !isItOrAdmin && !isAuditOnly && userPerms && userPerms.canAsset && !userPerms.canViewLog;
  
  var asetPublicHref = currentUser ? '/aset-public/' + encodeURIComponent(currentUser.divisi || 'IT') : '/aset-public';

  /* LOGIKA KLIK LOGO BRAND */
  var brandHref = '/kerja';
  if (isAuditOnly) brandHref = '/audit';
  else if (isNonItUser) brandHref = '/aset';
  else if (!currentUser) brandHref = '/';
%>

<nav class="it-nav" id="mainNav">
  <a href="<%= brandHref %>" class="it-nav-brand">&gt;_ IT <span>SUPPORT</span> LOG</a>

  <div class="it-nav-links">
    <% if (isAuditOnly) { %>
      <!-- JIKA YANG LOGIN TIM AUDIT, KUNCI HANYA DI MENU INI -->
      <a href="/audit" class="it-nav-link <%= activePage === 'audit' ? 'active' : '' %>" style="color:#f59e0b;">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="4"/><line x1="9" y1="9" x2="14" y2="14"/><line x1="4" y1="6" x2="8" y2="6"/><line x1="6" y1="4" x2="6" y2="8"/></svg>
        Dashboard Audit
      </a>

    <% } else if (isNonItUser) { %>
      <!-- JIKA YANG LOGIN USER DIVISI LAIN (NON IT/AUDIT) -->
      <a href="<%= asetPublicHref %>" class="it-nav-link <%= activePage === 'aset-public' ? 'active' : '' %>">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 6.5L8 2l6 4.5V14a1 1 0 01-1 1H3a1 1 0 01-1-1V6.5z"/></svg>
        Home
      </a>
      <a href="/aset" class="it-nav-link <%= activePage === 'aset' ? 'active' : '' %>">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/></svg>
        Dashboard Aset
      </a>
      <% if (typeof currentUser !== 'undefined' && currentUser && userPerms && userPerms.canVendor) { %>
      <a href="/vendor" class="it-nav-link <%= activePage === 'vendor' ? 'active' : '' %>" style="color:#4da6ff;">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 7h12v7a1 1 0 01-1 1H3a1 1 0 01-1-1V7z"/><path d="M1 7h14M4 7V4a2 2 0 012-2h4a2 2 0 012 2v3"/></svg>
        Vendor
      </a>
      <% } %>

    <% } else { %>
      <!-- JIKA YANG LOGIN ADMIN / IT / PUBLIC -->
      <a href="/" class="it-nav-link <%= activePage === 'view' ? 'active' : '' %>">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 6.5L8 2l6 4.5V14a1 1 0 01-1 1H3a1 1 0 01-1-1V6.5z"/></svg>
        Home
      </a>
      
      <% if (currentUser && userPerms && userPerms.canViewLog) { %>
      <a href="/kerja" class="it-nav-link <%= activePage === 'dashboard' ? 'active' : '' %>">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/></svg>
        Dashboard IT
      </a>
      <% } %>
      
      <% if (!currentUser || (userPerms && userPerms.canAsset)) { %>
      <%
        var isAdminRole   = currentUser && userPerms && (userPerms.canUsers || userPerms.canAudit);
