<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master Vendor — IT Support Log</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0f1117">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { background: var(--body-bg) !important; color: var(--body-text) !important; font-family: 'Inter', -apple-system, sans-serif; margin: 0; transition: background 0.25s, color 0.25s; }
        .page-wrap { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }

        /* FORM PANEL */
        .form-panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; padding: 1.25rem; position: sticky; top: 72px; }
        .form-panel h6 { font-size: 0.78rem; font-weight: 700; color: #4da6ff; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; }
        .f-label { display: block; font-size: 0.68rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
        .f-input { background: var(--body-input) !important; border: 1px solid var(--body-input-border) !important; border-radius: 6px; color: var(--body-text) !important; padding: 8px 10px; width: 100%; margin-bottom: 0.65rem; font-size: 0.83rem; outline: none; transition: border-color 0.15s; }
        .f-input:focus { border-color: var(--body-input-focus) !important; }
        .btn-add { background: #0d1a38; border: 1px solid #1a2d5c; color: #4da6ff; width: 100%; padding: 9px; border-radius: 6px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all 0.15s; margin-top: 4px; }
        .btn-add:hover { background: #0f2040; }

        /* MAIN PANEL */
        .main-panel { background: var(--body-card); border: 1px solid var(--body-border); border-radius: 12px; overflow: hidden; }
        .panel-header { padding: 1rem 1.25rem; border-bottom: 1px solid var(--body-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        .panel-title { font-size: 0.82rem; font-weight: 700; color: var(--body-text2); text-transform: uppercase; letter-spacing: 0.07em; }

        /* FILTER BAR */
        .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; }
        .filter-bar .f-input { margin-bottom: 0; width: auto; min-width: 150px; }
        .btn-filter { background: #1a1a1a; color: #fff; border: 1px solid #333; padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
        .btn-filter:hover { background: #333; }
        .btn-reset  { background: var(--body-bg); border: 1px solid var(--body-border); color: var(--body-text2); padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.15s; display: inline-flex; align-items: center; }
        .btn-reset:hover { border-color: var(--body-border2); color: var(--body-text); }

        /* TABLE */
        .vendor-table { width: 100%; border-collapse: collapse; min-width: 800px; }
        .vendor-table th { padding: 10px 14px; font-size: 0.65rem; font-weight: 700; color: var(--body-text3); text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--body-border); background: var(--body-bg); text-align: left; white-space: nowrap; }
        .vendor-table td { padding: 11px 14px; font-size: 0.83rem; color: var(--body-text); border-bottom: 1px solid var(--body-border); vertical-align: middle; }
        .vendor-table tr:last-child td { border-bottom: none; }
        .vendor-table tr:hover td { background: var(--body-bg3); }

        /* ACTION BTN */
        .act-btn { background: none; border: 1px solid var(--body-border); color: var(--body-text2); padding: 4px 9px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; cursor: pointer; transition: all 0.12s; }
        .act-btn.blue:hover  { border-color: #2a3d6a; color: #7eb8f7; background: #0d1a38; }
        .act-btn.red:hover   { border-color: #5c1a1a; color: #f87171; background: #2a0d0d; }

        /* DIVISI TAG */
        .div-tag { display:inline-block;padding:2px 7px;border-radius:4px;font-size:0.62rem;font-weight:700;background:#1a2d3d;color:#7eb8f7;border:1px solid #1a3d5c; }
        
        /* CATEGORY TAG */
        .cat-tag { display:inline-block;padding:2px 7px;border-radius:4px;font-size:0.62rem;font-weight:700;background:#1a1a0d;color:#fde68a;border:1px solid #5c4a00; }

        /* MODAL */
        .m-content { background: var(--body-card) !important; border: 1px solid var(--body-border) !important; }
        .m-header  { border-bottom: 1px solid var(--body-border) !important; }
        .m-footer  { border-top: 1px solid var(--body-border) !important; }

        /* ALERT */
        .alert-success-custom { background: #0d2a18; border: 1px solid #1a5c30; color: #4ade80; border-radius: 8px; padding: 10px 14px; font-size: 0.82rem; font-weight: 600; margin-bottom: 1rem; }
        .alert-error-custom   { background: #2a0d0d; border: 1px solid #5c1a1a; color: #f87171; border-radius: 8px; padding: 10px 14px; font-size: 0.82rem; font-weight: 600; margin-bottom: 1rem; }

        @media (max-width: 768px) { .page-wrap { padding: 1rem; } .form-panel { position: static; margin-bottom: 1rem; } }
    </style>
</head>
<body>
<%- include('navbar', {activePage: 'vendor'}) %>

<div class="page-wrap">
  <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="<%= msgType === 'error' ? 'alert-error-custom' : 'alert-success-custom' %>">
      <%- msgType === 'error' ? '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' : '<svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>' %> <%= msg %>
    </div>
  <% } %>

  <div class="row g-4">

    <!-- TABLE FULL WIDTH -->
    <div class="col-12">
      <div class="main-panel">
        <div class="panel-header">
          <div class="panel-title">Master Data Vendor (<%= vendors.length %>)</div>
          
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
            <!-- FILTER -->
            <form action="/vendor" method="GET" class="filter-bar">
              <input type="text" name="q" class="f-input" placeholder="Cari nama/alamat..." value="<%= q %>">
              <select name="kategori" class="f-input">
                <option value="">-- Semua Kategori --</option>
                <% allKategori.forEach(k => { %>
                  <option value="<%= k %>" <%= k === kategori ? 'selected' : '' %>><%= k %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn-filter">Cari</button>
              <a href="/vendor" class="btn-reset">Reset</a>
            </form>

            <!-- TOMBOL TAMBAH -->
            <button type="button" class="btn-add" style="width:auto;margin:0;padding:8px 16px;display:flex;align-items:center;gap:6px;white-space:nowrap;" onclick="new bootstrap.Modal(document.getElementById('modalTambahVendor')).show()">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Tambah Vendor
            </button>
          </div>

        </div>
        <div style="overflow-x:auto;">
          <table class="vendor-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Nama Vendor</th>
                <th>Kategori & Divisi</th>
                <th>Kontak & Alamat</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (vendors.length === 0) { %>
                <tr><td colspan="5" style="text-align:center; padding: 2rem; color:var(--body-text3);">Tidak ada data vendor.</td></tr>
              <% } %>
              <% vendors.forEach((v, i) => { %>
              <tr>
                <td style="color:var(--body-text3);font-size:0.75rem;"><%= i+1 %></td>
                <td>
                  <strong><%= v.nama %></strong>
                  <% if (v.keterangan) { %>
                  <div style="font-size:0.72rem; color:var(--body-text2); margin-top:3px;"><%= v.keterangan %></div>
                  <% } %>
                </td>
                <td>
                  <span class="cat-tag"><%= v.kategori %></span>
                  <div style="margin-top:4px;"><span class="div-tag"><%= v.divisi %></span></div>
                </td>
                <td>
                  <div style="font-size:0.8rem; color:var(--body-text);"><%= v.noHp || '-' %></div>
                  <div style="font-size:0.72rem; color:var(--body-text2); margin-top:2px; max-width:200px; white-space:normal;"><%= v.alamat || '-' %></div>
                </td>
                <td>
                  <div style="display:flex;gap:5px;">
                    <button class="act-btn blue" onclick="openEditModal(
                      <%= v.id %>,
                      `<%= v.nama.replace(/`/g,'\\`') %>`,
                      `<%= (v.kategori || '').replace(/`/g,'\\`') %>`,
                      `<%= (v.noHp || '').replace(/`/g,'\\`') %>`,
                      `<%- (v.alamat || '').replace(/`/g,'\\`').replace(/\n/g,'\\n') %>`,
                      `<%- (v.keterangan || '').replace(/`/g,'\\`').replace(/\n/g,'\\n') %>`,
                      `<%= v.divisi %>`
                    )">Edit</button>
                    
                    <form action="/vendor/hapus/<%= v.id %>" method="POST" style="margin:0;" onsubmit="return confirm('Yakin hapus vendor ini?');">
                        <button type="submit" class="act-btn red">Hapus</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL EDIT VENDOR -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content m-content">
      <div class="modal-header m-header">
        <h5 class="modal-title"><svg class="lc" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit Vendor</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formEdit" action="" method="POST">
        <div class="modal-body">
            <label class="f-label">Nama Vendor / Bengkel *</label>
            <input type="text" name="nama" id="edit_nama" class="f-input" required>

            <label class="f-label">Kategori</label>
            <input type="text" name="kategori" id="edit_kategori" class="f-input" list="catListEdit">
            <datalist id="catListEdit">
                <option value="Bengkel Kendaraan">
                <option value="Toko Komputer / IT">
                <option value="Service AC">
                <option value="Kontraktor Sipil">
            </datalist>

            <label class="f-label">No HP / Telepon</label>
            <input type="text" name="noHp" id="edit_noHp" class="f-input">

            <label class="f-label">Alamat Lengkap</label>
            <textarea name="alamat" id="edit_alamat" class="f-input" rows="2"></textarea>
            
            <label class="f-label">Keterangan / Notes</label>
            <textarea name="keterangan" id="edit_keterangan" class="f-input" rows="2"></textarea>

            <% if (currentUser && userPerms && userPerms.canUsers) { %>
            <label class="f-label">Akses Divisi <span style="color:var(--body-text3);font-size:0.6rem;">(Khusus Admin)</span></label>
            <input type="text" name="divisi" id="edit_divisi" class="f-input" style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()">
            <% } %>
        </div>
        <div class="modal-footer m-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary fw-bold">Simpan Perubahan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- MODAL TAMBAH VENDOR -->
<div class="modal fade" id="modalTambahVendor" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:480px;">
    <div class="modal-content m-content" style="border-radius:14px;max-height:90vh;display:flex;flex-direction:column;">
      <div class="modal-header m-header" style="padding:14px 20px;flex-shrink:0;">
        <h6 class="modal-title" style="color:#4da6ff;font-weight:700;font-size:0.85rem;letter-spacing:0.06em;text-transform:uppercase;margin:0;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Tambah Vendor Baru
        </h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/vendor/tambah" method="POST" style="display:flex;flex-direction:column;flex:1;min-height:0;">
        <div class="modal-body" style="padding:20px;overflow-y:auto;flex:1;">

          <label class="f-label">Nama Vendor / Bengkel *</label>
          <input type="text" name="nama" class="f-input" placeholder="cth: Bengkel Tiga Berlian" required>

          <label class="f-label">Kategori</label>
          <input type="text" name="kategori" class="f-input" placeholder="cth: Bengkel Mobil, Toko IT..." list="catListM">
          <datalist id="catListM">
            <option value="Bengkel Kendaraan">
            <option value="Toko Komputer / IT">
            <option value="Service AC">
            <option value="Kontraktor Sipil">
            <option value="Pembasmi Tikus">
          </datalist>

          <label class="f-label">No HP / Telepon</label>
          <input type="text" name="noHp" class="f-input" placeholder="cth: 08123456789">

          <label class="f-label">Alamat Lengkap</label>
          <textarea name="alamat" class="f-input" rows="3" placeholder="Alamat bengkel/toko..."></textarea>

          <label class="f-label">Keterangan / Notes</label>
          <textarea name="keterangan" class="f-input" rows="2" placeholder="Informasi tambahan..."></textarea>

          <% if (currentUser && userPerms && userPerms.canUsers) { %>
          <label class="f-label">Akses Divisi <span style="color:var(--body-text3);font-size:0.6rem;">(Khusus Admin)</span></label>
          <input type="text" name="divisi" class="f-input" value="IT" style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()">
          <% } %>

        </div>
        <div class="modal-footer m-footer" style="padding:12px 20px;flex-shrink:0;">
          <button type="button" class="btn btn-sm fw-bold" data-bs-dismiss="modal" style="background:var(--body-bg3);border:1px solid var(--body-border);color:var(--body-text2);">Batal</button>
          <button type="submit" class="btn-add" style="width:auto;margin:0;padding:8px 24px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:5px;"><polyline points="20 6 9 17 4 12"/></svg>
            Simpan Vendor
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
function openEditModal(id, nama, kategori, noHp, alamat, keterangan, divisi) {
  document.getElementById('formEdit').action     = '/vendor/edit/' + id;
  document.getElementById('edit_nama').value     = nama;
  document.getElementById('edit_kategori').value = kategori;
  document.getElementById('edit_noHp').value     = noHp;
  document.getElementById('edit_alamat').value   = alamat.replace(/\\n/g, '\n');
  document.getElementById('edit_keterangan').value = keterangan.replace(/\\n/g, '\n');
  
  const divEl = document.getElementById('edit_divisi');
  if(divEl) divEl.value = divisi;

  new bootstrap.Modal(document.getElementById('editModal')).show();
}
</script>
<script src="/offline-sync.js"></script>
<script>
if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
        navigator.serviceWorker.register('/sw.js').catch(function() {});
    });
}
</script>
</body>
</html>