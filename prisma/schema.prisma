generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Journal {
  id            Int      @id @default(autoincrement())
  tanggalManual DateTime
  jamMulai      String?
  jamSelesai    String?
  durasiMenit   Int?
  aktivitas     String
  divisi        String
  pemesan       String
  deskripsi     String   @db.Text
  status        String
  fotoUrl       String?
  fotoAwalUrl   String?
  createdAt     DateTime @default(now())
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
