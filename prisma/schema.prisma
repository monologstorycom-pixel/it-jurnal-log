generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Journal {
  id             Int       @id @default(autoincrement())
  tipeInput      String?   @default("harian")
  tanggalMulai   DateTime?
  tanggalSelesai DateTime?
  tanggalManual  DateTime
  jamMulai       String?
  jamSelesai     String?
  durasiMenit    Int?
  aktivitas      String
  divisi         String
  pemesan        String
  deskripsi      String    @db.Text
  status         String
  fotoUrl        String?
  fotoAwalUrl    String?
  createdAt      DateTime  @default(now())
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Aset {
  id          Int              @id @default(autoincrement())
  nama        String
  divisi      String           @default("IT")
  kategori    String           @default("Umum")
  satuan      String           @default("unit")
  stokAwal    Int              @default(0)
  stok        Int              @default(0)
  kondisi     String           @default("Baik")
  keterangan  String?          @db.Text
  fotoUrl     String?
  foto2Url    String?          // Foto ke-2
  foto3Url    String?          // Foto ke-3
  createdAt   DateTime         @default(now())
  penggunaan  AsetPenggunaan[]
  pinjaman    AsetPinjam[]
  service     AsetService[]
}

model AsetPenggunaan {
  id          Int      @id @default(autoincrement())
  asetId      Int
  aset        Aset     @relation(fields: [asetId], references: [id], onDelete: Cascade)
  jumlah      Int      @default(1)
  divisi      String
  lokasi      String
  keterangan  String?  @db.Text
  fotoUrl     String?
  tanggal     DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AsetPinjam {
  id              Int       @id @default(autoincrement())
  asetId          Int
  aset            Aset      @relation(fields: [asetId], references: [id], onDelete: Cascade)
  jumlah          Int       @default(1)
  peminjam        String
  divisi          String
  keperluan       String?   @db.Text
  fotoUrl         String?
  tanggalPinjam   DateTime  @default(now())
  tanggalKembali  DateTime?
  status          String    @default("Dipinjam")
  createdAt       DateTime  @default(now())
}

model AsetService {
  id             Int       @id @default(autoincrement())
  asetId         Int
  aset           Aset      @relation(fields: [asetId], references: [id], onDelete: Cascade)
  teknisi        String
  vendor         String?
  keluhan        String    @db.Text
  hasil          String?   @db.Text
  biaya          Int?      @default(0)
  status         String    @default("Proses")
  tanggal        DateTime  @default(now())
  tanggalSelesai DateTime?
  fotoUrl        String?
  createdAt      DateTime  @default(now())
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String
  nama        String
  role        String   @default("user")
  divisi      String   @default("IT")
  permissions String?  @db.Text
  isAudit     Boolean  @default(false)
  fotoUrl     String?
  createdAt   DateTime @default(now())
}

model Vendor {
  id          Int      @id @default(autoincrement())
  nama        String
  kategori    String   @default("Umum")
  alamat      String?  @db.Text
  noHp        String?
  divisi      String   @default("IT")
  keterangan  String?  @db.Text
  createdAt   DateTime @default(now())
}
